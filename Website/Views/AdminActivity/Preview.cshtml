@model Cubetech.Website.Models.Activity
@{
    ViewBag.Title = "Xem trước hoạt động";
    Layout = null; // No layout for preview
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>@ViewBag.Title - @Model.Title</title>
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    
    <style>
        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        
        .preview-container {
            max-width: 800px;
            margin: 2rem auto;
            background: white;
            border-radius: 20px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            overflow: hidden;
        }
        
        .preview-header {
            background: linear-gradient(135deg, #2d3748, #4a5568);
            color: white;
            padding: 2rem;
            text-align: center;
        }
        
        .preview-badge {
            background: rgba(255,255,255,0.2);
            color: white;
            padding: 0.5rem 1rem;
            border-radius: 20px;
            font-size: 0.9rem;
            font-weight: 600;
            margin-bottom: 1rem;
            display: inline-block;
            backdrop-filter: blur(10px);
        }
        
        .preview-title {
            font-size: 2rem;
            font-weight: 700;
            margin-bottom: 1rem;
            text-shadow: 0 2px 4px rgba(0,0,0,0.3);
        }
        
        .preview-meta {
            display: flex;
            justify-content: center;
            gap: 2rem;
            flex-wrap: wrap;
            opacity: 0.9;
        }
        
        .meta-item {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 0.95rem;
        }
        
        .preview-content {
            padding: 2rem;
        }
        
        .preview-image {
            width: 100%;
            height: 300px;
            object-fit: cover;
            border-radius: 15px;
            margin-bottom: 2rem;
            box-shadow: 0 10px 30px rgba(0,0,0,0.15);
        }
        
        .preview-description {
            font-size: 1.1rem;
            line-height: 1.8;
            color: #4a5568;
            margin-bottom: 2rem;
        }
        
        .preview-details {
            background: #f8f9fa;
            padding: 1.5rem;
            border-radius: 15px;
            margin-bottom: 2rem;
        }
        
        .detail-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0.75rem 0;
            border-bottom: 1px solid #e2e8f0;
        }
        
        .detail-row:last-child {
            border-bottom: none;
        }
        
        .detail-label {
            font-weight: 600;
            color: #2d3748;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        
        .detail-value {
            color: #4a5568;
            text-align: right;
        }
        
        .preview-actions {
            padding: 1.5rem 2rem;
            background: #f8f9fa;
            border-top: 1px solid #e2e8f0;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 1rem;
        }
        
        .btn-preview {
            padding: 0.75rem 1.5rem;
            border-radius: 25px;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.3s ease;
            border: none;
            cursor: pointer;
        }
        
        .btn-preview:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        }
        
        .btn-primary {
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: white;
        }
        
        .btn-secondary {
            background: #6c757d;
            color: white;
        }
        
        .btn-success {
            background: #28a745;
            color: white;
        }
        
        .status-indicator {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 0.9rem;
        }
        
        .status-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
        }
        
        .status-draft { background: #ffc107; }
        .status-published { background: #28a745; }
        .status-featured { background: #fd7e14; }
        
        @media (max-width: 768px) {
            .preview-container {
                margin: 1rem;
                border-radius: 15px;
            }
            
            .preview-header {
                padding: 1.5rem;
            }
            
            .preview-title {
                font-size: 1.5rem;
            }
            
            .preview-meta {
                flex-direction: column;
                gap: 0.5rem;
            }
            
            .preview-content {
                padding: 1.5rem;
            }
            
            .preview-actions {
                flex-direction: column;
                align-items: stretch;
            }
        }
    </style>
</head>
<body>
    <div class="preview-container">
        <!-- Header -->
        <div class="preview-header">
            <div class="preview-badge">
                <i class="fas fa-eye"></i> Xem trước hoạt động
            </div>
            <h1 class="preview-title">@Model.Title</h1>
            <div class="preview-meta">
                <div class="meta-item">
                    <i class="fas fa-tag"></i>
                    <span>@Model.TypeLabel</span>
                </div>
                @if (Model.StartDate.HasValue)
                {
                    <div class="meta-item">
                        <i class="fas fa-calendar"></i>
                        <span>@Model.StartDate.Value.ToString("dd/MM/yyyy")</span>
                    </div>
                }
                @if (!string.IsNullOrEmpty(Model.Location))
                {
                    <div class="meta-item">
                        <i class="fas fa-map-marker-alt"></i>
                        <span>@Model.Location</span>
                    </div>
                }
            </div>
        </div>
        
        <!-- Content -->
        <div class="preview-content">
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl" alt="@Model.Title" class="preview-image">
            }
            
            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <div class="preview-description">
                    @Html.Raw(Model.Description.Replace("\n", "<br>"))
                </div>
            }
            
            <!-- Details -->
            <div class="preview-details">
                <h5 style="margin-bottom: 1rem; color: #2d3748;">
                    <i class="fas fa-info-circle"></i> Chi tiết hoạt động
                </h5>
                
                @if (Model.StartDate.HasValue || Model.EndDate.HasValue)
                {
                    <div class="detail-row">
                        <div class="detail-label">
                            <i class="fas fa-clock"></i> Thời gian
                        </div>
                        <div class="detail-value">
                            @if (Model.StartDate.HasValue && Model.EndDate.HasValue)
                            {
                                <span>@Model.StartDate.Value.ToString("dd/MM/yyyy HH:mm") - @Model.EndDate.Value.ToString("dd/MM/yyyy HH:mm")</span>
                            }
                            else if (Model.StartDate.HasValue)
                            {
                                <span>@Model.StartDate.Value.ToString("dd/MM/yyyy HH:mm")</span>
                            }
                        </div>
                    </div>
                }
                
                @if (Model.Participants.HasValue)
                {
                    <div class="detail-row">
                        <div class="detail-label">
                            <i class="fas fa-users"></i> Số người tham gia
                        </div>
                        <div class="detail-value">@Model.Participants người</div>
                    </div>
                }
                
                <div class="detail-row">
                    <div class="detail-label">
                        <i class="fas fa-eye"></i> Lượt xem
                    </div>
                    <div class="detail-value">@Model.ViewCount lượt</div>
                </div>
                
                <div class="detail-row">
                    <div class="detail-label">
                        <i class="fas fa-calendar-plus"></i> Ngày tạo
                    </div>
                    <div class="detail-value">@Model.CreatedDate.ToString("dd/MM/yyyy HH:mm")</div>
                </div>
                
                @if (!string.IsNullOrEmpty(Model.DocumentUrl))
                {
                    <div class="detail-row">
                        <div class="detail-label">
                            <i class="fas fa-file-alt"></i> Tài liệu đính kèm
                        </div>
                        <div class="detail-value">
                            <a href="@Model.DocumentUrl" target="_blank" class="btn btn-sm btn-outline-primary">
                                <i class="fas fa-download"></i> Tải xuống
                            </a>
                        </div>
                    </div>
                }
            </div>
        </div>
        
        <!-- Actions -->
        <div class="preview-actions">
            <div class="status-indicator">
                <div class="status-dot @(Model.IsPublished ? "status-published" : "status-draft")"></div>
                <span>@(Model.IsPublished ? "Đã xuất bản" : "Bản nháp")</span>
                @if (Model.IsFeatured)
                {
                    <div class="status-dot status-featured"></div>
                    <span>Nổi bật</span>
                }
            </div>
            
            <div>
                <a href="@Url.Action("Edit", new { id = Model.ActivityID })" class="btn-preview btn-primary">
                    <i class="fas fa-edit"></i> Chỉnh sửa
                </a>
                @if (!Model.IsPublished)
                {
                    <button onclick="publishActivity()" class="btn-preview btn-success">
                        <i class="fas fa-eye"></i> Xuất bản
                    </button>
                }
                <button onclick="window.close()" class="btn-preview btn-secondary">
                    <i class="fas fa-times"></i> Đóng
                </button>
            </div>
        </div>
    </div>
    
    <script>
        function publishActivity() {
            if (confirm('Bạn có muốn xuất bản hoạt động này?')) {
                fetch('/AdminActivity/ToggleStatus', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                    },
                    body: `id=@Model.ActivityID&type=published&__RequestVerificationToken=${document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''}`
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        alert('Hoạt động đã được xuất bản!');
                        location.reload();
                    } else {
                        alert('Có lỗi xảy ra: ' + data.message);
                    }
                })
                .catch(error => {
                    alert('Có lỗi xảy ra khi xuất bản');
                });
            }
        }
    </script>
</body>
</html>
