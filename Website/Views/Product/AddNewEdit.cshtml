</div>
<table style="display:none">

    <tbody id="subItemTemplate">
        <tr prid="{id}">
            <td>
                <input type="checkbox" id="ckbDelete_i_" {checked} />
                <input type="hidden" name="ckbDelete_i_" />


            </td>
            <td>
                {id}
            </td>
            <td>
                {name}
            </td>
            <td>
                <input class="form-control pricesale" type="text" value="{pricesale}" onblur="txtPriceSaleKeyUp(this)" />
            </td>
            <td>
                <input class="form-control pricesale2" type="text" value="{pricesale2}" onblur="txtPriceSale2KeyUp(this)" />
            </td>
        </tr>
    </tbody>
</table>

<script>

    $(document).ready(function () {


        setMoneyTextBox(".money-textbox");
        setIcheck('#ckbIcheck', "[name=IsActive]", "true", "false", function (e) { });
        setIcheck("#ckbMutilStandard", "[name=IsMultipleStandard]", "true", "false", function (e) {
            if (e) {
                $(".divStandard").show();
            } else {
                $(".divStandard").hide();
            }
        });




        setIcheck("#cbkIsOverSales", "[name=IsOverSales]", "true", "false", function (e) {});
        setIcheck("#ckbIsShowWeb", "[name=IsShowWeb]", "true", "false", function (e) {});

        tinymce.init(tinymceOption('#DetailInfo'));
        tinymce.init(tinymceOption('#BasicInfo'));

        genarateSubItem();



    });

    @{
        var lstSub = dao.Model.Products.Where(f => f.ID == pro.ID && f.IDAndSize != f.ID).Select(f=> new { f.ID, f.IDAndSize, f.IsDelete, f.PriceSale,f.PriceSale2,f.Standard1,f.Standard2,f.Standard3,f.Standard4}).ToList();
        string sss = Newtonsoft.Json.JsonConvert.SerializeObject(lstSub);
    }

    var lstSubItem = @Html.Raw(sss);


    function addNewStandar() {
        var s = '';

        $(".ckbStandard").each(function (index) {
            if (index > 0)
                s += ',';
            s += $(this).val();
        });
        $.ajax({
            url: "@Url.Content("/Product/GetStandard")",
            data: { selected: s },
            success: function (data) {
                $("#rowAddNewStandard").before(data);
            }
        });
        return false;
    }

    function standardChange(e) {
        var id = $(e).val();
        $.ajax({
            url: "@Url.Content("/Product/GetTokenField")",
            data: { id: id },
            success: function (data) {
                $(e).closest("tr").find('.val_container').html(data);
                genarateSubItem();
            }
        });
    }

    function removeStandard(e) {
        $(e).closest("tr").remove();
        genarateSubItem();
    }

    function genarateSubItem(isKeepPrice) {
        var keepPrice =true;
        if(typeof isKeepPrice !="undefined" ){
            keepPrice = isKeepPrice;
        }
        var array = new Array();
        $(".standardVal").each(function (index) {
            var arrayToken = $(this).tokenfield('getTokens');
            var arrayVal = new Array();
            for (var i = 0; i < arrayToken.length; i++) {
                arrayVal.push(arrayToken[i].label);

            }
            console.log(arrayVal);
            array.push(arrayVal);

        });
        //lấy tổ hợp các tiêu chuẩn
        while (array.length > 1) {
            var arrayTarget = array[array.length - 2];
            var arraySource = array[array.length - 1];
            var arrayOut = new Array();
            for (var i = 0; i < arrayTarget.length; i++) {
                var item = arrayTarget[i];
                for (var j = 0; j < arraySource.length; j++) {
                    arrayOut.push(item + "_" + arraySource[j]);
                }
            }
            array[array.length - 2] = arrayOut;
            array.splice(array.length - 1, 1);
        }
        var listProduct = new Array();
        var id = $("#ID").val();
        var name = $("#Name").val();
        var price = $("#PriceSale").val();
        var priceSale = $("#PriceSale2").val();
        //xuất các tiêu chuẩn
        if (array.length == 1) {
            var arrayId = array[0];
            for (var i = 0; i < arrayId.length; i++) {
                console.log(arrayId[i]);

                var lstStandard =  arrayId[i].split("_");


                var prID = id + '_' + arrayId[i];
                var prName = name ;//+ ' ' + arrayId[i];
                var pr = { ID: id, IDAndSize: prID, Name: prName, PriceSale: price, PriceSale2: priceSale,Standard1: lstStandard[0], Standard2:lstStandard[1], Standard3:lstStandard[2], IsDelete: false };
                listProduct.push(pr);
                var old = getSubItemByID(prID);
                if (old != null) {
                    pr.IsDelete = old.IsDelete;
                    if(keepPrice){
                        pr.PriceSale = old.PriceSale;
                        pr.PriceSale2 = old.PriceSale2;
                    }

                }
            }
        }

        lstSubItem = listProduct;
        renderSubItem();

    }

    function renderSubItem() {
        var html = '';
        for (var i = 0; i < lstSubItem.length; i++) {
            html += renderOnceSubItem(lstSubItem[i], i);
        }
        $("#tblSubItems").html(html);
        for (var i = 0; i < lstSubItem.length; i++) {
            setIcheck("#ckbDelete" + i, "[name=ckbDelete" + i + "]", "true", "false", function (val, e) {
                console.log(e.currentTarget);
                ckbDeleteChange(val, e.currentTarget);
            });
        }
        //

        setMoneyTextBox(".pricesale");
        setMoneyTextBox(".pricesale2");


    }

    function renderOnceSubItem(item, i) {

        var template = $("#subItemTemplate").html();
        template = template.replace(/{id}/g, item.IDAndSize);
        template = template.replace(/{name}/g, item.Name);
        template = template.replace(/{pricesale}/g, item.PriceSale);
        template = template.replace(/{pricesale2}/g, item.PriceSale2);
        template = template.replace(/_i_/g, i);

        if (!item.IsDelete) {
            template = template.replace(/{checked}/g, 'checked');
        } else {
            template = template.replace(/{checked}/g, '');
        }


        return template;
    }





    function saveProduct() {
        if (!validate()) {
            return;
        }

        var fd = new FormData(document.getElementById("ProductForm"));

        fd.append("htmlDetailInfo",encodeURIComponent(tinyMCE.get('DetailInfo').getContent()));
        fd.append("htmlBasicInfo",encodeURIComponent(tinyMCE.get('BasicInfo').getContent()));



        fd.append("lst", JSON.stringify(lstSubItem));
        var array = new Array();
        $(".standardVal").each(function (index) {
            var arrayToken = $(this).tokenfield('getTokens');
            var arrayVal = new Array();
            var s = "";
            for (var i = 0; i < arrayToken.length; i++) {
                if (i > 0)
                    s += ',';
                s += arrayToken[i].label;
            }
            array.push(s);

        });
        var arrayS = new Array();
        var prID = $("#ID").val();
        var arrayStandardDetail = new Array();
        $(".ckbStandard").each(function (index) {
            var standarID = $(this).val();
            arrayStandardDetail.push({ ProductID: prID, StandardID: standarID, Val: array[index] });

        });

        fd.append("standardDetail", JSON.stringify(arrayStandardDetail));




        $.ajax({
            url: "@Url.Content("/Product/UpdateProduct")",
            type: "POST",
            data: fd,
            enctype: 'multipart/form-data',
            processData: false,  // tell jQuery not to process the data
            contentType: false,   // tell jQuery not to set contentType
            success: function (data) {
                switch (data.Code) {
                    case 1:
                        showSuccess("Thành công", "Lưu sản phẩm thành công");
                        $("#ModalProduct").modal("hide");
                        window.location="/Product/Index";
                        break;
                    case 2:
                        showError("Lỗi", "Mã sản phẩm này đã tồn tại");
                        break;
                    case 3:
                        showConfirm("Lỗi", "Sản phẩm này đã bị xóa. Bạn có muốn khôi phục lại sản phẩm này", function(){

                        }, function(){});
                        break;
                    default:

                }

            }
        });

        return false;
    }

    function validate() {
        if($("[name=IsMultipleStandard]").val()=="true")
        {
            if(  $(".standardVal").length==0){
                showError("Lỗi", "Bạn phải chọn ít nhât 1 thuộc tính");
                return false;
            }
            var checkVal =true;
            $(".standardVal").each(function (index) {
                var arrayToken = $(this).tokenfield('getTokens');
                if(arrayToken.length ==0){
                    showError("Lỗi", "Bạn phải chọn ít nhât 1 giá trị cho thuộc tính");
                    checkVal=  false;
                }


            });
            if(!checkVal)
                return false;

        }
        return true;
    }

    function getSubItemByID(id) {
        for (var i = 0; i < lstSubItem.length; i++) {
            var item = lstSubItem[i];
            if (item.IDAndSize == id)
                return item;
        }
        return null;
    }

    function txtPriceKeyUp(e) {
        var id = $(e).closest("tr").attr("prid");
        var val = $(e).val().replace(/,/g, "") * 1;
        var pr = getSubItemByID(id);
        if (pr != null)
            pr.PriceSale = val;
        console.log(pr);

    }

    function ckbDeleteChange(val, e) {
        var id = $(e).closest("tr").attr("prid");
        var pr = getSubItemByID(id);
        if (pr != null)
            pr.IsDelete = !val;
        console.log(pr);
    }

    function OnSuccessCategory(data) {
        if (data.Code === 1) {
            $('#ModalCategory').modal('hide');
            swal('Thành Công', data.message, 'success');
            $('#CategoryID').append('<option value=' + data.data.ID + '>' + data.data.Name + '</option>');
            $('#CategoryID').val(data.data.ID).trigger("change");
        } else {
            swal('Lỗi', data.message, 'error');
        }
    }
    function OnSuccessCategoryWeb(data) {

        if (data.Code == 1) {
            $('#ModalCategoryWeb').modal('hide');
            swal('Thành Công', data.message, 'success');
            $('#CategoryIDWebTarget').append('<option value=' + data.data.ID + '>' + data.data.Name + '</option>');
            $('#CategoryIDWebTarget').val(data.data.ID).trigger("change");
        } else {
            swal('Lỗi', data.message, 'error');
        }
    }
    function OnSuccessUnit(data) { UnitID
        if (data.Code === 1) {
            $('#ModalCategory').modal('hide');
            swal('Thành Công', data.message, 'success');
            $('#CategroryID').append('<option value=' + data.data.ID + '>' + data.data.Name + '</option>');
            $('#CategroryID').val(data.data.ID).trigger("change");
            $('#CategroryID').val(data.data.ID);
        } else {
            swal('Lỗi', data.message, 'error');
        }
    }
    function OnSuccessUnit(data) {
        if (data.Code === 1) {
            $('#ModalUnit').modal('hide');
            swal('Thành Công', data.message, 'success');
            $('#UnitID').append('<option value=' + data.data.ID + '>' + data.data.Name + '</option>');
            $('#UnitID').val(data.data.ID).trigger("change");
            $('#UnitID').val(data.data.ID);
        } else {
            swal('Lỗi', data.message, 'error');
        }
    }
    function OnSuccessBrand(data) {
        if (data.Code === 1) {
            $('#ModalBrand').modal('hide');
            showSuccess('Thành Công', data.message);
            $('#MarkerID').append('<option value=' + data.data.ID + '>' + data.data.Name + '</option>');
            $('#MarkerID').val(data.data.ID).trigger("change");
        } else {
            showError('Lỗi', data.message);
        }
    }
    function OnSuccessStandard(data) {
        if (data.Code === 1) {
            $('#ModalStandard').modal('hide');

            swal('Thành Công', data.message, 'success');
        } else {
            swal('Lỗi', data.message, 'error');
        }
    }

    function txtNameKeyup(e){
        //if(e.keyCode == 13){
        genarateSubItem();
        //}
    }

    function txtPriceSaleKeyup(e){
        //if(e.keyCode == 13){
        genarateSubItem(false);
        //}
    }

    function txtPriceSale2Keyup(e){
        //if(e.keyCode == 13){
        genarateSubItem(false);
        //}
    }


</script>


<table style="display:none">
    <tbody id="SetDetailTemplate">
        <tr>
            <td>{id}</td>
            <td>{name}</td>
            <td class="originalprice">
                <input class="form-control price detail_price" onblur="changePriceTable('{index}', this)" type="text" value="{price}" />
