    <script>
        var imageCallBack = ";";
        function openSelectImage(callback) {
            var url = '@Url.Content("/filepicker/index?callback=")severImageSelectCallBack&tinymce=0';
            $("#ifSelectIMG").attr("src", url);
            $("#popupSelectImage").modal("show");
            imageCallBack = callback;
        }
        var severImageSelectCallBack = function (url) {
            imageCallBack(url);
            $("#popupSelectImage").modal("hide");
        }
        function selectIMG(hiden, display) {
            openSelectImage(function (url) {
                $(hiden).val(url);
                $(display).attr("src", url);
            });
        }
        function deleteImageDetail(inputDisplay, inputValue) {
            $('#' + inputValue).val('');
            $('#' + inputDisplay).removeAttr("src");
            $("#" + inputDisplay).css('width', '100%');
        }
    </script>
    
