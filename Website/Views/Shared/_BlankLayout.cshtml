
<!DOCTYPE html>

<html>
<head>

    <meta charset="UTF-8">
    <meta name="robots" content="noindex">
    <meta name="googlebot" content="noindex">
    <script async src="https://cdn.ampproject.org/v0.js"></script>
    <link rel="canonical" href="@Request.Url.AbsoluteUri">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title</title>

    <script src="https://code.jquery.com/jquery-1.10.2.min.js" type="text/javascript"></script>
    <link rel="shortcut icon" href="@Url.Content("/Content/Image")/favicon.ico" />
    <link rel="icon" type="image/vnd.microsoft.icon" href="@Url.Content("/Content/Image")/favicon.ico" />

    <link href="~/Content/plugins/bootstrap/css/bootstrap.min.css" rel="stylesheet" />
    <script src="~/Content/plugins/bootstrap/js/bootstrap.min.js"></script>
    <link href="@Url.Content("~/Content/")plugins/font-awesome-4.7.0/css/font-awesome.min.css" rel="stylesheet" type="text/css" />


    <link href="~/Content/css/common.css" rel="stylesheet" />
    <script src="~/Scripts/common.js"></script>

    <script src="~/Scripts/jquery.unobtrusive-ajax.js"></script>
    <script src="~/Content/plugins/sweetalert2/sweetalert2.js"></script>
    <link href="~/Content/plugins/sweetalert2/sweetalert2.css" rel="stylesheet" />

</head>

<body>
    <div>
        @RenderBody()
    </div>

    <div class="waiting-spin-content-web">
        <img src="~/Content/Image/loading.gif" />
    </div>
</body>
</html>
