        }
        
        /* Ultimate fallback for the 3 specific icons */
        .contact-info .fas.fa-map-marker-alt:before {
            content: "\f3c5" !important;
            font-family: "Font Awesome 6 Free" !important;
            font-weight: 900 !important;
            display: inline-block !important;
        }
        
        .contact-info .fas.fa-phone-alt:before {
            content: "\f879" !important;
            font-family: "Font Awesome 6 Free" !important;
            font-weight: 900 !important;
            display: inline-block !important;
        }
        
        .contact-info .fas.fa-envelope:before {
            content: "\f0e0" !important;
            font-family: "Font Awesome 6 Free" !important;
            font-weight: 900 !important;
            display: inline-block !important;
        }
        
        /* Backup with Font Awesome 4 codes */
        .contact-info .fa-map-marker-alt:before {
            content: "\f041" !important; /* FA4 map-marker */
        }
        
        .contact-info .fa-phone-alt:before {
            content: "\f095" !important; /* FA4 phone */
        }
        
        .contact-info .fa-envelope:before {
            content: "\f0e0" !important; /* FA4 envelope */
        }
    </style>
    
    <!-- Essential JS - jQuery must load first, then other scripts can defer -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js" integrity="sha256-/xUj+3OJU5yExlq6GSYGSHk7tPXikynS7ogEvDej/m4=" crossorigin="anonymous"></script>
    
    <!-- Icon Fix Script - Defer for better performance -->
    <script defer>
        // Force fix icons if CSS fails
        document.addEventListener('DOMContentLoaded', function() {
            setTimeout(function() {
                // Check if icons are displaying correctly
                var contactIcons = document.querySelectorAll('.contact-info .fas');
                contactIcons.forEach(function(icon) {
                    var computedStyle = window.getComputedStyle(icon, ':before');
                    var content = computedStyle.getPropertyValue('content');
                    
                    // If icon is not displaying (showing X or empty)
                    if (!content || content === 'none' || content === '""') {
                        // Force add the correct unicode
                        if (icon.classList.contains('fa-map-marker-alt')) {
                            icon.innerHTML = '📍'; // Fallback emoji
                        } else if (icon.classList.contains('fa-phone-alt')) {
                            icon.innerHTML = '📞'; // Fallback emoji
                        } else if (icon.classList.contains('fa-envelope')) {
                            icon.innerHTML = '✉️'; // Fallback emoji
                        }
                        
                        // Add inline style to ensure visibility
                        icon.style.fontFamily = '"Font Awesome 6 Free", "Font Awesome 4", sans-serif';
                        icon.style.fontWeight = '900';
                        icon.style.display = 'inline-block';
                    }
                });
            }, 1000);
        });
    </script>
</head>
<body>
    <!-- Facebook SDK - Load asynchronously with connection awareness -->
    <div id="fb-root"></div>
    <script defer>
        (function (d, s, id) {
            // Check connection speed before loading Facebook SDK
            if (navigator.connection) {
                var connection = navigator.connection || navigator.mozConnection || navigator.webkitConnection;
                // Delay loading on slow connections
                if (connection.effectiveType === 'slow-2g' || connection.effectiveType === '2g' || connection.saveData) {
                    setTimeout(function() {
                        loadFacebookSDK();
                    }, 3000);
                    return;
                }
            }
            loadFacebookSDK();
            
            function loadFacebookSDK() {
                if (d.getElementById(id)) return;
                var js, fjs = d.getElementsByTagName(s)[0];
                js = d.createElement(s); js.id = id;
                js.src = 'https://connect.facebook.net/vi_VN/sdk.js#xfbml=1&version=v2.11&appId=1107474626060509&autoLogAppEvents=1';
                js.async = true;
                js.defer = true;
                fjs.parentNode.insertBefore(js, fjs);
            }
        }(document, 'script', 'facebook-jssdk'));
    </script>
    
