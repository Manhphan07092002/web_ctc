    <!-- Bootstrap JS - Required for button functions -->
    <script src="~/Content/plugins/bootstrap/js/bootstrap.min.js" defer></script>
    <!-- Fallback to CDN if local Bootstrap fails -->
    <script defer>
        (function() {
            function checkBootstrap() {
                if (typeof jQuery !== 'undefined' && (typeof jQuery().button === 'undefined')) {
                    var script = document.createElement('script');
                    script.src = 'https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/js/bootstrap.min.js';
                    script.async = true;
                    document.body.appendChild(script);
                } else if (typeof jQuery === 'undefined') {
                    setTimeout(checkBootstrap, 100);
                }
            }
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', checkBootstrap);
            } else {
                checkBootstrap();
            }
        })();
    </script>
    
    <!-- Bootstrap Compatibility Fix -->
    <script src="~/Scripts/bootstrap-compatibility-fix.js" defer></script>
    
    <!-- Header Responsive JavaScript -->
    <!-- Removed conflicting header-responsive.js script -->

    <!-- Google Analytics - Load asynchronously with connection awareness -->
    <script defer>
        (function() {
            // Delay analytics on slow connections to prioritize content
            function loadAnalytics() {
                try {
                    if (typeof ga !== 'undefined') {
                        ga('create', 'UA-69727220-2', 'auto');
                        ga('send', 'pageview');
                    }
                } catch (e) {
                    // Analytics setup failed - silent fail
                }
            }
            
            if (navigator.connection) {
                var connection = navigator.connection || navigator.mozConnection || navigator.webkitConnection;
                if (connection.effectiveType === 'slow-2g' || connection.effectiveType === '2g' || connection.saveData) {
                    // Delay analytics on slow connections
                    setTimeout(loadAnalytics, 2000);
                } else {
                    setTimeout(loadAnalytics, 100);
                }
            } else {
                setTimeout(loadAnalytics, 100);
            }
        })();
    </script>

    <!-- HIDE GOOGLE TRANSLATE UI -->
    <script src="~/Scripts/hide-google-translate-ui.js" defer></script>
    
    <!-- GT TRANSLATE INTEGRATOR - LIVE TRANSLATION WITHOUT RELOAD -->
    <script src="~/Scripts/gt-translate-integrator.js" defer></script>
    
    <!-- Performance monitoring and optimization -->
    <script defer>
        // Global image error handler - prevent 404 errors from cluttering console
        (function() {
            'use strict';
            
            // Handle broken images gracefully - prevent 404 errors
            var defaultFallback = '@Url.Content("~/Content/Image/noimage.png")';
            
            document.addEventListener('error', function(e) {
                if (e.target.tagName === 'IMG') {
                    var img = e.target;
                    var fallbackSrc = img.getAttribute('data-fallback') || defaultFallback;
                    
                    // Only replace if not already using fallback and not already handled
                    if (!img.dataset.errorHandled && img.src !== fallbackSrc) {
                        img.dataset.errorHandled = 'true';
                        img.src = fallbackSrc;
                        img.style.opacity = '0.7'; // Slightly fade broken images
                    }
                }
            }, true); // Use capture phase
            
            // Also handle images that fail to load after page load
            window.addEventListener('load', function() {
                var images = document.querySelectorAll('img[data-fallback]');
                images.forEach(function(img) {
                    if (!img.complete || img.naturalHeight === 0) {
                        var fallbackSrc = img.getAttribute('data-fallback') || defaultFallback;
                        if (img.src !== fallbackSrc && !img.dataset.errorHandled) {
                            img.dataset.errorHandled = 'true';
                            img.src = fallbackSrc;
                            img.style.opacity = '0.7';
                        }
                    }
                });
            });
            
            // Log performance metrics in development
            if (window.performance && window.performance.timing) {
                window.addEventListener('load', function() {
                    setTimeout(function() {
                        var perfData = window.performance.timing;
                        var pageLoadTime = perfData.loadEventEnd - perfData.navigationStart;
                        var domReadyTime = perfData.domContentLoadedEventEnd - perfData.navigationStart;
                        
                        // Only log if load time is significant (helps identify issues)
                        // Logging disabled for production - uncomment for debugging
                        // if (pageLoadTime > 3000) {
                        //     console.log('Page Load Time: ' + (pageLoadTime / 1000).toFixed(2) + 's');
                        //     console.log('DOM Ready Time: ' + (domReadyTime / 1000).toFixed(2) + 's');
                        // }
                    }, 0);
                });
            }
            
            // Connection-aware resource loading
            if (navigator.connection) {
                var connection = navigator.connection || navigator.mozConnection || navigator.webkitConnection;
                if (connection.saveData || connection.effectiveType === 'slow-2g' || connection.effectiveType === '2g') {
                    // Disable animations and reduce quality on slow connections
                    document.documentElement.classList.add('slow-connection');
                    
                    // Reduce video quality
                    var videos = document.querySelectorAll('video');
                    videos.forEach(function(video) {
                        video.preload = 'none';
                    });
                }
            }
            
            // Optimize scroll performance with passive listeners
            var ticking = false;
            function optimizeScroll() {
                if (!ticking) {
                    window.requestAnimationFrame(function() {
                        // Scroll optimizations
                        ticking = false;
                    });
                    ticking = true;
                }
            }
            
            // Use passive event listeners for better scroll performance
            window.addEventListener('scroll', optimizeScroll, { passive: true });
            window.addEventListener('touchmove', optimizeScroll, { passive: true });
            
            // Optimize scroll performance
            if ('requestIdleCallback' in window) {
                requestIdleCallback(function() {
                    // Defer non-critical operations
                    var lazyElements = document.querySelectorAll('[data-lazy]');
                    lazyElements.forEach(function(el) {
                        // Process lazy elements when browser is idle
                    });
                });
            }
        })();
    </script>
    
    <!-- Additional CSS for slow connections -->
    <style>
        .slow-connection * {
            animation-duration: 0.01ms !important;
            animation-iteration-count: 1 !important;
            transition-duration: 0.01ms !important;
        }
        
        .slow-connection video {
            display: none;
        }
        
        .slow-connection .hero-overlay {
            background: linear-gradient(135deg, #2677f1 0%, #1565c0 50%, #0d47a1 100%) !important;
            animation: none !important;
        }
    </style>

</body>
