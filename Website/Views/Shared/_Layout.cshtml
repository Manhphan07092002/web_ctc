    <!-- Icon Fix CSS -->
    <style>
        /* Fix icon conflicts and ensure visibility */
        .fa, .fas, .far, .fal, .fab, .bi {
            font-family: "Font Awesome 6 Free", "Font Awesome 4", "bootstrap-icons" !important;
            font-weight: 900;
            font-style: normal;
            font-variant: normal;
            text-rendering: auto;
            line-height: 1;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }
        
        /* Ensure icons are visible */
        .fa:before, .fas:before, .far:before, .fal:before, .fab:before, .bi:before {
            display: inline-block;
            font-style: normal;
            font-variant: normal;
            text-rendering: auto;
            -webkit-font-smoothing: antialiased;
        }
        
        /* Fix missing icons with fallback - Enhanced */
        .fa-phone-alt:before, .fas.fa-phone-alt:before { content: "\f879" !important; }
        .fa-envelope:before, .fas.fa-envelope:before { content: "\f0e0" !important; }
        .fa-map-marker-alt:before, .fas.fa-map-marker-alt:before { content: "\f3c5" !important; }
        .fa-facebook-f:before, .fab.fa-facebook-f:before { content: "\f39e" !important; }
        .fa-youtube:before, .fab.fa-youtube:before { content: "\f167" !important; }
        .fa-linkedin-in:before, .fab.fa-linkedin-in:before { content: "\f0e1" !important; }
        .fa-paper-plane:before, .fas.fa-paper-plane:before { content: "\f1d8" !important; }
        .fa-times:before, .fas.fa-times:before { content: "\f00d" !important; }
        .fa-caret-down:before, .fas.fa-caret-down:before { content: "\f0d7" !important; }
        
        /* Additional footer icons */
        .fa-phone:before, .fas.fa-phone:before { content: "\f095" !important; }
        .fa-location-dot:before, .fas.fa-location-dot:before { content: "\f3c5" !important; }
        .fa-envelope-open:before, .fas.fa-envelope-open:before { content: "\f2b6" !important; }
        
        /* Force icon display for problematic icons */
        i.fas:before, i.fab:before, i.fa:before {
            font-family: "Font Awesome 6 Free", "Font Awesome 4", "FontAwesome" !important;
            font-weight: 900 !important;
            display: inline-block !important;
            font-style: normal !important;
            font-variant: normal !important;
            text-rendering: auto !important;
            line-height: 1 !important;
            -webkit-font-smoothing: antialiased !important;
            -moz-osx-font-smoothing: grayscale !important;
        }
        
        /* Specific fixes for the 3 problematic icons */
        .fas.fa-map-marker-alt:before { content: "\f3c5" !important; font-family: "Font Awesome 6 Free" !important; }
        .fas.fa-phone-alt:before { content: "\f879" !important; font-family: "Font Awesome 6 Free" !important; }
        .fas.fa-envelope:before { content: "\f0e0" !important; font-family: "Font Awesome 6 Free" !important; }
        
        /* Fix Bootstrap caret */
        .caret {
            display: inline-block;
            width: 0;
            height: 0;
            margin-left: 2px;
            vertical-align: middle;
            border-top: 4px solid;
            border-right: 4px solid transparent;
            border-left: 4px solid transparent;
        }
        
        /* Fix navbar toggle icon bars */
        .navbar-toggle .icon-bar {
            display: block;
            width: 22px;
            height: 2px;
            border-radius: 1px;
            background-color: #fff;
            margin: 4px 0;
        }
        
        /* Footer icon fixes */
        footer .fas, footer .fab, footer .fa {
            font-family: "Font Awesome 6 Free", "Font Awesome 4" !important;
            font-weight: 900 !important;
            display: inline-block;
            font-style: normal;
            font-variant: normal;
            text-rendering: auto;
            line-height: 1;
            margin-right: 8px;
            width: 16px;
            text-align: center;
        }
        
        /* Social icons specific styling */
          .social-icons .fab {
             font-size: 16px;
              line-height: 1;
          }
        
        /* Contact info icons - Enhanced fix */
        .contact-info .fas {
            font-size: 14px;
            color: #007bff;
            margin-right: 10px;
            width: 20px;
            text-align: center;
            font-family: "Font Awesome 6 Free" !important;
