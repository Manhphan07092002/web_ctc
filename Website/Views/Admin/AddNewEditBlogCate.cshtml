
@{
    Layout = null;
    var blogcate = ViewData["obj"] as Cubetech.Website.Models.BlogCategory;
}
<div class="modal" id="modalBlogCategory" role="dialog" data-easein="bounceIn">
    <div class="modal-dialog modal-md">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal">&times;</button>
                <h4 class="modal-title">@ViewData["Title"]</h4>
            </div>
            <form id="BlogCategoryForm">

                <div class="modal-body">
                    <input type="hidden" name="mode" id="mode" value="@ViewData["Mode"]" />
                    <input type="hidden" name="ID" id="ID" value="@blogcate.ID" />
                    <div class="form-group">
                        <label for="FullName">Tên</label>
                        <input type="text" class="form-control" id="BlogCategoryName" name="BlogCategoryName" placeholder="Tên" tabindex="1" value="@blogcate.BlogCategoryName">
                    </div>
                    <div class="form-group">
                        <label for="FullName">URL</label>
                        <input type="text" class="form-control" id="BlogURL" name="BlogURL" placeholder="URL" tabindex="1" value="@blogcate.BlogURL">
                    </div>

                    <div class="clearfix"></div>
                    <div class="form-group">
                        <label for="FullName">Thứ Tự</label>
                        <input type="number" class="form-control" id="Rank" name="Rank" placeholder="Thứ Tự" tabindex="1" min="0" value="@blogcate.Rank">
                    </div>
                    <div class="form-group">
                        <label for="FullName">SEO title</label>
                        <input type="text" class="form-control" id="SEOTitle" name="SEOTitle" placeholder="tiêu đề" tabindex="1" value="@blogcate.SEOTitle">
                    </div>
                    <div class="form-group">
                        <label for="FullName">SEO Keywords</label>
                        <textarea class="form-control" rows="3" name="SEOKeywords" id="SEOKeywords" style="resize:none">@blogcate.SEOKeywords</textarea>
                    </div>
                    <div class="form-group">
                        <label for="FullName">SEO Description</label>
                        <textarea class="form-control" rows="3" name="SEODescriptions" id="SEODescriptions" style="resize:none">@blogcate.SEODescriptions</textarea>
                    </div>
                    <div class="form-group">
                        <label for="ParrentID">Danh mục cha</label>
                        @{
                            Cubetech.Website.DAO.BlogDAO wdao = new Cubetech.Website.DAO.BlogDAO();
                            var lstParent = wdao.GetListBloCategoryTree();
                        }
                        <select class="form-control" id="ParentID" name="ParentID">
                            <option value="0">--Tất Cả--</option>
                            @foreach (var item in lstParent)
                            {
                                var str = "";

                                for (var i = 0; i < item.LevelDisplay; i++)
                                {
                                    str += "&nbsp;&nbsp;";
                                }
                                str += "|-";

                                <option value="@item.ID">@Html.Raw(str)  @item.BlogCategoryName</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="clearfix"></div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-dark" data-dismiss="modal" aria-hidden="true">
                        <span class="glyphicon glyphicon-remove" aria-hidden="true"></span> Hủy
                    </button>
                    <button type="button" onclick="fnSaveBlogCategory();" class="btn btn-danger"><span class="glyphicon glyphicon-ok" aria-hidden="true"></span> Lưu</button>
                </div>
            </form>
        </div>

    </div>
</div>
<script>
    $(document).ready(function () {
        if ('@ViewData["Mode"].ToString()' == 'EDIT') {
            $('#ParentID').val('@blogcate.ParentID').trigger('change');
        }
    })


    function fnSaveBlogCategory() {
        var fd = new FormData(document.getElementById("BlogCategoryForm"));

        $.ajax({
            url: "/Admin/UpdateBlogCate",
            type: "POST",
            data: fd,
            enctype: 'multipart/form-data',
            processData: false,  // tell jQuery not to process the data
            contentType: false,   // tell jQuery not to set contentType
            success: function (data) {
                if (data.Code == 1) {
                    showSuccess("Thành công", data.message);
                    $("#modalBlogCategory").modal("hide");
                    getList();
                }
                else {
                    showError('Lỗi', data.message);
                }
            }
        });
    }
</script>
