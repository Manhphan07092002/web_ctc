
@{
    ViewBag.Title = "BLog";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="row">
    <div class="col-md-12">
        <div class="panel panel-master list-panel" id="list-panel">
            <form id="frmAccountSearch">
                <div class="panel-heading list-panel-heading">
                    <div class="col-md-4">
                        <div class="input-group input-group-sm pull-right">
                            <input type="text" class="form-control" id="Info" name="Info" placeholder="Nội dung tìm kiếm">
                            <span class="input-group-btn">
                                <button type="button" class="btn btn-success btn-flat" onclick="loadTable()">
                                    <span class="glyphicon glyphicon-search" aria-hidden="true"></span> Tìm kiếm
                                </button>
                            </span>
                        </div>
                    </div>

                    <div class="col-md-2 pull-right search-top">
                        <a href="/Admin/AddNewEditBlog/0" class="btn btn-danger btn-sm  refresh-button" id="refresh-button">
                            <span class="glyphicon glyphicon-plus" aria-hidden="true"></span> Thêm mới
                        </a>
                    </div>
                </div>
            </form>
            <div class="panel-body">
                <table id="tbBlog" class="table table-striped" cellspacing="0" width="100%">
                    <thead>
                        <tr>
                            <th>Hình Ảnh</th>
                            <th>Tiêu Đề</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody></tbody>

                </table>
            </div>
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        $('#modalBrand').on('hidden.bs.modal', function () {
            $(this).find('form')[0].reset();
        });
        loadTable();
    });
   // enterSearch("#Info", ReloadTable);
    function loadTable() {
        $("#Info").val($.trim($("#Info").val()));
        var table = $('#tbBlog').DataTable({
            "bDestroy": true,
            "processing": true,
            "serverSide": true,
            "ajax": {
                "url": "/Admin/GetListBlog",
                "type": "POST",
                "data": function (d) {
                    return $.extend({}, d, {
                        'Info': $('#Info').val()
                    })
                }
            },
            "columns": [
                 {
                     "name": "Image",
                     'render': function (data, type, full, meta) {
                         var html = '<img src="' + full.Image + '" style="height:50px"/>'
                         return html;
                     }
                 },
                        { "name": "Name", "data": "Name" },

                        {
                            targets: 'no-sort',
                            orderable: false,
                            'class': 'text-center',
                            'width': '10%',
                            'render': function (data, type, full, meta) {
                                var html = '<a href="/Admin/AddNewEditBlog/'+full.ID+'" type="button"  style="margin-right: 10px;" class="btn btn-warning btn-xs" title="Cập Nhật" ><i class="glyphicon glyphicon-edit"></i></a>' +
                                            '<button type="button" class="btn  btn-dark btn-xs" style="margin-right: 10px;" title="Xóa" onclick="Remove(this,' + full.ID + ')"><i class="glyphicon glyphicon-trash"></i></button> ';
                                return html;
                            }
                        }
            ],
            "scrollCollapse": true,
            "scrollX": true,
            "paging": true,
            "lengthChange": true,
            "searching": false,
            "ordering": true,
            "info": false,
            "autoWidth": false,
            "dom": '<"top"i>rt<"bottom row"<"col-md-3"l><"col-md-9"<"pullright"p>>><"clear">'
        });
    }
    function showModalBlog(id) {
        $.ajax({
            url: "/WBlog/AddNewEdit",
            method: "POST",
            beforeSend: function () {
                showSpinLoading();
            },
            data: {
                id: id
            },
            success: function (data) {
                hideSpinLoading();
                $("#popupContainer1").html(data);
                $("#ModalBlog").modal("show");
            }
        });
    }
    function OnBegin() {
    }
    function OnSuccess(data) {
        if (data.Code === 1) {
            $('#modalBrand').modal('hide');
            var table = $('#tbBrand').DataTable();
            if (data.mode === "ADD") {
                table.row.add(data.data).draw(false);
            } else {
                loadTable();
            }
            showSuccess('Thành Công', data.message);
        } else {
            showError('Lỗi', data.message);
        }
    }
    function ReloadTable() {
        $("#Info").val($.trim($("#Info").val()));
        var table = $('#tbBrand').DataTable();
        table.ajax.reload();
    }
    function Remove(thiz, id) {
        showConfirm("", "Bạn có chắc chắn muốn xóa blog ?",
            function () {
                $.ajax({
                    type: "POST",
                    url: '/Admin/DeleteBlog',
                    data: { id: id },

                }).success(function (data) {
                    if (data.Code === 1) {
                        $('#tbBlog').DataTable().row($(thiz).parents('tr')).remove().draw(false);
                        showSuccess('Thông báo', data.message);
                    } else {
                        showError('Lỗi', data.message);
                    }
                });

            }, function () { }
);
    }
</script>