        <!-- Create/Edit Modal -->
        <div id="categoryModal" class="modal">
            <div class="modal-content">
                <div class="modal-header">
                    <h4 id="modalTitle">ThÃŠm danh máŧĨc máŧi</h4>
                    <span class="close" onclick="closeModal()">&times;</span>
                </div>
                <div class="modal-body">
                    <form id="categoryForm">
                        <input type="hidden" id="categoryId" name="id">
                        
                        <div class="form-row">
                            <div class="form-group">
                                <label for="categoryCode">MÃĢ danh máŧĨc *</label>
                                <input type="text" id="categoryCode" name="categoryCode" class="form-control" required placeholder="vd: infrastructure">
                            </div>
                            
                            <div class="form-group">
                                <label for="categoryName">TÃŠn danh máŧĨc *</label>
                                <input type="text" id="categoryName" name="categoryName" class="form-control" required placeholder="vd: HášĄ táš§ng Káŧđ thuáš­t">
                            </div>
                        </div>
                        
                        <div class="form-row">
