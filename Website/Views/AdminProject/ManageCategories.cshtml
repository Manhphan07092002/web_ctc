@section Scripts {
    <script src="~/Scripts/admin-projects.js"></script>
    <script>
        var currentCategoryId = null;
        var categories = [];

        $(document).ready(function() {
            loadCategories();
            initializeCategoryForm();
        });

        function loadCategories() {
            $('#categoriesTableBody').html('<tr><td colspan="8" class="text-center"><i class="fas fa-spinner fa-spin"></i> Äang tášĢi danh máŧĨc...</td></tr>');
            
            $.ajax({
                url: '/admin/projects/api/project-categories',
                type: 'GET',
                success: function(data) {
                    categories = data;
                    renderCategoriesTable(data);
                },
                error: function() {
                    $('#categoriesTableBody').html('<tr><td colspan="8" class="text-center text-danger">KhÃīng tháŧ tášĢi danh sÃĄch danh máŧĨc</td></tr>');
                    showToast('error', 'KhÃīng tháŧ tášĢi danh sÃĄch danh máŧĨc');
                }
            });
        }

        function renderCategoriesTable(categories) {
            var tbody = $('#categoriesTableBody');
            tbody.empty();

            if (categories.length === 0) {
                tbody.html('<tr><td colspan="8" class="text-center">ChÆ°a cÃģ danh máŧĨc nÃ o</td></tr>');
                return;
            }

            categories.forEach(function(category) {
                var row = $('<tr>').attr('data-category-id', category.CategoryID);
                
                row.html(`
                    <td>${category.CategoryID}</td>
                    <td><code>${category.CategoryCode}</code></td>
                    <td><strong>${category.CategoryName}</strong></td>
                    <td>${category.Description || '<em class="text-muted">KhÃīng cÃģ mÃī tášĢ</em>'}</td>
                    <td><span class="badge badge-info">${category.DisplayOrder}</span></td>
                    <td>
                        <span class="badge ${category.IsActive ? 'badge-success' : 'badge-secondary'}">
                            ${category.IsActive ? 'KÃ­ch hoášĄt' : 'VÃī hiáŧu'}
                        </span>
                    </td>
                    <td>${formatDate(category.CreatedDate)}</td>
                    <td>
                        <div class="action-buttons">
                            <button class="btn btn-sm btn-primary" onclick="editCategory(${category.CategoryID})" title="Cháŧnh sáŧ­a">
                                <i class="fas fa-edit"></i>
                            </button>
                            <button class="btn btn-sm btn-danger" onclick="showDeleteCategoryModal(${category.CategoryID})" title="XÃģa">
                                <i class="fas fa-trash"></i>
                            </button>
                        </div>
                    </td>
                `);
                
                tbody.append(row);
            });
        }

        function initializeCategoryForm() {
            // Character counter for description
            $('#categoryDescription').on('input', function() {
                var length = $(this).val().length;
                $('#description-count').text(length);
                
                if (length > 450) {
                    $('#description-count').addClass('text-warning');
                } else {
                    $('#description-count').removeClass('text-warning');
                }
            });

            // Form submission
            $('#categoryForm').on('submit', function(e) {
                e.preventDefault();
                saveCategoryForm();
            });

            // Auto-generate category code from name
            $('#categoryName').on('input', function() {
                if (!$('#categoryId').val()) { // Only for new categories
                    var name = $(this).val();
                    var code = generateCategoryCode(name);
                    $('#categoryCode').val(code);
                }
            });
        }

        function generateCategoryCode(name) {
            return name.toLowerCase()
                      .replace(/[Ã ÃĄášĄášĢÃĢÃĒáš§ášĨáš­ášĐášŦÄášąášŊáš·ášģášĩ]/g, 'a')
                      .replace(/[ÃĻÃĐášđášŧáš―ÃŠáŧášŋáŧáŧáŧ]/g, 'e')
                      .replace(/[ÃŽÃ­áŧáŧÄĐ]/g, 'i')
                      .replace(/[ÃēÃģáŧáŧÃĩÃīáŧáŧáŧáŧáŧÆĄáŧáŧáŧĢáŧáŧĄ]/g, 'o')
                      .replace(/[ÃđÃšáŧĨáŧ§ÅĐÆ°áŧŦáŧĐáŧąáŧ­áŧŊ]/g, 'u')
                      .replace(/[áŧģÃ―áŧĩáŧ·áŧđ]/g, 'y')
                      .replace(/Ä/g, 'd')
                      .replace(/[^a-z0-9]/g, '_')
                      .replace(/_+/g, '_')
                      .replace(/^_|_$/g, '');
        }

        function showCreateCategoryModal() {
            currentCategoryId = null;
            $('#categoryModalTitle').text('ThÃŠm Danh máŧĨc Máŧi');
            $('#saveButtonText').text('LÆ°u danh máŧĨc');
            $('#categoryForm')[0].reset();
            $('#categoryForm').find('.is-invalid').removeClass('is-invalid');
            $('#categoryForm').find('.invalid-feedback').text('');
            $('#description-count').text('0');
            $('#isActive').prop('checked', true);
            $('#categoryModal').modal('show');
        }

        function editCategory(categoryId) {
            var category = categories.find(c => c.CategoryID === categoryId);
            if (!category) {
                showToast('error', 'KhÃīng tÃŽm thášĨy danh máŧĨc');
                return;
            }

            currentCategoryId = categoryId;
            $('#categoryModalTitle').text('Cháŧnh sáŧ­a Danh máŧĨc');
            $('#saveButtonText').text('Cáš­p nháš­t danh máŧĨc');
            
            $('#categoryId').val(category.CategoryID);
            $('#categoryCode').val(category.CategoryCode);
            $('#categoryName').val(category.CategoryName);
            $('#categoryDescription').val(category.Description || '');
            $('#displayOrder').val(category.DisplayOrder);
            $('#isActive').prop('checked', category.IsActive);
            
            $('#description-count').text((category.Description || '').length);
            
            $('#categoryForm').find('.is-invalid').removeClass('is-invalid');
            $('#categoryForm').find('.invalid-feedback').text('');
            
            $('#categoryModal').modal('show');
        }

        function saveCategoryForm() {
            var formData = {
                CategoryID: $('#categoryId').val() || 0,
                CategoryCode: $('#categoryCode').val().trim(),
                CategoryName: $('#categoryName').val().trim(),
                Description: $('#categoryDescription').val().trim(),
                DisplayOrder: parseInt($('#displayOrder').val()) || 0,
                IsActive: $('#isActive').prop('checked')
            };

            // Client-side validation
            var isValid = true;
            $('#categoryForm').find('.is-invalid').removeClass('is-invalid');
            $('#categoryForm').find('.invalid-feedback').text('');

            if (!formData.CategoryCode) {
                showFieldError($('#categoryCode'), 'MÃĢ danh máŧĨc lÃ  bášŊt buáŧc');
                isValid = false;
            }

            if (!formData.CategoryName) {
                showFieldError($('#categoryName'), 'TÃŠn danh máŧĨc lÃ  bášŊt buáŧc');
                isValid = false;
            }

            // Check for duplicate category code
            var existingCategory = categories.find(c => 
                c.CategoryCode.toLowerCase() === formData.CategoryCode.toLowerCase() && 
                c.CategoryID !== formData.CategoryID
            );
            
            if (existingCategory) {
                showFieldError($('#categoryCode'), 'MÃĢ danh máŧĨc ÄÃĢ táŧn tášĄi');
                isValid = false;
            }

            if (!isValid) {
                return;
            }

            // Show loading state
            var submitBtn = $('#categoryForm button[type="submit"]');
            var originalText = submitBtn.html();
            submitBtn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i> Äang lÆ°u...');

            // Determine endpoint
            var url = formData.CategoryID > 0 
                ? '/admin/projects/api/project-categories/' + formData.CategoryID
                : '/admin/projects/api/project-categories';

            $.ajax({
                url: url,
                type: 'POST',
                data: formData,
                success: function(response) {
                    if (response.success) {
                        showToast('success', response.message);
                        $('#categoryModal').modal('hide');
                        loadCategories();
                    } else {
                        showToast('error', response.message);
                    }
                },
                error: function() {
                    showToast('error', 'CÃģ láŧi xášĢy ra khi lÆ°u danh máŧĨc');
                },
                complete: function() {
                    submitBtn.prop('disabled', false).html(originalText);
                }
            });
        }

        function showDeleteCategoryModal(categoryId) {
            var category = categories.find(c => c.CategoryID === categoryId);
            if (!category) {
                showToast('error', 'KhÃīng tÃŽm thášĨy danh máŧĨc');
                return;
            }

            currentCategoryId = categoryId;
            $('#deleteCategoryName').text(category.CategoryName);
            $('#deleteCategoryCode').text(category.CategoryCode);
            $('#deleteCategoryModal').modal('show');
        }

        function confirmDeleteCategory() {
            if (!currentCategoryId) return;

            $.ajax({
                url: '/admin/projects/api/project-categories/' + currentCategoryId,
                type: 'DELETE',
                success: function(response) {
                    if (response.success) {
                        showToast('success', response.message);
                        $('#deleteCategoryModal').modal('hide');
                        loadCategories();
                    } else {
                        showToast('error', response.message);
                    }
                },
                error: function() {
                    showToast('error', 'CÃģ láŧi xášĢy ra khi xÃģa danh máŧĨc');
                }
            });
        }

        function showFieldError(field, message) {
            field.addClass('is-invalid');
            field.siblings('.invalid-feedback').text(message);
        }

        function formatDate(dateString) {
            if (!dateString) return '';
            var date = new Date(dateString);
            return date.toLocaleDateString('vi-VN') + ' ' + date.toLocaleTimeString('vi-VN', {hour: '2-digit', minute: '2-digit'});
        }

        function showToast(type, message) {
            // Remove existing toasts
            $('.toast').remove();
            
            // Create new toast
            var toast = $('<div class="toast toast-' + type + '">' + message + '</div>');
            $('body').append(toast);
            
            // Show toast with animation
            toast.fadeIn(300).delay(4000).fadeOut(300, function() {
                $(this).remove();
            });
        }
    </script>
}
