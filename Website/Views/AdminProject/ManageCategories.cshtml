                            <th>TrášĄng thÃĄi</th>
                            <th>Thao tÃĄc</th>
                        </tr>
                    </thead>
                    <tbody id="categoriesTableBody">
                        <tr>
                            <td colspan="7" style="text-align: center; padding: 40px;">
                                <i class="fas fa-spinner fa-spin"></i> Äang tášĢi dáŧŊ liáŧu...
                            </td>
                        </tr>
                    </tbody>
