    <script>
        let isEditMode = false;
        let currentCategoryId = null;

        // Load categories on page load
        document.addEventListener('DOMContentLoaded', function() {
            loadCategories();
        });

        // Load categories from API
        function loadCategories() {
            fetch('/AdminProject/GetProjectCategories')
                .then(response => response.json())
                .then(data => {
                    const tbody = document.getElementById('categoriesTableBody');
                    if (data && data.length > 0) {
                        tbody.innerHTML = data.map(category => `
                            <tr>
                                <td>${category.CategoryID}</td>
                                <td><code>${category.CategoryCode}</code></td>
                                <td><strong>${category.CategoryName}</strong></td>
                                <td>${category.Description || ''}</td>
                                <td>${category.DisplayOrder || 1}</td>
                                <td>
                                    <span class="status-badge ${category.IsActive ? 'status-active' : 'status-inactive'}">
                                        ${category.IsActive ? 'KÃ­ch hoášĄt' : 'TášĄm dáŧŦng'}
                                    </span>
                                </td>
                                <td>
                                    <button onclick="editCategory(${category.CategoryID})" class="btn btn-sm btn-primary">
                                        <i class="fas fa-edit"></i> Sáŧ­a
                                    </button>
                                    <button onclick="deleteCategory(${category.CategoryID})" class="btn btn-sm btn-danger">
                                        <i class="fas fa-trash"></i> XÃģa
                                    </button>
                                </td>
                            </tr>
                        `).join('');
                    } else {
                        tbody.innerHTML = `
                            <tr>
                                <td colspan="7" style="text-align: center; padding: 40px; color: #6b7280;">
                                    <i class="fas fa-inbox"></i><br>
                                    ChÆ°a cÃģ danh máŧĨc nÃ o
                                </td>
                            </tr>
                        `;
                    }
                })
                .catch(error => {
                    console.error('Error loading categories:', error);
                    showAlert('Láŧi khi tášĢi danh máŧĨc: ' + error.message, 'error');
                });
        }

        // Show create modal
        function showCreateModal() {
            isEditMode = false;
            currentCategoryId = null;
            document.getElementById('modalTitle').textContent = 'ThÃŠm danh máŧĨc máŧi';
            document.getElementById('categoryForm').reset();
            document.getElementById('categoryModal').style.display = 'block';
        }

        // Edit category
        function editCategory(id) {
            isEditMode = true;
            currentCategoryId = id;
            document.getElementById('modalTitle').textContent = 'Cháŧnh sáŧ­a danh máŧĨc';
            
            // Load category data
            fetch(`/AdminProject/GetProjectCategory?id=${id}`)
                .then(response => response.json())
                .then(result => {
                    if (result.success) {
                        const category = result.data;
                        document.getElementById('categoryId').value = category.CategoryID;
                        document.getElementById('categoryCode').value = category.CategoryCode;
                        document.getElementById('categoryName').value = category.CategoryName;
                        document.getElementById('description').value = category.Description || '';
                        document.getElementById('displayOrder').value = category.DisplayOrder || 1;
                        document.getElementById('isActive').checked = category.IsActive;
                        document.getElementById('categoryModal').style.display = 'block';
                    } else {
                        showAlert('Láŧi: ' + result.message, 'error');
                    }
                })
                .catch(error => {
                    console.error('Error loading category:', error);
                    showAlert('Láŧi khi tášĢi thÃīng tin danh máŧĨc', 'error');
                });
        }

        // Save category
        function saveCategory() {
            const form = document.getElementById('categoryForm');
            const formData = new FormData(form);
            
            const data = {
                categoryCode: formData.get('categoryCode'),
                categoryName: formData.get('categoryName'),
                description: formData.get('description'),
                displayOrder: parseInt(formData.get('displayOrder')) || 1,
                isActive: document.getElementById('isActive').checked
            };

            if (isEditMode) {
                data.id = currentCategoryId;
            }

            const url = isEditMode ? '/AdminProject/UpdateProjectCategory' : '/AdminProject/CreateProjectCategory';
            const params = new URLSearchParams(data).toString();

            fetch(`${url}?${params}`, { method: 'POST' })
                .then(response => response.json())
                .then(result => {
                    if (result.success) {
                        showAlert(result.message, 'success');
                        closeModal();
                        loadCategories();
                    } else {
                        showAlert('Láŧi: ' + result.message, 'error');
                    }
                })
                .catch(error => {
                    console.error('Error saving category:', error);
                    showAlert('Láŧi khi lÆ°u danh máŧĨc', 'error');
                });
        }

        // Delete category
        function deleteCategory(id) {
            if (confirm('BášĄn cÃģ chášŊc chášŊn muáŧn xÃģa danh máŧĨc nÃ y?')) {
                fetch(`/AdminProject/DeleteProjectCategory?id=${id}`, { method: 'POST' })
                    .then(response => response.json())
                    .then(result => {
                        if (result.success) {
                            showAlert(result.message, 'success');
                            loadCategories();
                        } else {
                            showAlert('Láŧi: ' + result.message, 'error');
                        }
                    })
                    .catch(error => {
                        console.error('Error deleting category:', error);
                        showAlert('Láŧi khi xÃģa danh máŧĨc', 'error');
                    });
            }
        }

        // Close modal
        function closeModal() {
            document.getElementById('categoryModal').style.display = 'none';
        }

        // Show alert
        function showAlert(message, type) {
            const alertContainer = document.getElementById('alertContainer');
            const alertClass = type === 'success' ? 'alert-success' : 'alert-error';
            const icon = type === 'success' ? 'fas fa-check-circle' : 'fas fa-exclamation-triangle';
            
            alertContainer.innerHTML = `
                <div class="alert ${alertClass}">
                    <i class="${icon}"></i>
                    ${message}
                </div>
            `;
            
            setTimeout(() => {
                alertContainer.innerHTML = '';
            }, 5000);
        }

        // Close modal when clicking outside
        window.onclick = function(event) {
            const modal = document.getElementById('categoryModal');
            if (event.target === modal) {
                closeModal();
            }
        }
    </script>
</body>
