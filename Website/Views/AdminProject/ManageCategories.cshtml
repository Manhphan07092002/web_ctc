                                <label for="description">MÃī tášĢ</label>
                                <textarea id="description" name="description" class="form-control textarea" placeholder="MÃī tášĢ chi tiášŋt váŧ danh máŧĨc"></textarea>
                            </div>
                        </div>
                        
                        <div class="form-row">
                            <div class="form-group">
                                <label for="displayOrder">TháŧĐ táŧą hiáŧn tháŧ</label>
                                <input type="number" id="displayOrder" name="displayOrder" class="form-control" value="1" min="1">
                            </div>
                            
                            <div class="form-group">
                                <div class="checkbox-group">
                                    <input type="checkbox" id="isActive" name="isActive" checked>
                                    <label for="isActive">KÃ­ch hoášĄt</label>
