@model Cubetech.Website.Models.Project
@{
    ViewBag.Title = "Chỉnh sửa Dự án";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title</title>
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #f8fafc; color: #1e293b; line-height: 1.6; font-size: 16px; }
        .admin-container { max-width: 1200px; margin: 0 auto; padding: 20px; }
        .admin-header { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 30px; border-radius: 12px; margin-bottom: 30px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); }
        .header-content { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 20px; }
        .header-content h1 { font-size: 2rem; font-weight: 600; display: flex; align-items: center; gap: 12px; }
        .header-actions { display: flex; gap: 15px; flex-wrap: wrap; }
        .btn { padding: 12px 20px; border: none; border-radius: 8px; cursor: pointer; font-weight: 500; text-decoration: none; display: inline-flex; align-items: center; gap: 8px; transition: all 0.3s ease; font-size: 16px; }
        .btn-primary { background: #3b82f6; color: white; }
        .btn-primary:hover { background: #2563eb; transform: translateY(-2px); }
        .btn-secondary { background: #6b7280; color: white; }
        .btn-success { background: #10b981; color: white; }
        .btn-success:hover { background: #059669; transform: translateY(-2px); }
        .btn-danger { background: #ef4444; color: white; }
        .btn-danger:hover { background: #dc2626; transform: translateY(-2px); }
        .form-section { background: white; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); overflow: hidden; margin-bottom: 30px; }
        .form-header { padding: 20px 24px; border-bottom: 1px solid #e2e8f0; background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%); }
        .form-header h3 { font-size: 1.35rem; font-weight: 600; color: #1e293b; display: flex; align-items: center; gap: 10px; }
        .form-body { padding: 30px; }
        .form-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 20px; margin-bottom: 25px; }
        .form-group { display: flex; flex-direction: column; }
        .form-group label { font-weight: 500; color: #374151; margin-bottom: 12px; font-size: 1rem; line-height: 1.4; }
        .form-control { width: 100%; padding: 16px 20px; border: 1px solid #d1d5db; border-radius: 8px; font-size: 16px; transition: all 0.2s ease; min-height: 50px; line-height: 1.5; }
        .form-control:focus { outline: none; border-color: #3b82f6; box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1); }
        .form-control.textarea { min-height: 120px; resize: vertical; }
        .upload-section { border: 2px dashed #d1d5db; border-radius: 12px; padding: 30px; text-align: center; transition: all 0.3s ease; margin-bottom: 20px; }
        .upload-section:hover { border-color: #3b82f6; background: #f8fafc; }
        .upload-section.dragover { border-color: #3b82f6; background: #eff6ff; }
        .upload-icon { font-size: 3rem; color: #9ca3af; margin-bottom: 15px; }
        .upload-text { color: #6b7280; margin-bottom: 15px; }
        .file-input { display: none; }
        .file-preview { margin-top: 15px; padding: 15px; background: #f8fafc; border-radius: 8px; display: none; }
        .current-file { background: #e0f2fe; padding: 15px; border-radius: 8px; margin-bottom: 15px; display: flex; align-items: center; gap: 10px; }
        .current-file img { max-width: 100px; max-height: 100px; border-radius: 6px; }
        .progress-group { display: grid; grid-template-columns: 1fr auto; gap: 15px; align-items: center; }
        .progress-input { width: 100px; }
        .progress-display { font-weight: 600; color: #3b82f6; }
        .checkbox-group { display: flex; align-items: center; gap: 10px; margin-bottom: 15px; }
        .checkbox-group input[type="checkbox"] { width: 18px; height: 18px; }
        .alert { padding: 16px 20px; border-radius: 8px; margin-bottom: 20px; display: flex; align-items: center; gap: 10px; }
        .alert-success { background: #d1fae5; color: #065f46; border: 1px solid #a7f3d0; }
        .alert-error { background: #fee2e2; color: #991b1b; border: 1px solid #fca5a5; }
        .form-actions { display: flex; gap: 15px; justify-content: flex-end; padding-top: 20px; border-top: 1px solid #e2e8f0; }
        @@media (max-width: 768px) { .form-row { grid-template-columns: 1fr; } .form-actions { flex-direction: column; } }
    </style>
</head>
<body>
    <div class="admin-container">
        <header class="admin-header">
            <div class="header-content">
                <h1><i class="fas fa-edit"></i> Chỉnh sửa Dự án</h1>
                <div class="header-actions">
                    <a href="/admin/projects" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Quay lại danh sách
                    </a>
                    <a href="/admin/projects/create" class="btn btn-primary">
                        <i class="fas fa-plus"></i> Tạo mới
                    </a>
                </div>
            </div>
        </header>

        <!-- Alert Messages -->
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">
                <i class="fas fa-check-circle"></i>
                @TempData["Success"]
            </div>
        }
        
        @if (ViewData.ModelState.Count > 0 && !ViewData.ModelState.IsValid)
        {
            <div class="alert alert-error">
                <i class="fas fa-exclamation-triangle"></i>
                Vui lòng kiểm tra lại thông tin đã nhập
            </div>
        }

        <!-- Edit Form -->
        <div class="form-section">
            <div class="form-header">
                <h3><i class="fas fa-edit"></i> Chỉnh sửa Dự án: @Model.Title</h3>
            </div>
            <div class="form-body">
                @using (Html.BeginForm("Edit", "AdminProject", FormMethod.Post, new { enctype = "multipart/form-data" }))
                {
                    @Html.AntiForgeryToken()
                    @Html.HiddenFor(m => m.ProjectID)
                    
                    <!-- Basic Information -->
                    <div class="form-row">
                        <div class="form-group">
                            <label for="Title">Tên dự án *</label>
                            @Html.TextBoxFor(m => m.Title, new { @class = "form-control", placeholder = "Nhập tên dự án", required = "required" })
                            @Html.ValidationMessageFor(m => m.Title, "", new { @class = "text-danger" })
                        </div>
                        
                        <div class="form-group">
                            <label for="Category">Danh mục *</label>
                            @Html.DropDownListFor(m => m.Category, 
                                new SelectList(ViewBag.Categories ?? new List<object>(), "CategoryCode", "CategoryName", Model.Category), 
                                "-- Chọn danh mục --", 
                                new { @class = "form-control", required = "required" })
                            @Html.ValidationMessageFor(m => m.Category, "", new { @class = "text-danger" })
                        </div>
                    </div>
                    
                    <div class="form-row">
                        <div class="form-group">
                            <label for="Description">Mô tả</label>
                            @Html.TextAreaFor(m => m.Description, new { @class = "form-control textarea", placeholder = "Mô tả chi tiết về dự án", rows = "4" })
                        </div>
                    </div>
                    
                    <!-- Project Details -->
                    <div class="form-row">
                        <div class="form-group">
                            <label for="Location">Địa điểm</label>
                            @Html.TextBoxFor(m => m.Location, new { @class = "form-control", placeholder = "Địa điểm thực hiện dự án" })
                        </div>
                        
                        <div class="form-group">
                            <label for="Client">Khách hàng</label>
                            @Html.TextBoxFor(m => m.Client, new { @class = "form-control", placeholder = "Tên khách hàng" })
                        </div>
                    </div>
                    
                    <div class="form-row">
                        <div class="form-group">
                            <label for="Contractor">Nhà thầu</label>
                            @Html.TextBoxFor(m => m.Contractor, new { @class = "form-control", placeholder = "Tên nhà thầu" })
                        </div>
                        
                        <div class="form-group">
                            <label for="Status">Trạng thái</label>
                            @Html.DropDownListFor(m => m.Status, new SelectList(new[] {
                                new { Value = "planning", Text = "Lập kế hoạch" },
                                new { Value = "in_progress", Text = "Đang thực hiện" },
                                new { Value = "completed", Text = "Hoàn thành" },
                                new { Value = "on_hold", Text = "Tạm dừng" }
                            }, "Value", "Text", Model.Status), new { @class = "form-control" })
                        </div>
                    </div>
                    
                    <!-- Financial Information -->
                    <div class="form-row">
                        <div class="form-group">
                            <label for="ProjectValue">Giá trị dự án</label>
                            @Html.TextBoxFor(m => m.ProjectValue, new { @class = "form-control", type = "number", step = "0.01", placeholder = "0" })
                        </div>
                        
                        <div class="form-group">
                            <label for="Currency">Đơn vị tiền tệ</label>
                            @Html.DropDownListFor(m => m.Currency, new SelectList(new[] {
                                new { Value = "VND", Text = "VND" },
                                new { Value = "USD", Text = "USD" },
                                new { Value = "EUR", Text = "EUR" }
                            }, "Value", "Text", Model.Currency), new { @class = "form-control" })
                        </div>
                    </div>
                    
                    <!-- Dates -->
                    <div class="form-row">
                        <div class="form-group">
                            <label for="StartDate">Ngày bắt đầu</label>
                            @Html.TextBoxFor(m => m.StartDate, new { @class = "form-control", type = "date", Value = Model.StartDate != null ? Model.StartDate.Value.ToString("yyyy-MM-dd") : "" })
                        </div>
                        
                        <div class="form-group">
                            <label for="EndDate">Ngày kết thúc dự kiến</label>
                            @Html.TextBoxFor(m => m.EndDate, new { @class = "form-control", type = "date", Value = Model.EndDate != null ? Model.EndDate.Value.ToString("yyyy-MM-dd") : "" })
                        </div>
                    </div>
                    
                    <!-- Progress -->
                    <div class="form-row">
                        <div class="form-group">
                            <label for="Progress">Tiến độ (%)</label>
                            <div class="progress-group">
                                @Html.TextBoxFor(m => m.Progress, new { @class = "form-control progress-input", type = "number", min = "0", max = "100" })
                                <span class="progress-display">@Model.Progress%</span>
                            </div>
                        </div>
                        
                        <div class="form-group">
                            <label for="Tags">Tags</label>
                            @Html.TextBoxFor(m => m.Tags, new { @class = "form-control", placeholder = "Nhập tags, cách nhau bằng dấu phẩy" })
                        </div>
                    </div>
                    
                    <!-- File Uploads -->
                    <div class="form-row">
                        <div class="form-group">
                            <label>Hình ảnh dự án</label>
                            @if (!string.IsNullOrEmpty(Model.ImageUrl))
                            {
                                <div class="current-file">
                                    <img src="@Model.ImageUrl" alt="Current Image" />
                                    <div>
                                        <strong>Hình ảnh hiện tại</strong><br>
                                        <small>@Model.ImageUrl</small>
                                    </div>
                                </div>
                            }
                            <div class="upload-section" onclick="document.getElementById('imageFile').click()">
                                <div class="upload-icon">
                                    <i class="fas fa-cloud-upload-alt"></i>
                                </div>
                                <div class="upload-text">
                                    <strong>Click để chọn hình ảnh mới</strong> hoặc kéo thả file vào đây
                                    <br><small>Hỗ trợ: JPG, PNG, GIF (tối đa 5MB)</small>
                                </div>
                                <input type="file" id="imageFiles" name="imageFiles" class="file-input" accept="image/*" multiple>
                                <div class="file-preview" id="imagePreview"></div>
                            </div>
                        </div>
                        
                        <div class="form-group">
                            <label>Tài liệu dự án</label>
                            @if (!string.IsNullOrEmpty(Model.DocumentUrl))
                            {
                                <div class="current-file">
                                    <i class="fas fa-file-alt" style="font-size: 2rem; color: #10b981;"></i>
                                    <div>
                                        <strong>Tài liệu hiện tại</strong><br>
                                        <small>@Model.DocumentUrl</small><br>
                                        <a href="@Model.DocumentUrl" target="_blank" class="btn btn-sm btn-primary">
                                            <i class="fas fa-download"></i> Tải xuống
                                        </a>
                                    </div>
                                </div>
                            }
                            <div class="upload-section" onclick="document.getElementById('documentFile').click()">
                                <div class="upload-icon">
                                    <i class="fas fa-file-upload"></i>
                                </div>
                                <div class="upload-text">
                                    <strong>Click để chọn tài liệu mới</strong> hoặc kéo thả file vào đây
                                    <br><small>Hỗ trợ: PDF, DOC, DOCX, XLS, XLSX (tối đa 10MB)</small>
                                </div>
                                <input type="file" id="documentFiles" name="documentFiles" class="file-input" accept=".pdf,.doc,.docx,.xls,.xlsx" multiple>
                                <div class="file-preview" id="documentPreview"></div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Options -->
                    <div class="form-row">
                        <div class="form-group">
                            <div class="checkbox-group">
                                @Html.CheckBoxFor(m => m.IsPublished)
                                <label for="IsPublished">Xuất bản</label>
                            </div>
                            <div class="checkbox-group">
                                @Html.CheckBoxFor(m => m.IsFeatured)
                                <label for="IsFeatured">Dự án nổi bật</label>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Form Actions -->
                    <div class="form-actions">
                        <a href="/admin/projects" class="btn btn-secondary">
                            <i class="fas fa-times"></i> Hủy
                        </a>
                        <button type="button" class="btn btn-danger" onclick="confirmDelete(@Model.ProjectID)">
                            <i class="fas fa-trash"></i> Xóa
                        </button>
                        <button type="submit" class="btn btn-success">
                            <i class="fas fa-save"></i> Cập nhật
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>

    <script>
        // Multiple image files upload preview
        document.getElementById('imageFiles').addEventListener('change', function(e) {
            const files = e.target.files;
            const preview = document.getElementById('imagePreview');
            
            if (files.length > 5) {
                alert('Chỉ được chọn tối đa 5 ảnh!');
                e.target.value = '';
                return;
            }
            
            if (files.length > 0) {
                let html = '<div style="margin-top: 10px;"><strong>Đã chọn ' + files.length + ' ảnh:</strong><br>';
                for (let i = 0; i < files.length; i++) {
                    const file = files[i];
                    if (file.size > 5 * 1024 * 1024) {
                        alert('Ảnh "' + file.name + '" quá lớn! Tối đa 5MB.');
                        e.target.value = '';
                        return;
                    }
                    html += '• ' + file.name + ' (' + (file.size/1024/1024).toFixed(2) + ' MB)<br>';
                }
                html += '</div>';
                preview.innerHTML = html;
                preview.style.display = 'block';
            }
        });

        // Multiple document files upload preview
        document.getElementById('documentFiles').addEventListener('change', function(e) {
            const files = e.target.files;
            const preview = document.getElementById('documentPreview');
            
            if (files.length > 3) {
                alert('Chỉ được chọn tối đa 3 tài liệu!');
                e.target.value = '';
                return;
            }
            
            if (files.length > 0) {
                let html = '<div style="margin-top: 10px;"><strong>Đã chọn ' + files.length + ' tài liệu:</strong><br>';
                for (let i = 0; i < files.length; i++) {
                    const file = files[i];
                    if (file.size > 10 * 1024 * 1024) {
                        alert('Tài liệu "' + file.name + '" quá lớn! Tối đa 10MB.');
                        e.target.value = '';
                        return;
                    }
                    html += '• ' + file.name + ' (' + (file.size/1024/1024).toFixed(2) + ' MB)<br>';
                }
                html += '</div>';
                preview.innerHTML = html;
                preview.style.display = 'block';
            }
        });

        // Progress display update
        document.querySelector('input[name="Progress"]').addEventListener('input', function(e) {
            document.querySelector('.progress-display').textContent = e.target.value + '%';
        });

        // Delete confirmation
        function confirmDelete(projectId) {
            if (confirm('🗑️ Bạn có chắc chắn muốn xóa dự án này?\n\nDự án sẽ được chuyển vào thùng rác và có thể khôi phục sau này.')) {
                // Direct delete via GET request
                window.location.href = '/admin/projects/delete/' + projectId;
            }
        }
    </script>
</body>
</html>
