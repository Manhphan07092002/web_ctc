    // Format bytes helper
    function formatBytes(bytes) {
        if (bytes === 0) return '0 B';
        var k = 1024;
        var sizes = ['B', 'KB', 'MB', 'GB'];
        var i = Math.floor(Math.log(bytes) / Math.log(k));
        return parseFloat((bytes / Math.pow(k, i)).toFixed(1)) + ' ' + sizes[i];
    }
    
    // Get display name for prettier file names
    function getDisplayName(fileName) {
        if (!fileName) return 'Unknown';
        
        var nameWithoutExt = fileName.substring(0, fileName.lastIndexOf('.')) || fileName;
        var extension = fileName.substring(fileName.lastIndexOf('.')) || '';
        
        // If filename is very long hash-like string, create a prettier name
        if (nameWithoutExt.length > 30 && isHashLike(nameWithoutExt)) {
            var fileType = getFileTypeFromExtension(extension);
            var now = new Date();
            var timestamp = now.getHours().toString().padStart(2, '0') + ':' + 
                           now.getMinutes().toString().padStart(2, '0');
            return fileType + '_' + timestamp + extension;
        }
        
        // If filename is too long, truncate it nicely
        if (nameWithoutExt.length > 20) {
            return nameWithoutExt.substring(0, 15) + '...' + extension;
        }
        
        return fileName;
    }
    
    // Check if string looks like a hash
    function isHashLike(text) {
        if (text.length < 20) return false;
        
        var alphanumericCount = 0;
        for (var i = 0; i < text.length; i++) {
            var c = text.charAt(i);
            if ((c >= 'a' && c <= 'z') || (c >= 'A' && c <= 'Z') || (c >= '0' && c <= '9')) {
                alphanumericCount++;
            }
        }
        
        // If more than 80% is alphanumeric, consider it hash-like
        return (alphanumericCount / text.length) > 0.8;
    }
    
    // Get file type from extension
    function getFileTypeFromExtension(extension) {
        switch (extension.toLowerCase()) {
            case '.jpg':
            case '.jpeg':
            case '.png':
            case '.gif':
            case '.webp':
                return 'Hình ảnh';
            case '.pdf':
                return 'PDF';
            case '.doc':
            case '.docx':
                return 'Word';
            case '.xls':
            case '.xlsx':
                return 'Excel';
            case '.ppt':
            case '.pptx':
                return 'PowerPoint';
            default:
                return 'File';
        }
    }
    
