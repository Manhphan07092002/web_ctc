@{
    Layout = null;
    string callBack = Request["callback"];
    string tinymceMode = Request["tinymce"];
    
    // Security: Validate callback parameter
    if (!string.IsNullOrEmpty(callBack))
    {
        // Only allow alphanumeric characters and underscores for callback function names
        if (!System.Text.RegularExpressions.Regex.IsMatch(callBack, @"^[a-zA-Z_][a-zA-Z0-9_]*$"))
        {
            callBack = "defaultCallback"; // Fallback to safe default
        }
    }
    else
    {
        callBack = "defaultCallback";
    }
}
<!DOCTYPE html>

<html>
<head>
    <meta name="robots" content="noindex">
    <meta name="googlebot" content="noindex">
    <meta charset="UTF-8">
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
    <meta http-equiv="Pragma" content="no-cache">
    <meta http-equiv="Expires" content="0">
    <!-- FilePicker v2025.11.08.10.08 - Delete functions re-enabled -->


    <link rel="shortcut icon" href="@Url.Content("/Content/Image")/favicon.png" />
    <link rel="icon" type="image/vnd.microsoft.icon" href="@Url.Content("/Content/Image")/favicon.ico" />
    <meta content='width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no' name='viewport'>

    <script src="https://code.jquery.com/jquery-1.10.2.min.js" type="text/javascript"></script>

    <link href="@Url.Content("/Content/")plugins/select2/select2.css" rel="stylesheet" />
    <script src="@Url.Content("/Content/")plugins/select2/select2.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <link href="~/Content/css/common.css" rel="stylesheet" />
    <script src="~/Scripts/common.js"></script>


    <!-- Bootstrap -->
    <link href="@Url.Content("~/Content/")plugins/gentelella-master/vendors/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link href="@Url.Content("~/Content/")plugins/gentelella-master/vendors/font-awesome/css/font-awesome.min.css" rel="stylesheet">
    <!-- iCheck -->
    <link href="@Url.Content("~/Content/")plugins/gentelella-master/vendors/iCheck/skins/flat/green.css" rel="stylesheet">
    <!-- Custom Theme Style -->
    <link href="@Url.Content("~/Content/")plugins/gentelella-master/build/css/custom.min.css" rel="stylesheet">


    <!-- jQuery (already loaded above) -->
    <!-- Bootstrap -->
    <script src="@Url.Content("~/Content/")plugins/gentelella-master/vendors/bootstrap/dist/js/bootstrap.min.js"></script>
    <!-- iCheck -->
    <script src="@Url.Content("~/Content/")plugins/gentelella-master/vendors/iCheck/icheck.min.js"></script>

    <style>
        #popupSelectImage body {
            background: #fff !important;
            color: #333 !important;
        }
        
        /* FilePicker Custom Styles */
        .file-item:hover {
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
            transform: translateY(-2px);
        }
        
        .folder-item:hover {
            background: #e3f2fd !important;
            border-color: #2196f3 !important;
        }
        
        .progress {
            height: 20px;
            background-color: #f5f5f5;
            border-radius: 10px;
            overflow: hidden;
        }
        
        .progress-bar {
            background: linear-gradient(45deg, #007bff, #0056b3);
            transition: width 0.3s ease;
        }
        
        .btn:hover {
            transform: translateY(-1px);
        }
        
        .breadcrumb {
            background: #f8f9fa;
            border-radius: 8px;
            padding: 10px 15px;
            margin-bottom: 20px;
        }
        
        .breadcrumb-item + .breadcrumb-item::before {
            content: ">";
            color: #6c757d;
        }
        
        .alert {
            border-radius: 8px;
            border: none;
        }
        
        .file-item img {
            transition: transform 0.3s ease;
        }
        
        .file-item:hover img {
            transform: scale(1.05);
        }
        
        /* Loading animation */
        .fa-spinner {
            animation: spin 1s linear infinite;
        }
        
        @@keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
        
        /* Loading skeleton styles */
        .loading-skeleton {
            opacity: 0.7;
        }
        
        .skeleton-item {
            background: #f8f9fa;
            border-radius: 8px;
            padding: 10px;
            margin-bottom: 15px;
            height: 200px;
        }
        
        .skeleton-image {
            width: 100%;
            height: 120px;
            background: linear-gradient(90deg, #e0e0e0 25%, #f0f0f0 50%, #e0e0e0 75%);
            background-size: 200% 100%;
            animation: skeleton-loading 1.5s infinite;
            border-radius: 4px;
            margin-bottom: 10px;
        }
        
        .skeleton-text {
            width: 80%;
            height: 12px;
            background: linear-gradient(90deg, #e0e0e0 25%, #f0f0f0 50%, #e0e0e0 75%);
            background-size: 200% 100%;
            animation: skeleton-loading 1.5s infinite;
            border-radius: 4px;
            margin: 0 auto;
        }
        
        @@keyframes skeleton-loading {
            0% { background-position: 200% 0; }
            100% { background-position: -200% 0; }
        }
        
        /* Enhanced progress bar */
        #progressText {
            font-size: 12px;
            font-weight: bold;
            color: #fff;
            text-shadow: 1px 1px 1px rgba(0,0,0,0.3);
        }
        
        /* Button state transitions */
        .btn {
            transition: all 0.2s ease;
        }
        
        .btn:disabled {
            opacity: 0.7;
            cursor: not-allowed;
        }

        /* Mobile responsive */
        @@media (max-width: 768px) {
            .file-item {
                height: 180px !important;
            }
            
            .col-xs-6 {
                width: 50%;
                float: left;
            }
            
            .skeleton-item {
                height: 160px;
            }
            
            .skeleton-image {
                height: 100px;
            }
        }
    </style>
</head>
<body style="background: #fff !important; color: #333 !important;">
    <div class="modal-body content_body">
        <div>

            <div class="form-group">
                <div class="row">
                    <div class="col-lg-12">
                        <div class="input-group input-group">
                            <input id="folderName" class="form-control" placeholder="Tạo thư mục mới" name="data" type="text" 
                                   maxlength="100" aria-label="Tên thư mục mới" />
                            <span class="input-group-btn">
                                <button type="button" style="min-width: 100px;" class="btn btn-danger btn-flat" 
                                        onclick="createFolder()" id="btnCreateDirectory" 
                                        data-loading-text="Đang tạo thư mục" aria-label="Tạo thư mục mới">
                                    <i class="fa fa-folder-plus"></i> Tạo thư mục
                                </button>
                            </span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="form-group">
                <div class="row">
                    <div class="col-lg-12">
                        <div class="input-group input-group">
                            <input id="txtSearch" class="form-control" placeholder="Nhập từ khóa tìm kiếm" name="data" type="text" 
                                   aria-label="Từ khóa tìm kiếm" />
                            <span class="input-group-btn">
                                <button type="button" style="min-width: 100px;" class="btn btn-success btn-flat" 
                                        onclick="search()" id="btnSearch" data-loading-text="Đang tìm kiếm..." 
                                        aria-label="Tìm kiếm file">
                                    <i class="fa fa-search"></i> Tìm Kiếm
                                </button>
                            </span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="form-group">
                <form id="frmUpLoadImage" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <div class="input-group input-group">
                        <span class="input-group-addon">
                            <input type="checkbox" checked id="rdAutoRename" aria-label="Tự động đổi tên file">
                            <label for="rdAutoRename" style="margin-left: 5px;">Auto rename</label>
                        </span>
                        <input class="form-control" placeholder="Chọn file để upload" name="uploadFiles" type="file" 
                               multiple accept=".jpg,.jpeg,.png,.gif,.webp,.bmp,.svg,.pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx"
                               aria-label="Chọn file để upload" />
                        <span class="input-group-btn">
                            <button type="button" style="min-width: 100px;" class="btn btn-info btn-flat" 
                                    id="btnUpload" data-loading-text="Đang upload..."
                                    aria-label="Upload file">
                                <i class="fa fa-upload"></i> Upload
                            </button>
                        </span>
                    </div>
                    <div id="uploadProgress" style="display: none; margin-top: 10px;">
                        <div class="progress">
                            <div class="progress-bar progress-bar-striped active" role="progressbar" 
                                 style="width: 0%" id="progressBar">
                                <span id="progressText">0%</span>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
        @if (ViewBag.TestMessage != null)
        {
            <div class="alert alert-success">
                <strong>✅ @ViewBag.TestMessage</strong>
            </div>
        }
        
        <div id="divContainer">

        </div>
    </div>
</body>
</html>



<script>
    // Global variables - OPTIMIZED
    var currentPath = "";
    var tinymceMode = '@Html.Raw(tinymceMode)';
    var callbackFunction = '@Html.Raw(callBack)';
    var pathHistory = [];
    var isLoading = false;
    
    // Performance optimization variables
    var directoryCache = new Map();
    var searchDebounceTimer = null;
    var lastSearchTerm = "";
    var requestQueue = [];

    // Upload files function - MOVED UP for proper hoisting
    function uploadFiles() {
        var fileInput = $('input[name="uploadFiles"]')[0];
        var files = fileInput.files;
        
        if (!files || files.length === 0) {
            // Removed warning toast - silent validation
            return;
        }

        // Validate files
        var validationResult = validateFiles(files);
        if (!validationResult.isValid) {
            // Removed validation error toast - silent validation
            return;
        }

        var autoRename = $("#rdAutoRename").is(":checked");
        var formData = new FormData();
        
        // Add files to FormData
        for (var i = 0; i < files.length; i++) {
            formData.append('uploadFiles', files[i]);
        }
        
        formData.append('path', currentPath);
        formData.append('rename', autoRename);
        
        // Add anti-forgery token if available
        var token = $('input[name="__RequestVerificationToken"]').val();
        if (token) {
            formData.append('__RequestVerificationToken', token);
        }

        // Show progress
        showUploadProgress();
        setButtonLoading('#btnUpload', true);

        // Use XMLHttpRequest for progress tracking - OPTIMIZED
        var xhr = new XMLHttpRequest();
        var startTime = Date.now();
        
        xhr.upload.addEventListener('progress', function(e) {
            if (e.lengthComputable) {
                var percentComplete = Math.round((e.loaded / e.total) * 100);
                var elapsed = Date.now() - startTime;
                var speed = e.loaded / (elapsed / 1000); // bytes per second
                
                updateUploadProgressOptimized(percentComplete, speed, e.loaded, e.total);
            }
        });

        xhr.addEventListener('load', function() {
            try {
                var response = JSON.parse(xhr.responseText);
                
                // Handle both response formats: {success: true} and {Code: 1}
                var isSuccess = response.success === true || response.Code === 1;
                var message = response.message || response.Message || 'Upload completed';
                
                if (isSuccess) {
                    // Removed toast notification - silent success
                    if (response.errors && response.errors.length > 0) {
                        console.warn('Upload warnings:', response.errors);
                    }
                    
                    // Add uploaded files to current view without reload
                    if (response.uploadedFiles && response.uploadedFiles.length > 0) {
                        addFilesToCurrentView(response.uploadedFiles);
                    } else {
                        // Fallback: smooth refresh if no file info returned
                        setTimeout(function() {
                            refreshCurrentDirectory();
                        }, 500);
                    }
                    
                    $("#frmUpLoadImage")[0].reset();
                    
                    // Reset file input visual state
                    $('#btnUpload').removeClass('btn-success').addClass('btn-info');
                    $('#btnUpload').find('i').removeClass('fa-check').addClass('fa-upload');
                } else {
                    console.error('Upload failed:', message);
                    // Removed error toast - silent fail
                }
            } catch (error) {
                console.error('Error parsing upload response:', error);
                showMessage('Lỗi khi xử lý phản hồi từ server: ' + xhr.responseText.substring(0, 100), 'error');
            }
            hideUploadProgress();
            setButtonLoading('#btnUpload', false);
        });

        xhr.addEventListener('error', function() {
            // Removed error toast - silent fail
            hideUploadProgress();
            setButtonLoading('#btnUpload', false);
        });

        xhr.open('POST', '/filepicker/UploadImage');
        xhr.send(formData);
    }

    // Make functions globally accessible for onclick calls from List.cshtml
    window.uploadFiles = uploadFiles;
    window.removeFile = removeFile;
    window.removeFolder = removeFolder;
    window.onFileSelect = onFileSelect;
    window.loadPicker = loadPicker;

    // Initialize on document ready - v2025.11.08.10.08
    $(document).ready(function() {
        
        // Add event listeners
        setupEventListeners();
        
        // Load initial directory on page ready with fallback
        try {
            loadPicker('');
        } catch (loadError) {
            console.error('🔴 Initial load error:', loadError);
            
            // Fallback: show basic file browser
            $("#divContainer").html(
                '<div class="alert alert-warning" style="margin: 20px;">' +
                '<h4>⚠️ Chế độ cơ bản</h4>' +
                '<p>Đang chạy ở chế độ cơ bản do lỗi tải giao diện.</p>' +
                '<p>Chức năng upload vẫn hoạt động bình thường.</p>' +
                '</div>'
            );
        }
    });

    // Setup event listeners - OPTIMIZED
    function setupEventListeners() {
        // Optimized search with debouncing and instant clear
        $('#txtSearch').on('input', function(e) {
            var searchText = $(this).val().trim();
            if (searchText === '') {
                instantSearch(); // Instant clear
            } else {
                search(); // Debounced search
            }
        });
        
        // Search on Enter key (immediate)
        $('#txtSearch').on('keydown', function(e) {
            if (e.keyCode === 13) {
                e.preventDefault();
                if (searchDebounceTimer) {
                    clearTimeout(searchDebounceTimer);
                }
                var searchText = $(this).val().trim();
                lastSearchTerm = searchText;
                setButtonLoading('#btnSearch', true);
                loadPickerOptimized(currentPath, searchText);
            }
        });

        // Upload button click - optimized
        $('#btnUpload').on('click', function(e) {
            e.preventDefault();
            if ($(this).prop('disabled')) return; // Prevent double-clicks
            
            var fileCount = $('input[name="uploadFiles"]')[0].files.length;
            
            if (fileCount > 0) {
                uploadFiles();
            } else {
                // Removed warning toast - silent validation
            }
        });

        // Prevent form submission
        $('#frmUpLoadImage').on('submit', function(e) {
            e.preventDefault();
            uploadFiles();
        });
        
        // File input change event for instant feedback
        $('input[name="uploadFiles"]').on('change', function() {
            var fileCount = this.files.length;
            if (fileCount > 0) {
                $('#btnUpload').removeClass('btn-info').addClass('btn-success');
                $('#btnUpload').find('i').removeClass('fa-upload').addClass('fa-check');
            } else {
                $('#btnUpload').removeClass('btn-success').addClass('btn-info');
                $('#btnUpload').find('i').removeClass('fa-check').addClass('fa-upload');
            }
        });
    }

    // File selection callback - FIXED XSS vulnerability
    function onFileSelect(file) {
        try {
            if (typeof parent[callbackFunction] === 'function') {
                parent[callbackFunction](file);
            } else if (typeof parent.defaultCallback === 'function') {
                parent.defaultCallback(file);
            } else {
                console.warn('Callback function not found:', callbackFunction);
            }

            // Close TinyMCE dialog if applicable
            if (tinymceMode === "1" && parent.tinymce && parent.tinymce.activeEditor) {
                parent.tinymce.activeEditor.windowManager.close();
            }
        } catch (error) {
            // Removed file selection error toast - silent fail
        }
    }

    // Search function - OPTIMIZED with debouncing
    function search() {
        var searchText = $('#txtSearch').val().trim();
        
        // Clear previous timer
        if (searchDebounceTimer) {
            clearTimeout(searchDebounceTimer);
        }
        
        // Debounce search requests
        searchDebounceTimer = setTimeout(function() {
            if (searchText === lastSearchTerm) return; // Avoid duplicate searches
            
            lastSearchTerm = searchText;
            setButtonLoading('#btnSearch', true);
            loadPickerOptimized(currentPath, searchText);
        }, 300); // 300ms debounce
    }
    
    // Instant search for empty queries
    function instantSearch() {
        var searchText = $('#txtSearch').val().trim();
        if (searchText === '') {
            lastSearchTerm = '';
            loadPickerOptimized(currentPath, '');
        }
    }

    // Load directory contents - OPTIMIZED with caching
    function loadPickerOptimized(path, searchText) {
        if (isLoading) return;
        
        path = path || "";
        searchText = searchText || $("#txtSearch").val().trim();
        
        // Create cache key
        var cacheKey = path + '|' + searchText;
        
        // Check cache first (only for non-search queries to avoid stale results)
        if (!searchText && directoryCache.has(cacheKey)) {
            var cachedData = directoryCache.get(cacheKey);
            var cacheAge = Date.now() - cachedData.timestamp;
            
            // Use cache if less than 30 seconds old
            if (cacheAge < 30000) {
                $("#divContainer").html(cachedData.html);
                currentPath = path;
                updateHistory(path);
                setButtonLoading('#btnSearch', false);
                return;
            }
        }
        
        isLoading = true;
        currentPath = path;
        updateHistory(path);
        
        // Show loading skeleton
        showLoadingSkeleton();

        $.ajax({
            url: "/filepicker/List",
            method: "POST",
            data: { 
                path: currentPath, 
                text: searchText,
                __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
            },
            timeout: 15000, // Reduced timeout for faster feedback
            success: function(html) {
                // Cache the result (only for directory listings, not searches)
                if (!searchText) {
                    directoryCache.set(cacheKey, {
                        html: html,
                        timestamp: Date.now()
                    });
                    
                    // Limit cache size to prevent memory issues
                    if (directoryCache.size > 20) {
                        var firstKey = directoryCache.keys().next().value;
                        directoryCache.delete(firstKey);
                    }
                }
                
                // Smooth transition
                $("#divContainer").fadeOut(100, function() {
                    $(this).html(html).fadeIn(200);
                });
                
                setButtonLoading('#btnSearch', false);
            },
            error: function(xhr, status, error) {
                console.error('🔴 Directory loading error:', {
                    status: xhr.status,
                    statusText: xhr.statusText,
                    responseText: xhr.responseText,
                    error: error
                });
                
                // Show error details in console for debugging
                if (xhr.responseText) {
                    console.error('🔴 Server response:', xhr.responseText.substring(0, 500));
                }
                
                // Try to show a simple error message in container with retry
                $("#divContainer").html(
                    '<div class="alert alert-danger" style="margin: 20px;">' +
                    '<h4>❌ Lỗi tải danh sách file</h4>' +
                    '<p>Status: ' + xhr.status + ' - ' + xhr.statusText + '</p>' +
                    '<p>Vui lòng kiểm tra console để biết thêm chi tiết.</p>' +
                    '<button class="btn btn-primary" onclick="location.reload()">🔄 Tải lại trang</button>' +
                    '</div>'
                );
                
                setButtonLoading('#btnSearch', false);
                hideLoadingSkeleton();
            },
            complete: function() {
                isLoading = false;
            }
        });
    }
    
    // Legacy function for backward compatibility
    function loadPicker(path) {
        loadPickerOptimized(path, "");
    }
    
    // Update history helper
    function updateHistory(path) {
        if (pathHistory.length === 0 || pathHistory[pathHistory.length - 1] !== path) {
            pathHistory.push(path);
        }
    }
    
    // Add uploaded files directly to current view - NO RELOAD
    function addFilesToCurrentView(uploadedFiles) {
        var container = $("#divContainer .row");
        if (container.length === 0) {
            // If no row container, fallback to refresh
            setTimeout(function() {
                refreshCurrentDirectory();
            }, 500);
            return;
        }
        
        // Create file cards for each uploaded file
        uploadedFiles.forEach(function(fileInfo, index) {
            setTimeout(function() {
                var fileCard = createFileCard(fileInfo);
                
                // Add with animation
                fileCard.css({
                    'opacity': '0',
                    'transform': 'scale(0.8)'
                });
                
                // Insert at the beginning (newest first)
                container.prepend(fileCard);
                
                // Animate in
                fileCard.animate({
                    'opacity': 1
                }, 300).css({
                    'transform': 'scale(1)',
                    'transition': 'transform 0.3s ease'
                });
                
            }, index * 100); // Stagger animation
        });
        
        // Clear cache to ensure fresh data on next load
        var searchText = $("#txtSearch").val().trim();
        var cacheKey = currentPath + '|' + searchText;
        directoryCache.delete(cacheKey);
    }
    
    // Create file card HTML
    function createFileCard(fileInfo) {
        var fileName = fileInfo.name || fileInfo.fileName || 'Unknown';
        var filePath = fileInfo.path || fileInfo.webPath || (currentPath + '/' + fileName);
        var fileSize = fileInfo.size || fileInfo.fileSize || 0;
        var isImage = /\.(jpg|jpeg|png|gif|webp|bmp|svg)$/i.test(fileName);
        
        var sizeText = formatBytes(fileSize);
        var iconClass = isImage ? 'fa-file-image-o' : 'fa-file-o';
        var timeText = 'Vừa tải lên'; // Default for new uploads 
        var displayName = getDisplayName(fileName); // Pretty name
        
        var cardHtml = '<div class="col-xs-6 col-sm-4 col-md-3 col-lg-2">' +
                       '<div class="file-item" style="position: relative; border: 1px solid #ddd; border-radius: 8px; padding: 10px; margin-bottom: 15px; height: 200px; cursor: pointer; background: #fff;">' +
                       '<div style="position: relative; height: 120px; overflow: hidden; border-radius: 4px; background: #f8f9fa; display: flex; align-items: center; justify-content: center;">';
        
        if (isImage) {
            cardHtml += '<img src="' + filePath + '" style="max-width: 100%; max-height: 100%; object-fit: cover;" ' +
                       'onerror="this.style.display=\'none\'; this.nextElementSibling.style.display=\'flex\';" />' +
                       '<div style="display: none; flex-direction: column; align-items: center; color: #6c757d;">' +
                       '<i class="fa fa-file-image-o" style="font-size: 32px; margin-bottom: 5px;"></i>' +
                       '<small>Image</small></div>';
        } else {
            cardHtml += '<div style="display: flex; flex-direction: column; align-items: center; color: #6c757d;">' +
                       '<i class="fa ' + iconClass + '" style="font-size: 32px; margin-bottom: 5px;"></i>' +
                       '<small>File</small></div>';
        }
        
        cardHtml += '</div>' +
                   '<div style="margin-top: 8px; text-align: center;">' +
                   '<div style="font-size: 12px; font-weight: bold; color: #333; word-break: break-word; height: 24px; overflow: hidden; line-height: 12px;" title="' + fileName + '">' +
                   displayName + '</div>' +
                   '<div style="font-size: 10px; color: #6c757d; margin-top: 2px;">' + sizeText + '</div>' +
                   '<div style="font-size: 9px; color: #28a745; margin-top: 2px; font-weight: bold;">' + timeText + '</div>' +
                   '</div>' +
                   
                   // Action buttons
                   '<button type="button" class="btn btn-sm btn-primary" ' +
                   'style="position: absolute; top: 5px; left: 5px; z-index: 10; opacity: 0.8;" ' +
                   'onclick="onFileSelect(\'' + filePath + '\')" title="Chọn file ' + fileName + '">' +
                   '<i class="fa fa-check"></i></button>' +
                   
                   '<button type="button" class="btn btn-sm btn-danger" ' +
                   'style="position: absolute; top: 5px; right: 5px; z-index: 10; opacity: 0.8;" ' +
                   'onclick="removeFile(\'' + filePath + '\')" title="Xóa file ' + fileName + '">' +
                   '<i class="fa fa-trash"></i></button>' +
                   
                   '</div></div>';
        
        return $(cardHtml);
    }
    
