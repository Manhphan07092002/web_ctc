    // Smooth refresh current directory without losing view
    function refreshCurrentDirectory() {
        // Clear cache for current directory to get fresh data
        var searchText = $("#txtSearch").val().trim();
        var cacheKey = currentPath + '|' + searchText;
        directoryCache.delete(cacheKey);
        
        // Add subtle loading indicator
        var container = $("#divContainer");
        container.css('opacity', '0.7');
        
        $.ajax({
            url: "/filepicker/List",
            method: "POST",
            data: { 
                path: currentPath, 
                text: searchText,
                __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
            },
            timeout: 10000,
            success: function(html) {
                // Cache the fresh result
                if (!searchText) {
                    directoryCache.set(cacheKey, {
                        html: html,
                        timestamp: Date.now()
                    });
                }
                
                // Smooth update without flicker
                container.html(html).animate({opacity: 1}, 300);
            },
            error: function(xhr, status, error) {
                console.error('Error refreshing directory:', error);
                // Removed refresh error toast - silent fail
                container.css('opacity', '1'); // Restore opacity on error
            }
        });
    }

