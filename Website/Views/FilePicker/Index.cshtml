    // File validation
    function validateFiles(files) {
        var maxSize = 10 * 1024 * 1024; // 10MB
        var allowedTypes = ['.jpg', '.jpeg', '.png', '.gif', '.webp', '.bmp', '.svg', '.pdf', '.doc', '.docx', '.xls', '.xlsx', '.ppt', '.pptx'];
        
        for (var i = 0; i < files.length; i++) {
            var file = files[i];
            
            // Check file size
            if (file.size > maxSize) {
                return {
                    isValid: false,
                    message: 'File "' + file.name + '" vượt quá kích thước cho phép (10MB)'
                };
            }
            
            // Check file type
            var extension = '.' + file.name.split('.').pop().toLowerCase();
            if (allowedTypes.indexOf(extension) === -1) {
                return {
                    isValid: false,
                    message: 'File "' + file.name + '" có định dạng không được hỗ trợ'
                };
            }
        }
        
        return { isValid: true };
    }

