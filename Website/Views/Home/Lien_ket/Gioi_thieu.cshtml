    }
    .contact-card {
        background-color: #fff;
        padding: 30px;
        border-radius: 8px;
        box-shadow: 0 2px 15px rgba(0,0,0,0.05);
    }
    .contact-card h4 {
        font-size: 22px;
        font-weight: 700;
        margin-bottom: 20px;
    }
    .contact-details {
        list-style: none;
        padding: 0;
        margin: 0;
    }
    .contact-details li {
        display: flex;
        align-items: flex-start;
        margin-bottom: 15px;
        font-size: 15px;
    }
    .contact-details i {
        color: #007bff;
        margin-right: 15px;
        margin-top: 4px;
    }
    .contact-details a {
        color: #212529;
        text-decoration: none;
        transition: color 0.3s;
    }
    .contact-details a:hover {
        color: #007bff;
    }
    .map-container {
        border-radius: 8px;
        overflow: hidden;
    }
</style>