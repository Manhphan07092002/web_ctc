@{
    Layout = null;
}

<style>
    /* === MODERN FEATURES SECTION CSS === */
    
    /* --- CSS VARIABLES --- */
    :root {
        --primary-gradient: linear-gradient(135deg, #2677f1 0%, #1565c0 100%);
        --secondary-gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        --accent-gradient: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
        --success-gradient: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
        --accent-color: #2677f1;
        --accent-light: rgba(38, 119, 241, 0.1);
        --heading-color: #1a1a1a;
        --text-color: #4a5568;
        --text-light: #718096;
        --border-color: #e2e8f0;
        --background-light: #ffffff;
        --background-gradient: linear-gradient(135deg, #f7fafc 0%, #edf2f7 100%);
        --shadow-light: 0 4px 6px rgba(0, 0, 0, 0.05);
        --shadow-medium: 0 10px 25px rgba(0, 0, 0, 0.1);
        --shadow-heavy: 0 20px 40px rgba(0, 0, 0, 0.15);
        --font-heading: 'Be Vietnam Pro', 'Roboto', sans-serif;
        --font-body: 'Be Vietnam Pro', 'Roboto', sans-serif;
        --border-radius: 16px;
        --border-radius-lg: 24px;
    }

    /* --- KEYFRAME ANIMATIONS --- */
    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes fadeInLeft {
        from {
            opacity: 0;
            transform: translateX(-30px);
        }
        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    @@keyframes fadeInRight {
        from {
            opacity: 0;
            transform: translateX(30px);
        }
        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    @@keyframes scaleIn {
        from {
            opacity: 0;
            transform: scale(0.9);
        }
        to {
            opacity: 1;
            transform: scale(1);
        }
    }

    @@keyframes pulse {
        0%, 100% {
            transform: scale(1);
        }
        50% {
            transform: scale(1.05);
        }
    }

    @@keyframes float {
        0%, 100% {
            transform: translateY(0px);
        }
        50% {
            transform: translateY(-10px);
        }
    }

    @@keyframes shimmer {
        0% {
            transform: translateX(-100%);
        }
        100% {
            transform: translateX(100%);
        }
    }

    @@keyframes modalSlideIn {
        from {
            opacity: 0;
            transform: scale(0.8) translateY(-50px);
        }
        to {
            opacity: 1;
            transform: scale(1) translateY(0);
        }
    }

    /* --- MODERN FEATURES CONTAINER --- */
    .features-container {
        max-width: 100%;
        margin: 60px auto;
        padding: 40px 20px;
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 50px;
        position: relative;
        text-align: center;
    }

    .features-container::before {
        content: '';
        position: absolute;
        top: -20px;
        left: 50%;
        transform: translateX(-50%);
        width: 100px;
        height: 4px;
        background: var(--primary-gradient);
        border-radius: 2px;
    }

    /* --- MODERN FEATURE ITEMS --- */
    .feature-item {
        background: var(--background-light);
        border-radius: var(--border-radius-lg);
        padding: 40px 30px;
        text-align: center;
        cursor: pointer;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: var(--shadow-light);
        position: relative;
        overflow: hidden;
        animation: fadeInUp 0.8s ease-out both;
        border: 2px solid transparent;
        min-height: 280px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
    }

    .feature-item:nth-child(1) {
        animation-delay: 0.1s;
    }

    .feature-item:nth-child(2) {
        animation-delay: 0.2s;
    }

    .feature-item:nth-child(3) {
        animation-delay: 0.3s;
    }

    .feature-item:nth-child(4) {
        animation-delay: 0.4s;
    }

    .feature-item::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: var(--primary-gradient);
        transform: scaleX(0);
        transition: transform 0.4s ease;
    }

    .feature-item:hover::before {
        transform: scaleX(1);
    }

    .feature-item:hover {
        transform: translateY(-10px);
        box-shadow: var(--shadow-heavy);
        border-color: var(--accent-light);
    }

    /* --- MODERN CIRCLE ICONS --- */
    .circle-wrapper {
        margin-bottom: 20px;
        display: flex;
        justify-content: center;
    }

    .circle-shape {
        width: 80px;
        height: 80px;
        background: var(--primary-gradient);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        transition: all 0.4s ease;
        box-shadow: var(--shadow-medium);
        flex-shrink: 0;
    }

    .feature-item:nth-child(2) .circle-shape {
        background: var(--secondary-gradient);
    }

    .feature-item:nth-child(3) .circle-shape {
        background: var(--accent-gradient);
    }

    .feature-item:nth-child(4) .circle-shape {
        background: var(--success-gradient);
    }

    .circle-shape::before {
        content: '';
        position: absolute;
        top: -4px;
        left: -4px;
        right: -4px;
        bottom: -4px;
        background: var(--primary-gradient);
        border-radius: 50%;
        z-index: -1;
        opacity: 0;
        transition: opacity 0.4s ease;
    }

    .feature-item:hover .circle-shape::before {
        opacity: 0.3;
        animation: pulse 2s infinite;
    }

    .feature-item:hover .circle-shape {
        transform: scale(1.1);
        animation: float 3s ease-in-out infinite;
    }

    .icon-content {
        color: white;
        font-size: 32px;
        z-index: 2;
    }

    /* --- MODERN FEATURE CONTENT --- */
    .feature-content {
        flex: 1;
        display: flex;
        flex-direction: column;
        text-align: center;
        align-items: center;
        justify-content: center;
        width: 100%;
    }
    
    .feature-content * {
        text-align: center;
    }
    
    .feature-content h3 {
        font-family: var(--font-heading);
        font-size: 18px;
        font-weight: 700;
        color: var(--heading-color);
        margin-bottom: 12px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        transition: color 0.3s ease;
        line-height: 1.3;
        text-align: center;
        width: 100%;
        display: block;
    }

    .feature-item:hover .feature-content h3 {
        color: var(--accent-color);
    }

    .feature-content hr {
        width: 40px;
        height: 2px;
        background: var(--primary-gradient);
        border: none;
        margin: 8px auto 15px auto;
        border-radius: 2px;
        transition: width 0.4s ease;
    }

    .feature-item:hover .feature-content hr {
        width: 60px;
    }

    .feature-content p {
        font-family: var(--font-body);
        font-size: 14px;
        line-height: 1.6;
        color: var(--text-color);
        margin: 0;
        text-align: center;
        flex: 1;
        width: 100%;
        display: block;
    }
    
    .feature-content p strong {
        text-align: center;
        display: inline;
    }
    
    .feature-content p strong {
        display: inline;
    }

    .feature-content strong {
        color: var(--accent-color);
        font-weight: 600;
    }

    /* --- MODERN MODAL STYLES --- */
    .modal {
        display: none;
        position: fixed;
        z-index: 10000;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0, 0, 0, 0.6);
        backdrop-filter: blur(5px);
        animation: fadeInUp 0.3s ease-out;
    }

    .modal-content {
        background: var(--background-light);
        margin: 5% auto;
        padding: 40px;
        border-radius: var(--border-radius-lg);
        width: 90%;
        max-width: 800px;
        max-height: 80vh;
        overflow-y: auto;
        position: relative;
        box-shadow: var(--shadow-heavy);
        animation: modalSlideIn 0.4s ease-out;
    }

    .modal-content::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: var(--primary-gradient);
        border-radius: var(--border-radius-lg) var(--border-radius-lg) 0 0;
    }

    .close-button {
        position: absolute;
        top: 15px;
        right: 20px;
        font-size: 28px;
        font-weight: bold;
        color: var(--text-light);
        cursor: pointer;
        transition: all 0.3s ease;
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        background: var(--accent-light);
    }

    .close-button:hover {
        color: var(--accent-color);
        background: rgba(38, 119, 241, 0.2);
        transform: scale(1.1);
    }

    .modal-content h4 {
        font-family: var(--font-heading);
        font-size: 28px;
        font-weight: 700;
        background: var(--primary-gradient);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin: 0 0 25px 0;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .modal-content h5 {
        font-family: var(--font-heading);
        font-size: 20px;
        font-weight: 600;
        color: var(--accent-color);
        margin: 25px 0 15px 0;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .modal-content p {
        font-family: var(--font-body);
        font-size: 16px;
        line-height: 1.7;
        color: var(--text-color);
        margin-bottom: 20px;
    }

    .modal-content ul {
        padding-left: 0;
        list-style: none;
    }

    .modal-content ul li {
        font-size: 16px;
        line-height: 1.7;
        color: var(--text-color);
        margin-bottom: 12px;
        padding-left: 25px;
        position: relative;
    }

    .modal-content ul li::before {
        content: "\f00c";
        font-family: 'Font Awesome 5 Free';
        font-weight: 900;
        color: var(--accent-color);
        position: absolute;
        left: 0;
        top: 2px;
        font-size: 14px;
    }

    .download-button {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        background: var(--primary-gradient);
        color: white;
        padding: 12px 24px;
        border-radius: var(--border-radius);
        text-decoration: none;
        font-weight: 600;
        font-size: 14px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        transition: all 0.3s ease;
        box-shadow: var(--shadow-light);
        margin-top: 15px;
    }

    .download-button:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-medium);
        text-decoration: none;
        color: white;
    }

    .download-button i {
        font-size: 16px;
    }

    .report-year-section {
        background: var(--accent-light);
        padding: 25px;
        border-radius: var(--border-radius);
        margin-bottom: 20px;
        border-left: 4px solid var(--accent-color);
        transition: all 0.3s ease;
    }

    .report-year-section:hover {
        transform: translateX(5px);
        box-shadow: var(--shadow-light);
    }

    /* --- RESPONSIVE DESIGN --- */
    @@media (max-width: 1024px) {
        .features-container {
            grid-template-columns: repeat(2, 1fr);
            gap: 30px;
        }
        
        .feature-item {
            padding: 35px 25px;
        }
    }
    
    @@media (max-width: 768px) {
        .features-container {
            grid-template-columns: 1fr;
            gap: 20px;
            margin: 40px auto;
            padding: 20px 15px;
        }

        .feature-item {
            padding: 30px 20px;
            text-align: center;
        }
        
        .circle-wrapper {
            justify-content: center;
        }

        .circle-shape {
            width: 70px;
            height: 70px;
        }

        .icon-content {
            font-size: 28px;
        }

        .feature-content h3 {
            font-size: 16px;
            text-align: center;
        }
        
        .feature-content hr {
            margin: 8px auto 15px auto;
        }
        
        .feature-content p {
            text-align: center;
        }
        
        .feature-content * {
            text-align: center;
        }

        .modal-content {
            margin: 10% auto;
            padding: 30px 20px;
            width: 95%;
        }

        .modal-content h4 {
            font-size: 24px;
        }
    }
</style>

<div class="features-container">

        <div class="feature-item" data-target-modal="#hsnlModal">
            <div class="circle-wrapper"> <div class="circle-shape"> <div class="icon-content"> <i class="fas fa-edit"></i> </div> </div> </div>
            <div class="feature-content">
                <h3>HỒ SƠ NĂNG LỰC</h3>
                <hr />
                <p style="text-align: center;"><strong>Tìm hiểu toàn diện về chúng tôi:</strong> Từ năng lực pháp lý, tài chính, đội ngũ nhân sự chuyên nghiệp đến các dự án tiêu biểu đã thực hiện.</p>
            </div>
        </div>

        <div class="feature-item" data-target-modal="#bctcModal">
            <div class="circle-wrapper"> <div class="circle-shape"> <div class="icon-content"> <i class="fas fa-chart-line"></i> </div> </div> </div>
             <div class="feature-content">
                <h3>BÁO CÁO TÀI CHÍNH</h3>
                <hr />
                <p style="text-align: center;"><strong>Minh bạch & Tăng trưởng:</strong> Xem xét chi tiết tình hình tài chính, hiệu quả hoạt động và cam kết phát triển bền vững của CTC qua các năm.</p>
            </div>
        </div>

        <div class="feature-item" data-target-modal="#lvhđModal">
            <div class="circle-wrapper"> <div class="circle-shape"> <div class="icon-content"> <i class="fas fa-handshake"></i> </div> </div> </div>
             <div class="feature-content">
                <h3>LĨNH VỰC HOẠT ĐỘNG</h3>
                <hr />
                <p style="text-align: center;"><strong>Cung cấp giải pháp & sản phẩm công nghệ:</strong> Tích hợp hệ thống, thiết bị tin học, viễn thông, và xây dựng hạ tầng.</p>
            </div>
        </div>

        <div class="feature-item" data-target-modal="#tnsmModal">
            <div class="circle-wrapper"> <div class="circle-shape"> <div class="icon-content"> <i class="fas fa-rocket"></i> </div> </div> </div>
             <div class="feature-content">
                <h3>TẦM NHÌN - SỨ MỆNH</h3>
                <hr />
                <p style="text-align: center;"><strong>Dẫn đầu và tiên phong:</strong> Hướng tới vị thế hàng đầu khu vực, mang lại giá trị bền vững cho khách hàng và cổ đông.</p>
            </div>
        </div>
    </div>

    <div id="hsnlModal" class="modal">
         <div class="modal-content">
            <span class="close-button">&times;</span>
            <h4>Hồ sơ năng lực </h4>
            <p>Hồ sơ năng lực của chúng tôi cung cấp một cái nhìn chi tiết và toàn diện về CÔNG TY CỔ PHẦN XÂY LẮP BƯU ĐIỆN MIỀN TRUNG (CTC). Tại đây, Quý đối tác và khách hàng có thể tìm thấy thông tin đầy đủ về:</p>
            <ul>
                <li>Năng lực pháp lý: Giấy phép kinh doanh, chứng chỉ và các văn bản pháp lý liên quan.</li>
                <li>Năng lực tài chính: Các báo cáo tài chính tóm tắt, thể hiện sự ổn định và tiềm lực phát triển.</li>
                <li>Năng lực nhân sự: Giới thiệu về đội ngũ quản lý, kỹ sư và chuyên gia giàu kinh nghiệm.</li>
                <li>Năng lực trang thiết bị: Cơ sở vật chất và các trang thiết bị hiện đại phục vụ cho hoạt động kinh doanh và thi công.</li>
                <li>Kinh nghiệm và Dự án tiêu biểu: Danh sách các dự án đã hoàn thành, minh chứng cho năng lực và uy tín của chúng tôi.</li>
            </ul>
            <p>Chúng tôi tin rằng hồ sơ này sẽ giúp Quý vị hiểu rõ hơn về CTC và đưa ra quyết định hợp tác hiệu quả.</p>
            <a href="~/file/HSNL 2024.docx" download="HoSoNangLuc_CTC_2024.docx" class="download-button">
                <i class="fas fa-download"></i> Tải về Hồ sơ năng lực (DOCX)
            </a>
        </div>
    </div>

    <div id="bctcModal" class="modal">
