                                </small>
                            </span>
                        </a>
                    </li>
                }
            </ul>

            <ul class="nav navbar-nav navbar-right">
                <li>
                    <a href="tel:0915059666" title="Gọi Hotline">
                        <div class="contact-info">
                            <span class="contact-label">LIÊN HỆ NGAY</span>
                            <div class="phone-info">
                                 <img src="@Url.Content("~/Image/call.png")" alt="Call Icon" />
                                 <span class="hotline-number">0915.059.666</span>
                            </div>
                        </div>
                    </a>
                </li>
                
                @* Optimized Language Switcher v2.0 *@
