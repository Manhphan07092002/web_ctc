                               aria-label="Chuyển sang Tiếng Việt">
                                <img src="@Url.Content("~/Image/flags/vn.png")" 
                                     alt="" 
                                     class="flag-icon" 
                                     loading="lazy" 
                                     aria-hidden="true" /> 
                                Tiếng Việt
                            </a>
                        </li>
                        <li role="none">
                            <a href="#" 
                               role="menuitem" 
                               tabindex="0"
                               onclick="changeLanguage('en'); return false;"
                               onkeydown="if(event.key==='Enter'||event.key===' '){changeLanguage('en'); return false;}"
                               aria-label="Switch to English">
                                <img src="@Url.Content("~/Image/flags/us.png")" 
                                     alt="" 
                                     class="flag-icon" 
                                     loading="lazy" 
                                     aria-hidden="true" /> 
                                English
                            </a>
                        </li>
                    </ul>
                </li>
            </ul>

        </div>
    </div>
</div>