                             class="flag-icon" 
                             loading="lazy" />
                        <span id="current-lang" class="lang-text">VN</span>
                        <span class="caret" aria-hidden="true"></span>
                    </a>
                    <ul class="dropdown-menu" role="menu" aria-label="Danh sách ngôn ngữ">
