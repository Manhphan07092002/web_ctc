    ---
    Cách xưng hô khi trả lời:
    Hãy trả lời trực tiếp vào vấn đề, giữ giọng văn chuyên nghiệp, lịch sự và xưng hô là "CTC" khi cần thiết để khẳng định thương hiệu.
    `;

    // === CẬP NHẬT: DANH SÁCH CÂU HỎI NGẮN GỌN HƠN ===
    const allSuggestedQuestions = [
        "Thi công nhà ở cá nhân?",
        "Quy trình lắp điện mặt trời?",
        "Bao lâu có báo giá?",
        "Có bảo trì hệ thống điện không?",
        "Phạm vi hoạt động ở đâu?",
        "Chính sách bảo hành?",
        "Liên hệ bộ phận kinh doanh?",
        "Có nhận tổng thầu EPC không?",
        "Chi phí khảo sát thế nào?",
        "Thi công PCCC?"
    ];
    // ===================================================================

    // Function to initialize the chat with the knowledge base
    const initializeChat = () => {
        chatHistory = []; // Clear old history
        hasUserInteracted = false; // Reset tương tác
        chatBox.innerHTML = ''; // Xóa sạch box chat
        
        // Add the knowledge base as the first "turn" in the conversation
        chatHistory.push(
            { role: "user", parts: [{ text: companyKnowledge }] },
            { role: "model", parts: [{ text: "Đã hiểu. Tôi là trợ lý AI của CTC và sẵn sàng hỗ trợ." }] }
        );
        // Add the visible welcome message to history
        chatHistory.push({ role: "model", parts: [{ text: welcomeMessage }] });
        isChatInitialized = true;
    };

    // Hàm hiển thị câu hỏi gợi ý
    const displaySuggestedQuestions = () => {
        const existingSuggestions = document.getElementById('suggested-questions-container');
        if (existingSuggestions) {
            existingSuggestions.remove();
        }

        const container = document.createElement('div');
        container.id = 'suggested-questions-container';
        
        const title = document.createElement('div');
        title.className = 'suggested-title';
        title.textContent = 'Gợi ý cho bạn:';
        container.appendChild(title);

        const shuffled = [...allSuggestedQuestions].sort(() => 0.5 - Math.random());
        const selectedQuestions = shuffled.slice(0, 5);

        selectedQuestions.forEach(questionText => {
            const button = document.createElement('button');
            button.className = 'suggested-question-btn';
            button.textContent = questionText;
            button.onclick = () => {
                chatInput.value = questionText;
                handleSendMessage();
            };
            container.appendChild(button);
        });
        
        // Chèn container vào cuối box chat
        chatBox.appendChild(container);
        chatBox.scrollTop = chatBox.scrollHeight;
    };


    // === CẬP NHẬT: HIỂN THỊ CHAT NGAY LẬP TỨC ===
    const openChat = () => {
        aiChatContainer.classList.remove('hidden');
        aiChatButton.style.display = 'none';
        
        if (!isChatInitialized) {
            initializeChat();
            // Hiển thị lời chào và câu hỏi ngay lập tức
            addMessageToBox(welcomeMessage, 'ai');
            displaySuggestedQuestions();
        } else if (!hasUserInteracted) {
            // Nếu người dùng mở lại chat mà chưa tương tác, hiển thị lại câu hỏi gợi ý
            const existingMessage = chatBox.querySelector('.ai-message');
            const existingSuggestions = chatBox.querySelector('#suggested-questions-container');
            if(existingMessage && !existingSuggestions){
                 displaySuggestedQuestions();
            }
        }
        
        chatInput.focus();
    };

    // Function to close the chat window
    const closeChat = () => {
        aiChatContainer.classList.add('hidden');
        aiChatButton.style.display = 'flex';
    };

    // Function to add a message to the chat box UI
    const addMessageToBox = (text, sender, isLoading = false) => {
        const messageElement = document.createElement('div');
        messageElement.classList.add('chat-message', `${sender}-message`);
        if (isLoading) {
            messageElement.classList.add('loading');
            messageElement.textContent = 'AI đang trả lời...';
        } else {
            messageElement.innerHTML = text.replace(/\n/g, '<br>');
        }
        
        // Chèn tin nhắn vào trước khu vực câu hỏi gợi ý (nếu có)
        const suggestedContainer = document.getElementById('suggested-questions-container');
        if (suggestedContainer) {
            chatBox.insertBefore(messageElement, suggestedContainer);
        } else {
            chatBox.appendChild(messageElement);
        }

        chatBox.scrollTop = chatBox.scrollHeight;
        return messageElement;
    };

    // Function to handle sending a message
    const handleSendMessage = async () => {
        const userText = chatInput.value.trim();
        if (!userText || !isChatInitialized) return;

        // Đánh dấu đã tương tác và xóa các câu hỏi gợi ý
        hasUserInteracted = true;
        const suggestedContainer = document.getElementById('suggested-questions-container');
        if (suggestedContainer) {
            suggestedContainer.remove();
        }

        addMessageToBox(userText, 'user');
        chatInput.value = '';
        const loadingElement = addMessageToBox('', 'ai', true);

        chatHistory.push({ role: "user", parts: [{ text: userText }] });

        try {
            const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/${MODEL_NAME}:generateContent?key=${API_KEY}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ contents: chatHistory })
            });

            if (!response.ok) {
                const errorData = await response.json();
                throw new Error(`API call failed with status: ${response.status}. Details: ${JSON.stringify(errorData)}`);
            }

            const data = await response.json();
            
            if (data.candidates && data.candidates.length > 0 && data.candidates[0].content && data.candidates[0].content.parts && data.candidates[0].content.parts.length > 0) {
                 const aiText = data.candidates[0].content.parts[0].text;
                 loadingElement.innerHTML = aiText.replace(/\n/g, '<br>');
                 loadingElement.classList.remove('loading');
                 chatHistory.push({ role: "model", parts: [{ text: aiText }] });
            } else {
                 let errorMessage = "CTC đã nhận được câu hỏi, tuy nhiên có lỗi xảy ra trong quá trình xử lý. Quý khách vui lòng thử lại hoặc liên hệ trực tiếp.";
                 if(data.promptFeedback && data.promptFeedback.blockReason){
                   errorMessage = `Yêu cầu của bạn không thể được xử lý do: ${data.promptFeedback.blockReason}. Vui lòng diễn đạt lại câu hỏi.`;
                 }
                 loadingElement.textContent = errorMessage;
                 loadingElement.classList.remove('loading');
                 // Invalid response structure from API - handled gracefully
            }
        } catch (error) {
            // Gemini API Error - handled gracefully
            loadingElement.textContent = "Xin lỗi, đã có lỗi xảy ra. Vui lòng thử lại.";
            loadingElement.classList.remove('loading');
        }
    };

    // --- Event Listeners ---
    aiChatButton.addEventListener('click', openChat);
    closeChatButton.addEventListener('click', closeChat);
    sendButton.addEventListener('click', handleSendMessage);
    chatInput.addEventListener('keypress', (e) => {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            handleSendMessage();
        }
    });
</script>