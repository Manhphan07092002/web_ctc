    <script type="text/javascript">
    document.addEventListener("DOMContentLoaded", function() {
        // --- RESPONSIVE STATS SECTION WITH ENHANCED ANIMATIONS ---
        const statsSection = document.querySelector('.stats-banner');
        if (!statsSection) return;

        // Lưu trữ các timer để có thể hủy khi cần
        let animationTimers = [];
        let resizeTimeout;
        
        // Responsive breakpoints
        const breakpoints = {
            xs: 320,
            sm: 576,
            md: 768,
            lg: 992,
            xl: 1200
        };
        
        // Get current breakpoint
        function getCurrentBreakpoint() {
            const width = window.innerWidth;
            if (width >= breakpoints.xl) return 'xl';
            if (width >= breakpoints.lg) return 'lg';
            if (width >= breakpoints.md) return 'md';
            if (width >= breakpoints.sm) return 'sm';
            return 'xs';
        }
        
        // Mobile-optimized animation settings
        const responsiveSettings = {
            xl: { duration: 2500, delay: 0.15, easing: 'cubic-bezier(0.34, 1.56, 0.64, 1)' },
            lg: { duration: 2200, delay: 0.12, easing: 'cubic-bezier(0.34, 1.56, 0.64, 1)' },
            md: { duration: 2000, delay: 0.1, easing: 'cubic-bezier(0.25, 0.8, 0.25, 1)' },
            sm: { duration: 1600, delay: 0.08, easing: 'cubic-bezier(0.25, 0.8, 0.25, 1)' },
            xs: { duration: 1200, delay: 0.06, easing: 'cubic-bezier(0.25, 0.8, 0.25, 1)' }
        };
        
        // Mobile-specific optimizations
        function isMobileDevice() {
            return /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent);
        }
        
        function isReducedMotion() {
            return window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        }
        
        // Handle responsive layout changes
        function handleResponsiveChanges() {
            const currentBreakpoint = getCurrentBreakpoint();
            const settings = responsiveSettings[currentBreakpoint];
            const isMobile = currentBreakpoint === 'xs' || currentBreakpoint === 'sm';
            
            // Mobile-specific optimizations
            if (isMobile) {
                // Reduce animation complexity on mobile
                const circles = statsSection.querySelectorAll('.progress-ring-circle');
                circles.forEach(circle => {
                    circle.style.filter = 'none'; // Remove drop-shadow on mobile
                });
                
                // Optimize touch interactions
                const statsCircles = statsSection.querySelectorAll('.stats-circle');
                statsCircles.forEach(circle => {
                    circle.style.cursor = 'pointer';
                    circle.addEventListener('touchstart', function(e) {
                        this.style.transform = 'scale(0.95)';
                    }, { passive: true });
                    
                    circle.addEventListener('touchend', function(e) {
                        this.style.transform = 'scale(1)';
                    }, { passive: true });
                });
            }
            
            // Update animation settings based on screen size
            const columns = statsSection.querySelectorAll('.stats-column');
            columns.forEach((col, index) => {
                col.style.transitionDelay = `${settings.delay * index}s`;
            });
            
            // Recalculate circle sizes for SVG elements
            updateCircleSizes();
        }
        
        // Update SVG circle sizes based on current breakpoint
        function updateCircleSizes() {
            const currentBreakpoint = getCurrentBreakpoint();
            const circles = statsSection.querySelectorAll('.progress-ring-circle, .progress-ring-circle-bg');
            
            let radius;
            switch(currentBreakpoint) {
                case 'xs': radius = 54; break;  // 120px circle
                case 'sm': radius = 64; break;  // 140px circle  
                case 'md': radius = 74; break;  // 160px circle
                case 'lg': radius = 84; break;  // 180px circle
                default: radius = 94; break;    // 200px circle
            }
            
            const circumference = 2 * Math.PI * radius;
            
            circles.forEach(circle => {
                circle.setAttribute('r', radius);
                if (circle.classList.contains('progress-ring-circle')) {
                    circle.style.strokeDasharray = circumference;
                    circle.style.strokeDashoffset = circumference;
                }
            });
        }
        
        // Optimized intersection observer for mobile
        function createOptimizedObserver() {
            const options = {
                threshold: isMobileDevice() ? 0.1 : 0.3, // Lower threshold for mobile
                rootMargin: isMobileDevice() ? '50px' : '100px' // Smaller margin for mobile
            };
            
            return new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        const currentBreakpoint = getCurrentBreakpoint();
                        const settings = responsiveSettings[currentBreakpoint];
                        
                        // Skip animations if reduced motion is preferred
                        if (isReducedMotion()) {
                            entry.target.classList.add('is-visible');
                            const numberElement = entry.target.querySelector('.stats-number');
                            const targetValue = numberElement.getAttribute('data-target-value');
                            const suffix = numberElement.getAttribute('data-suffix') || '';
                            numberElement.textContent = targetValue + suffix;
                            return;
                        }
                        
                        // Animate with mobile-optimized settings
                        setTimeout(() => {
                            entry.target.classList.add('is-visible');
                            animateStatsNumber(entry.target, settings);
                            animateProgressRing(entry.target, settings);
                        }, settings.delay * 100);
                    }
                });
            }, options);
        }
        
        // Mobile-optimized animation functions
        function animateStatsNumber(column, settings) {
            const numberElement = column.querySelector('.stats-number');
            if (!numberElement) return;
            
            const startValue = parseInt(numberElement.getAttribute('data-start-value')) || 0;
            const targetValue = parseInt(numberElement.getAttribute('data-target-value')) || 0;
            const suffix = numberElement.getAttribute('data-suffix') || '';
            
            const duration = settings.duration;
            const startTime = performance.now();
            
            function updateNumber(currentTime) {
                const elapsed = currentTime - startTime;
                const progress = Math.min(elapsed / duration, 1);
                
                // Use easing function for smooth animation
                const easedProgress = easeOutCubic(progress);
                const currentValue = Math.round(startValue + (targetValue - startValue) * easedProgress);
                
                numberElement.textContent = currentValue + suffix;
                
                if (progress < 1) {
                    requestAnimationFrame(updateNumber);
                }
            }
            
            requestAnimationFrame(updateNumber);
        }
        
        function animateProgressRing(column, settings) {
            const circle = column.querySelector('.progress-ring-circle');
            const statsCircle = column.querySelector('.stats-circle');
            if (!circle || !statsCircle) return;
            
            const percentage = parseInt(statsCircle.getAttribute('data-percentage')) || 0;
            const radius = parseFloat(circle.getAttribute('r')) || 84;
            const circumference = 2 * Math.PI * radius;
            const offset = circumference - (percentage / 100) * circumference;
            
            // Apply mobile-optimized transition
            circle.style.transition = `stroke-dashoffset ${settings.duration}ms ${settings.easing}`;
            circle.style.strokeDashoffset = offset;
        }
        
        function easeOutCubic(t) {
            return 1 - Math.pow(1 - t, 3);
        }
        
        // Initialize responsive stats section
        function initializeStatsSection() {
            // Initial setup
            handleResponsiveChanges();
            
            // Create intersection observer
            const observer = createOptimizedObserver();
            const columns = statsSection.querySelectorAll('.stats-column');
            columns.forEach(column => observer.observe(column));
            
            // Handle window resize with debouncing
            let resizeTimer;
            window.addEventListener('resize', () => {
                clearTimeout(resizeTimer);
                resizeTimer = setTimeout(() => {
                    handleResponsiveChanges();
                }, 250);
            }, { passive: true });
            
            // Handle orientation change for mobile
            window.addEventListener('orientationchange', () => {
                setTimeout(() => {
                    handleResponsiveChanges();
                }, 300);
            });
        }
        
        // Start the magic
        initializeStatsSection();
    });
    </script>
</div>