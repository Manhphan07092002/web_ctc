        /* CSS được tinh chỉnh để mượt mà hơn */
        .stats-banner {
            padding: 80px 0;
            background-color: #f8f9fa;
            background-image: linear-gradient(135deg, #f0f2f5 0%, #e9ecef 100%);
            position: relative;
            overflow: hidden; /* Ẩn các phần tử trượt ra ngoài */
            font-family: 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            color: #343a40;
        }

        .stats-banner::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><defs><pattern id="grain" width="100" height="100" patternUnits="userSpaceOnUse"><circle cx="25" cy="25" r="1" fill="%23e0e0e0" opacity="0.2"/><circle cx="75" cy="75" r="1" fill="%23e0e0e0" opacity="0.2"/></pattern></defs><rect width="100" height="100" fill="url(%23grain)"/></svg>');
            pointer-events: none;
            opacity: 0.7;
        }

        /* --- Trạng thái ban đầu (ẩn) cho hiệu ứng xuất hiện --- */
        .stats-column {
            padding: 15px;
            opacity: 0; /* Ẩn đi lúc đầu */
            transform: translateY(30px); /* Dịch chuyển xuống dưới một chút */
            transition: opacity 0.6s cubic-bezier(0.25, 0.8, 0.25, 1), transform 0.6s cubic-bezier(0.25, 0.8, 0.25, 1);
            will-change: opacity, transform; /* GPU acceleration */
        }
        
        /* --- Hiệu ứng trễ cho từng cột để xuất hiện tuần tự (Stagger Effect) --- */
        .stats-column:nth-child(2) { transition-delay: 0.1s; }
        .stats-column:nth-child(3) { transition-delay: 0.2s; }
        .stats-column:nth-child(4) { transition-delay: 0.3s; }

        /* --- Trạng thái khi hiển thị (được kích hoạt bởi JS) --- */
        .stats-column.is-visible {
            opacity: 1;
            transform: translateY(0);
        }

        .stats-circle {
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            width: 180px;
            height: 180px;
            border-radius: 50%;
            background-color: #ffffff;
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.08);
            transition: transform 0.4s cubic-bezier(0.25, 0.8, 0.25, 1), box-shadow 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
            will-change: transform; /* GPU acceleration */
            transform: translateZ(0); /* Force GPU layer */
        }

        .progress-ring {
            width: 100%;
            height: 100%;
            transform: rotate(-90deg);
            position: absolute;
            top: 0;
            left: 0;
        }

        .progress-ring-circle-bg {
            fill: none;
            stroke: #e0e0e0;
            stroke-width: 8;
            opacity: 0.6;
        }

        .progress-ring-circle {
            fill: none;
            stroke-width: 8;
            stroke-linecap: round;
            stroke: url(#blueGradient);
            transition: stroke-dashoffset 2.5s cubic-bezier(0.34, 1.56, 0.64, 1); /* Easing mượt hơn */
            filter: drop-shadow(0 0 10px rgba(38, 119, 241, 0.4));
            will-change: stroke-dashoffset; /* GPU acceleration */
        }

        .gradient-defs {
            position: absolute; width: 0; height: 0; overflow: hidden;
        }

        .stats-number-container {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            display: flex;
            align-items: center;
            justify-content: center;
            width: 100%;
            height: 100%;
            z-index: 2;
        }

        .stats-number {
            font-size: 38px;
            font-weight: 700;
            color: #2677f1;
            line-height: 1;
            text-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
            transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
            text-align: center;
            display: flex;
            align-items: center;
            justify-content: center;
        }

.stats-title {
