<script>
    $(document).ready(function(){
        // Smooth scrolling for scroll-to-section buttons
        $('.scroll-to-section').on('click', function(event) {
            event.preventDefault();
            
            // Find the next section after hero
            var heroSection = $('.hero-video-section');
            var nextSection = heroSection.next('section, .section, div[class*="section"], main, .content');
            
            if (nextSection.length === 0) {
                // Try to find any content section below hero
                nextSection = heroSection.nextAll().filter('section, .section, div[class*="section"], main, .content').first();
            }
            
            if (nextSection.length > 0) {
                $('html, body').stop().animate({
                    scrollTop: nextSection.offset().top - 80
                }, 1200);
            } else {
                // Fallback: scroll down by viewport height
                $('html, body').stop().animate({
                    scrollTop: $(window).scrollTop() + $(window).height() - 100
                }, 1200);
            }
        });
        
        // Regular anchor links
        $('a[href^="#"]:not(.scroll-to-section)').on('click', function(event) {
            var target = $(this.getAttribute('href'));
            if( target.length ) {
                event.preventDefault();
                $('html, body').stop().animate({
                    scrollTop: target.offset().top - 80
                }, 1000);
            }
        });

        // Enhanced video optimization for mobile and responsive devices
        var video = $('.hero-video')[0];
        var isMobile = /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent);
        var isLowPowerMode = false;
        var videoLoaded = false;
        
        if (video) {
            // Mobile-specific optimizations
            video.muted = true;
            video.playsInline = true;
            video.loop = true;
            // Optimize preload: metadata for mobile, none for very slow connections
            if (isMobile) {
                video.preload = 'metadata';
            } else {
                // Check connection speed
                if (navigator.connection) {
                    var connection = navigator.connection || navigator.mozConnection || navigator.webkitConnection;
                    if (connection.effectiveType === 'slow-2g' || connection.effectiveType === '2g' || connection.saveData) {
                        video.preload = 'none';
                    } else {
                        video.preload = 'metadata';
                    }
                } else {
                    video.preload = 'metadata';
                }
            }
            
            // Detect low power mode or slow connection
            if (navigator.connection) {
                var connection = navigator.connection || navigator.mozConnection || navigator.webkitConnection;
                if (connection.effectiveType === 'slow-2g' || connection.effectiveType === '2g') {
                    isLowPowerMode = true;
                    video.preload = 'none';
                }
            }
            
            // Responsive video quality adjustment
            function adjustVideoQuality() {
                var screenWidth = window.innerWidth;
                var screenHeight = window.innerHeight;
                
                // For very small screens or low power, consider pausing video
                if (screenWidth < 480 || isLowPowerMode) {
                    if (video.readyState >= 2) {
                        video.pause();
                        $('.hero-overlay').css({
                            'background': 'linear-gradient(135deg, #2677f1 0%, #1565c0 50%, #0d47a1 100%)',
                            'opacity': '0.95'
                        });
                    }
                    return;
                }
                
                // Resume video for larger screens
                if (video.paused && !isLowPowerMode) {
                    video.play().catch(function(error) {
                        console.log('Resume play prevented:', error);
                    });
                }
            }
            
            // Initial quality adjustment
            adjustVideoQuality();
            
            // Adjust on resize with debounce
            var resizeTimeout;
            $(window).on('resize orientationchange', function() {
                clearTimeout(resizeTimeout);
                resizeTimeout = setTimeout(adjustVideoQuality, 250);
            });
            
            // Enhanced mobile video loading
            video.addEventListener('canplay', function() {
                if (!isLowPowerMode && window.innerWidth >= 480) {
                    video.play().catch(function(error) {
                        // Auto-play prevented - fallback to static background
                        $('.hero-video').hide();
                        $('.hero-overlay').css({
                            'background': 'linear-gradient(135deg, #2677f1 0%, #1565c0 50%, #0d47a1 100%)'
                        });
                    });
                }
            });
            
            // Handle video loading with mobile considerations
            video.addEventListener('loadeddata', function() {
                if (!isMobile || window.innerWidth >= 768) {
                    video.play().catch(function(error) {
                        // Play prevented - silent fail
                    });
                }
            });
            
            // Enhanced error handling
            video.addEventListener('error', function(e) {
                // Video loading error - graceful fallback with animated gradient
                $('.hero-video').fadeOut(500);
                $('.hero-overlay').css({
                    'background': 'linear-gradient(135deg, #2677f1 0%, #1565c0 50%, #0d47a1 100%)',
                    'animation': 'overlayPulse 8s ease-in-out infinite'
                });
            });

            // Optimized loop handling
            video.addEventListener('ended', function() {
                if (!isLowPowerMode) {
                    video.currentTime = 0;
                    video.play();
                }
            });

            // Reduced frequency checking for mobile
            var checkInterval = isMobile ? 10000 : 5000; // 10s for mobile, 5s for desktop
            setInterval(function() {
                if (video.paused && !video.ended && !isLowPowerMode && window.innerWidth >= 480) {
                    video.play().catch(function(error) {
                        // Restart prevented - silent fail
                    });
                }
            }, checkInterval);

            // Smooth loop transition
            video.addEventListener('timeupdate', function() {
                if (video.currentTime >= video.duration - 0.2) {
                    video.currentTime = 0;
                }
            });
            
            // Battery level consideration (if available)
            if (navigator.getBattery) {
                navigator.getBattery().then(function(battery) {
                    if (battery.level < 0.2) { // Less than 20% battery
                        isLowPowerMode = true;
                        video.pause();
                        $('.hero-overlay').css({
                            'background': 'linear-gradient(135deg, #2677f1 0%, #1565c0 50%, #0d47a1 100%)'
                        });
                    }
                });
            }
            
            // Intersection Observer for performance - Lazy load video
            if ('IntersectionObserver' in window) {
                var videoObserver = new IntersectionObserver(function(entries) {
                    entries.forEach(function(entry) {
                        if (entry.isIntersecting && !isLowPowerMode) {
                            // Lazy load video source when it enters viewport
                            if (!videoLoaded && video.readyState === 0) {
                                video.load();
                                videoLoaded = true;
                            }
                            
                            // Play video when visible
                            if (video.readyState >= 2) {
                                video.play().catch(function(error) {
                                    // Intersection play prevented - silent fail
                                });
                            }
                        } else {
                            // Pause video when not visible to save resources
                            if (!video.paused) {
                                video.pause();
                            }
                        }
                    });
                }, { 
                    threshold: 0.1, // Start loading when 10% visible
                    rootMargin: '50px' // Start loading 50px before entering viewport
                });
                
                videoObserver.observe(video);
            } else {
                // Fallback: load video immediately if IntersectionObserver not supported
                video.load();
                videoLoaded = true;
            }
        }

        // Intersection Observer for animations
        if ('IntersectionObserver' in window) {
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.style.animationPlayState = 'running';
                    }
                });
            });

            // Observe animated elements
            $('.hero-content, .company-badge, .hero-title, .hero-subtitle, .hero-cta').each(function() {
                observer.observe(this);
            });
        }

        // Keep video playing continuously - remove pause on blur
        // Video should never pause for continuous playback
        $(window).on('focus', function() {
            if (video && video.paused) {
                video.play().catch(function(error) {
                    // Focus play prevented - silent fail
                });
            }
        });

        // Ensure video keeps playing when page becomes visible
        document.addEventListener('visibilitychange', function() {
            if (!document.hidden && video && video.paused) {
                video.play().catch(function(error) {
                    // Visibility play prevented - silent fail
                });
            }
        });

        // Scroll indicator click handler
        $('.scroll-indicator').on('click', function() {
            var heroSection = $('.hero-video-section');
            var nextSection = heroSection.next('section, .section, div[class*="section"], main, .content');
            
            if (nextSection.length === 0) {
                nextSection = heroSection.nextAll().filter('section, .section, div[class*="section"], main, .content').first();
            }
            
            if (nextSection.length > 0) {
                $('html, body').animate({
                    scrollTop: nextSection.offset().top - 80
                }, 1200);
            } else {
                // Fallback: scroll down by viewport height
                $('html, body').animate({
                    scrollTop: $(window).scrollTop() + $(window).height() - 100
                }, 1200);
            }
        });
    });
</script>