@{
    Layout = null;
}

<style>
    /* === WHY CHOOSE US MODERN DESIGN === */
    
    :root {
        --primary-orange: #f59e0b;
        --dark-orange: #d97706;
        --primary-blue: #1e40af;
        --light-blue: #3b82f6;
        --text-dark: #1f2937;
        --text-light: #6b7280;
        --white: #ffffff;
        --shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .why-choose-section {
        padding: 80px 20px;
        background: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.4));
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        background-attachment: fixed;
        position: relative;
        min-height: 500px;
    }
    
    .why-choose-section::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-image: url('@Url.Content("~/Image/tai-sao.jpg")');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        background-attachment: fixed;
        z-index: -1;
        opacity: 0;
        transition: opacity 0.5s ease;
    }
    
    .why-choose-section.bg-loaded::before {
        opacity: 1;
    }

    .container {
        max-width: 100%;
        margin: 0 auto;
    }

    .section-header {
        text-align: center;
        margin-bottom: 50px;
        animation: fadeIn 0.8s ease;
    }

    .why-choose-section .section-title {
        font-size: 32px;
        font-weight: 700;
        color: rgb(255, 255, 255);
        margin-bottom: 16px;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .section-description {
        font-size: 16px;
        color: white;
        line-height: 1.6;
        max-width: 800px;
        margin: 0 auto;
        font-weight: 500;
    }

    .features-grid {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr;
        grid-template-rows: 1fr 1fr;
        gap: 2px;
        height: 900px;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: var(--shadow);
    }

    .feature-block {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 50px 40px;
        transition: transform 0.3s ease;
    }

    .feature-block:hover {
        transform: scale(1.02);
        z-index: 10;
    }

    /* Top Left - Large Image Block */
    .block-1 {
        grid-row: 1 / 3;
        background: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.4)), url('https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?ixlib=rb-4.0.3&auto=format&fit=crop&w=2000&q=80');
        background-size: cover;
        background-position: center;
        color: white;
        text-align: center;
    }

    /* Top Right - Team Block */
    .block-2 {
        background: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.3)), url('@Url.Content("~/Image/service/block3.jpg")');
        background-size: cover;
        background-position: center;
        color: white;
        text-align: center;
        flex-direction: column;
    }

    /* Bottom Left - Blue Block */
    .block-3 {
        background: linear-gradient(135deg, #1e40af, #3b82f6);
        color: white;
        text-align: center;
        flex-direction: column;
    }

    /* Bottom Middle - Technology Block */
    .block-4 {
        background: linear-gradient(rgba(30,64,175,0.9), rgba(59,130,246,0.9)), url('https://images.unsplash.com/photo-1518709268805-4e9042af2176?ixlib=rb-4.0.3&auto=format&fit=crop&w=1000&q=80');
        background-size: cover;
        background-position: center;
        color: white;
        text-align: center;
    }

    /* Bottom Right - New Image Block */
    .block-5 {
        background: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.3)), url('@Url.Content("~/Image/service/block4.jpg")');
        background-size: cover;
        background-position: center;
        color: white;
        text-align: center;
        flex-direction: column;
    }

    .feature-icon {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        background: rgba(255,255,255,0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 16px;
        backdrop-filter: blur(10px);
    }

    .block-2 .feature-icon {
        background: rgba(255,255,255,0.2);
        backdrop-filter: blur(10px);
    }

    .feature-icon i {
        font-size: 24px;
        color: white;
    }

    .feature-title {
        font-size: 18px;
        font-weight: 700;
        margin-bottom: 12px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .block-1 .feature-title {
        font-size: 24px;
        margin-bottom: 16px;
    }

    .feature-description {
        font-size: 15px;
        line-height: 1.6;
        opacity: 0.9;
    }

    .block-1 .feature-description {
        font-size: 16px;
    }

    @@media (max-width: 768px) {
        .why-choose-section {
            padding: 60px 15px;
        }
        
        .features-grid {
            grid-template-columns: 1fr;
            grid-template-rows: repeat(5, 250px);
            height: auto;
        }
        
        .block-1 {
            grid-row: 1;
        }
        
        .feature-block {
            padding: 30px 20px;
        }
        
        .section-title {
            font-size: 28px;
        }
        
        .feature-title {
            font-size: 16px;
        }
        
        .feature-description {
            font-size: 13px;
        }
    }
</style>

<div class="why-choose-section">
    <div class="container">
        <div class="section-header">
            <h2 class="section-title">TẠI SAO CHỌN CHÚNG TÔI?</h2>
            <p class="section-description">
                Công ty Cổ phần Xây lắp Bưu điện Miền Trung – Đối tác tin cậy với bề dày kinh nghiệm, đội ngũ chuyên gia giàu chuyên môn, được đào tạo bài bản và 
                đã thực hiện nhiều dự án lớn cho doanh nghiệp trong và ngoài nước. Chúng tôi cam kết mang đến giải pháp tối ưu, đáp ứng 
                mọi nhu cầu của khách hàng một cách chuyên nghiệp và hiệu quả.
            </p>
        </div>

        <div class="features-grid">
            <div class="feature-block block-1">
                <div>
                    <div class="feature-icon">
                        <i class="fas fa-users"></i>
                    </div>
                    <h3 class="feature-title">ĐỘI NGŨ NHÂN SỰ GIỎI</h3>
                    <p class="feature-description">
                        Công ty Cổ phần Xây lắp Bưu điện Miền Trung tự hào có đội ngũ nhân sự giàu kinh nghiệm và tài năng, cung cấp các giải pháp tùy 
                        chỉnh tiên tiến và phù hợp với nhu cầu của khách hàng; đồng thời, đem lại sự thành công và hiệu quả 
                        cho mọi dự án.
                    </p>
                </div>
            </div>

            <div class="feature-block block-2">
                <div>
                    <div class="feature-icon">
                        <i class="fas fa-award"></i>
                    </div>
                    <h3 class="feature-title">CHẤT LƯỢNG VÀ DỊCH VỤ</h3>
                    <p class="feature-description">
                        Sản phẩm và dịch vụ do Công ty Cổ phần Xây lắp Bưu điện Miền Trung cung cấp được kiểm tra nghiêm ngặt theo tiêu chuẩn quốc tế. 
                        Đi kèm theo đó là dịch vụ hỗ trợ tư vấn, kỹ thuật và bảo hành toàn diện cho các dự án.
                    </p>
                </div>
            </div>

            <div class="feature-block block-3">
                <div>
                    <div class="feature-icon">
                        <i class="fas fa-cogs"></i>
                    </div>
                    <h3 class="feature-title">CÔNG NGHỆ HIỆN ĐẠI</h3>
                    <p class="feature-description">
                        Ứng dụng công nghệ tiên tiến trong thiết kế, thi công và quản lý dự án. Sử dụng máy móc, thiết bị hiện đại để đảm bảo tiến độ và chất lượng công trình.
                    </p>
                </div>
            </div>

            <div class="feature-block block-4">
                <div>
                    <div class="feature-icon">
                        <i class="fas fa-handshake"></i>
                    </div>
                    <h3 class="feature-title">ĐỐI TÁC CHIẾN LƯỢC</h3>
                    <p class="feature-description">
                        Công ty Cổ phần Xây lắp Bưu điện Miền Trung là đối tác chiến lược của nhiều thương hiệu hàng đầu trong và ngoài nước, 
                        cung cấp giải pháp đa dạng đáp ứng nhu cầu khách hàng.
                    </p>
                </div>
            </div>

            <div class="feature-block block-5">
                <div>
                    <div class="feature-icon">
                        <i class="fas fa-chart-line"></i>
                    </div>
                    <h3 class="feature-title">PHÁT TRIỂN BỀN VỮNG</h3>
                    <p class="feature-description">
                        Cam kết phát triển bền vững, tăng trưởng ổn định và tạo giá trị lâu dài cho khách hàng và đối tác.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
(function() {
    'use strict';
    
    // Lazy load background image for why-choose-section
    var section = document.querySelector('.why-choose-section');
    if (section && 'IntersectionObserver' in window) {
        var bgObserver = new IntersectionObserver(function(entries) {
            entries.forEach(function(entry) {
                if (entry.isIntersecting) {
                    // Preload the background image
                    var img = new Image();
                    img.onload = function() {
                        section.classList.add('bg-loaded');
                    };
                    img.src = '@Url.Content("~/Image/tai-sao.jpg")';
                    bgObserver.unobserve(section);
                }
            });
        }, { rootMargin: '100px' });
        
        bgObserver.observe(section);
    } else if (section) {
        // Fallback: load immediately
        var img = new Image();
        img.onload = function() {
            section.classList.add('bg-loaded');
        };
        img.src = '@Url.Content("~/Image/tai-sao.jpg")';
    }
})();
</script>