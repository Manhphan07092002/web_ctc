@* 3. JavaScript (jQuery) để xử lý ẩn/hiện VÀ tự động ẩn khi cuộn qua - Optimized *@
<script defer>
    // Wait for jQuery to be available
    (function() {
        function initGioiThieu() {
            if (typeof jQuery === 'undefined') {
                setTimeout(initGioiThieu, 50);
                return;
            }
            
            $(document).ready(function() {
        var $imageTrigger = $('#imageTriggerGioiThieu');
        var $contentDiv = $('#contentGioiThieu');
        var $window = $(window); // Lưu trữ đối tượng window để tối ưu
        var isContentVisible = false; // Cờ theo dõi trạng thái hiển thị

        // Hàm để ẩn nội dung
        function hideContent() {
            if (isContentVisible) {
                $contentDiv.slideUp(function() {
                    isContentVisible = false;
                    // Gỡ bỏ trình nghe sự kiện cuộn khi nội dung đã ẩn
                    $window.off('scroll.gioithieu');
                });
            }
        }

        // Hàm để kiểm tra vị trí cuộn và ẩn nếu cần
        function checkScrollAndHide() {
            // Chỉ kiểm tra nếu nội dung đang hiển thị
            if (isContentVisible) {
                var contentBottom = $contentDiv.offset().top + $contentDiv.outerHeight();
                var windowTop = $window.scrollTop();
                var windowHeight = $window.height();

                // Điều kiện: Nếu đáy của nội dung đã cuộn lên trên đỉnh của cửa sổ
                // (Tức là người dùng đã cuộn hoàn toàn qua nó)
                if (contentBottom < windowTop) {
                    hideContent();
                }
                // (TÙY CHỌN) Điều kiện khác: Nếu đỉnh của nội dung cuộn lên trên đáy cửa sổ
                // (Tức là người dùng đã bắt đầu cuộn qua nó, nhưng nó vẫn còn trong view)
                // Bạn có thể chọn 1 trong 2 hoặc kết hợp. Điều kiện trên phổ biến hơn.
                // if ($contentDiv.offset().top < windowTop + windowHeight - someOffset) { ... }
            }
        }

        // Hàm để hiện nội dung và gắn trình nghe sự kiện cuộn
        function showContent() {
            if (!isContentVisible) {
                $contentDiv.slideDown(function() {
                    isContentVisible = true;
                    // Gắn trình nghe sự kiện cuộn (sử dụng namespace .gioithieu)
                    $window.on('scroll.gioithieu', checkScrollAndHide);
                    // Kiểm tra ngay lần đầu, phòng trường hợp nó đã bị cuộn qua
                    checkScrollAndHide();
                });
            }
        }

        // Kiểm tra sự tồn tại của các phần tử
        if ($imageTrigger.length && $contentDiv.length) {
            // Gán sự kiện click cho hình ảnh
            $imageTrigger.on('click', function() {
                if (!isContentVisible) {
                    showContent();
                } else {
                    hideContent(); // Cho phép người dùng nhấp để đóng lại
                }
            });
        }
            });
        }
        
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initGioiThieu);
        } else {
            initGioiThieu();
        }
    })();
</script>