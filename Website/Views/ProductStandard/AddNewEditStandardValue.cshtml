
@{
    Layout = null;
    var psv = ViewData["obj"] as Cubetech.Website.Models.ProductStandardValue;
}
     <!-- Bootstrap Colorpicker -->
<link href="@Url.Content("~/Content/")plugins/gentelella-master/vendors/mjolnic-bootstrap-colorpicker/dist/css/bootstrap-colorpicker.min.css" rel="stylesheet">




<div class="modal" id="ModalProductStandardValue" role="dialog" data-easein="bounceIn">
    <div class="modal-dialog modal-md">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-hidden="true"><i class="glyphicon glyphicon-remove"></i></button>
                <h4 class="modal-title">@ViewData["Title"] </h4>
            </div>
            <form id="ProductStandardValueForm" >
                <input type="hidden" name="mode" value="@ViewData["Mode"]" />
                <input type="hidden" name="ID" id="ID" value="@psv.ID"/>
                <input type="hidden" name="ProductStandardID" id="ProductStandardID" value="@psv.ProductStandardID" />
                <div class="modal-body">
                    <div class="form-group" id="divname">
                        <label for="Name">Mã Tiêu Chuẩn</label>
                        <input type="text" class="form-control" id="Name" name="Name" placeholder="Mã Tiêu Chuẩn" tabindex="1" autofocus value="@psv.Name">
                    </div>
                    <div class="form-group">
                        
                     
                            <label>Màu</label>
                        <div class="input-group my-colorpicker2">
                            <input type="text" value="@psv.Prefix" class="form-control" name="Prefix" id="Prefix" placeholder="Màu" />
                            <span class="input-group-addon"><i></i></span>
                        </div>
                 
                    </div>
                    <div class="form-group" id="divDisplayName">
                        <label>Tên Hiển Thị</label>
                        <input name="DisplayName" id="DisplayName" type="text" class="form-control" placeholder="Tên Hiển Thị" value="@psv.DisplayName">
                    </div>
                    
                    <div class="form-group">
                       

                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-dark" data-dismiss="modal" aria-hidden="true">
                        <span class="glyphicon glyphicon-remove" aria-hidden="true"></span> Hủy
                    </button>
                    <button id="save" type="button" onclick="saveStandardValue()" class="btn btn-danger"><span class="glyphicon glyphicon-ok" aria-hidden="true"></span> Lưu</button>
                </div>
            </form>
        </div>
    </div>
</div>
<script src="~/Scripts/common.js"></script>

       <!-- Bootstrap Colorpicker -->
<script src="@Url.Content("~/Content/")plugins/gentelella-master/vendors/mjolnic-bootstrap-colorpicker/dist/js/bootstrap-colorpicker.min.js"></script>
<script>
    $(document).ready(function () {
        $(".my-colorpicker2").colorpicker();
    });
</script>