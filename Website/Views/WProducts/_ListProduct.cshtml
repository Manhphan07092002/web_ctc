@* Liên kết Font Awesome (bắt buộc để hiển thị icon) *@
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" />

@{
    //====================================================================================
    // KHỐI CODE C# RAZOR - ĐÃ ĐƯỢC TỐI GIẢN ĐỂ BỎ PHÂN TRANG
    //====================================================================================
    // LƯU Ý QUAN TRỌNG:
    // Biến `lstProducts` này phải chứa TẤT CẢ sản phẩm được tải từ Controller.
    // Bạn cần phải chỉnh sửa Controller để không còn phân trang nữa.
    var lstProducts = ViewData["LstProducts"] as List<Cubetech.Website.Models.Product>;

    // Các phần khác giữ nguyên
    var lstCriteo = lstProducts != null ? lstProducts.Take(3) : new List<Cubetech.Website.Models.Product>();
    string lstIDs = string.Join(",", lstCriteo.Select(x => "'" + x.ID + "'").ToList());
    var totalProduct = int.Parse(ViewData["TotalProducts"].ToString());
    Cubetech.Website.DAO.CategoryDAO catedao = new Cubetech.Website.DAO.CategoryDAO();
    var lstCate = catedao.GetAll();
}

<div class="product-page-v2">
    <div class="row">
        @* =============================================================== *@
        @* KHỐI DANH MỤC SẢN PHẨM (BÊN TRÁI) - GIỮ NGUYÊN *@
        @* =============================================================== *@
        <div class="col-lg-3 category-sidebar-v2">
            <div class="category-header-v2">
                <h2>
                    <i class="fas fa-stream"></i>
                    Danh mục
                </h2>
            </div>
            <div class="category-body-v2">
                @if (lstCate != null && lstCate.Any())
                {
                    <a href="?" class="category-link-v2 all-items">
                        <i class="fas fa-th-large"></i>
                        <span>Tất cả sản phẩm</span>
                    </a>
                    foreach (var category in lstCate)
                    {
                        if (category.ParentID == 9)
                        {
                            // NƠI TÙY CHỈNH ICON CHO TỪNG DANH MỤC
                            string iconClass = "fa-tags";
                            if (category.ID == 10) { iconClass = "fa-building"; }
                            if (category.Name.ToLower().Contains("dự án")) { iconClass = "fa-city"; }
                            if (category.Name.ToLower().Contains("nội thất")) { iconClass = "fa-couch"; }
                            if (category.Name.ToLower().Contains("công nghệ")) { iconClass = "fa-laptop-code"; }

                            <a href="?categoryId=@category.ID" class="category-link-v2">
                                <i class="fas @iconClass"></i>
                                <span>@category.Name</span>
                            </a>
                        }
                    }
                }
            </div>
            
            @* =============================================================== *@
            @* KHỐI TÌM KIẾM VÀ LỌC SẢN PHẨM *@
            @* =============================================================== *@
            <div class="filter-section-v2">
                <div class="filter-header-v2">
                    <h3>
                        <i class="fas fa-search"></i>
                        Tìm kiếm & Lọc
                    </h3>
                </div>
                <div class="filter-body-v2">
                    @* Tìm kiếm theo tên *@
                    <div class="search-box-v2">
                        <label for="product-search">Tìm sản phẩm:</label>
                        <div class="search-input-wrapper">
                            <input type="text" id="product-search" placeholder="Nhập tên sản phẩm..." class="form-control">
                            <i class="fas fa-search search-icon"></i>
                        </div>
                    </div>
                    
                    @* Lọc theo giá *@
                    <div class="price-filter-v2">
                        <label>Khoảng giá:</label>
                        <div class="price-range-container">
                            <div class="price-inputs">
                                <input type="number" id="min-price" placeholder="Từ" class="form-control price-input">
                                <span class="price-separator">-</span>
                                <input type="number" id="max-price" placeholder="Đến" class="form-control price-input">
                            </div>
                            <div class="price-range-slider">
                                <input type="range" id="price-range-min" min="0" max="50000000" value="0" class="range-slider">
                                <input type="range" id="price-range-max" min="0" max="50000000" value="50000000" class="range-slider">
                            </div>
                            <div class="price-labels">
                                <span>0đ</span>
                                <span>50,000,000đ</span>
                            </div>
                        </div>
                    </div>
                    
                    @* Nút reset filter *@
                    <div class="filter-actions">
                        <button type="button" id="reset-filters" class="btn btn-outline-secondary btn-sm">
                            <i class="fas fa-undo"></i> Xóa bộ lọc
                        </button>
                    </div>
                </div>
            </div>
        </div>

        @* =============================================================== *@
        @* KHỐI HIỂN THỊ SẢN PHẨM (BÊN PHẢI) - GIỮ NGUYÊN *@
        @* =============================================================== *@
        <div class="col-lg-9 product-list-container-v2">
            @* =============================================================== *@
            @* KHỐI VIEW MODE TOGGLE - ĐẦU TRANG *@
            @* =============================================================== *@
            <div class="view-controls-container-v2">
                <div class="view-mode-header">
                    <h4>Hiển thị sản phẩm</h4>
                </div>
                <div class="view-mode-toggle-v2">
                    <button type="button" id="grid-view-btn" class="view-btn active" title="Dạng ô">
                        <i class="fas fa-th-large"></i>
                        <span>Dạng ô</span>
                    </button>
                    <button type="button" id="list-view-btn" class="view-btn" title="Dạng danh sách">
                        <i class="fas fa-list"></i>
                        <span>Dạng danh sách</span>
                    </button>
                </div>
            </div>
            
            <div class="row product-grid-row-v2">
                @if (lstProducts != null && lstProducts.Count > 0)
                {
                    foreach (var product in lstProducts)
                    {
                        // LOGIC TÍNH TOÁN - GIỮ NGUYÊN
                        string imgProduct = string.IsNullOrEmpty(product.Image1)
                            ? Url.Content("~/Content/Image/noimage.png")
                            : Url.Content(product.Image1);
                        
                        // Thử sử dụng version resize, nếu không có thì dùng ảnh gốc
                        string resizedImg = Cubetech.Website.Controllers.FilePickerController.GetFileNameAndSize(imgProduct, 800);
                        
                        // Kiểm tra xem file resize có tồn tại không bằng cách thêm onerror fallback
                        imgProduct = resizedImg;
                        decimal salePercent = 0;
                        if (product.PriceSale > 0 && product.PriceSale2 > 0 && product.PriceSale != 0)
                        {
                            salePercent = Math.Round(100 - (product.PriceSale2 / product.PriceSale * 100), 0);
                        }
                        var productUrl = Url.Content("/" + Cubetech.Website.Controllers.WProductsController.GetProductUrl(product));
                        if (productUrl == "/")
                        {
                            productUrl = "/Wproducts/Detail?id=" + product.ID;
                        }
                        string priceDisplay;
                        if (product.PriceSale2 > 0) {
                            priceDisplay = string.Format("{0:N0} đ", product.PriceSale2);
                            if (product.PriceSale > product.PriceSale2) {
                                priceDisplay += string.Format(" <del>{0:N0} đ</del>", product.PriceSale);
                            } else if (product.Price > product.PriceSale2) {
                                priceDisplay += string.Format(" <del>{0:N0} đ</del>", product.Price);
                            }
                        } else if (product.PriceSale > 0) {
                            priceDisplay = string.Format("{0:N0} đ", product.PriceSale);
                            if (product.Price > product.PriceSale) {
                                priceDisplay += string.Format(" <del>{0:N0} đ</del>", product.Price);
                            }
                        } else if (product.Price > 0) {
                            priceDisplay = string.Format("{0:N0} đ", product.Price);
                        } else {
                            priceDisplay = "Liên hệ";
                        }

                        // CẤU TRÚC HTML SẢN PHẨM V2 - GIỮ NGUYÊN
                        <div class="col-sm-6 col-md-4 product-item" data-cate-id="@product.CategoryID">
                            <div class="product-card-v2">
                                <div class="product-image-wrapper-v2">
                                    <img class="product-image-v2" src="@imgProduct" alt="@product.Name" loading="lazy" 
                                         onerror="handleImageError(this, '@Url.Content(product.Image1 ?? "~/Content/Image/noimage.png")', '@Url.Content("~/Content/Image/noimage.png")')">
                                     @if (salePercent > 0)
                                    {
                                        <span class="sale-badge-v2">-@salePercent%</span>
                                    }
                                    <div class="action-overlay-v2">
                                        <a href="@productUrl" class="btn-view-detail">Xem Chi Tiết</a>
                                    </div>
                                </div>
                                <div class="product-card-body-v2">
                                    <h3 class="product-name-v2"><a href="@productUrl">@product.Name</a></h3>
                                    <div class="product-price-v2 @(product.CategoryID == 10 ? "project" : "")">
                                        @Html.Raw(priceDisplay)
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
            
            
            @* =============================================================== *@
            @* KHỐI PHÂN TRANG HIỆN ĐẠI *@
            @* =============================================================== *@
            <div class="pagination-container-v2">
                <div class="pagination-header-v2">
                    <div class="pagination-info-v2">
                        <div class="info-icon">
                            <i class="fas fa-info-circle"></i>
                        </div>
                        <div class="info-content">
                            <span class="info-label">Kết quả tìm kiếm</span>
                            <span id="pagination-info" class="info-details">
                                Hiển thị <strong id="current-range">1-12</strong> của <strong id="total-products">0</strong> sản phẩm
                            </span>
                        </div>
                    </div>
                    
                    <div class="items-per-page-v2">
                        <div class="items-label">
                            <i class="fas fa-th-list"></i>
                            <span>Hiển thị</span>
                        </div>
                        <div class="items-selector">
                            <select id="items-per-page" class="form-control-modern">
                                <option value="12">12</option>
                                <option value="24">24</option>
                                <option value="36">36</option>
                                <option value="48">48</option>
                            </select>
                            <span class="items-suffix">sản phẩm</span>
                        </div>
                    </div>
                </div>
                
                <div class="pagination-navigation-v2">
                    <nav aria-label="Product pagination">
                        <ul class="pagination pagination-v2" id="pagination-nav">
                            <!-- Pagination sẽ được tạo bằng JavaScript -->
                        </ul>
                    </nav>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* MODERN UI VARIABLES */
    :root {
        --primary-color: #007bff;
        --primary-dark: #0056b3;
        --primary-light: #66b3ff;
        --accent-color: #e67e22;
        --accent-light: #f39c12;
        --white-color: #ffffff;
        --light-bg: #f8f9fa;
        --lighter-bg: #fafbfc;
        --border-color: #e9ecef;
        --border-light: #f1f3f4;
        --text-dark: #2c3e50;
        --text-light: #6c757d;
        --text-muted: #95a5a6;
        --success-color: #28a745;
        --warning-color: #ffc107;
        --danger-color: #dc3545;
        --card-shadow: 0 4px 20px rgba(0,0,0,0.08);
        --card-shadow-hover: 0 8px 30px rgba(0,0,0,0.12);
        --card-shadow-active: 0 2px 10px rgba(0,0,0,0.15);
        --gradient-primary: linear-gradient(135deg, var(--primary-color), var(--primary-light));
        --gradient-accent: linear-gradient(135deg, var(--accent-color), var(--accent-light));
        --border-radius: 12px;
        --border-radius-sm: 8px;
        --border-radius-lg: 16px;
        --transition-fast: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        --transition-smooth: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        --transition-slow: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .product-page-v2 a,
    .product-page-v2 a:hover { text-decoration: none !important; }
    .product-page-v2 { font-family: var(--font-family); background-color: var(--background-light); }
    .product-grid-row-v2 { display: flex; flex-wrap: wrap; }
    /* MODERN CATEGORY SIDEBAR */
    .category-sidebar-v2 { 
        background: var(--white-color); 
        border-radius: var(--border-radius); 
        box-shadow: var(--card-shadow); 
        padding: 0; 
        overflow: hidden; 
        align-self: flex-start;
        transform: translateY(0);
        transition: var(--transition-smooth);
        animation: slideInLeft 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    }
    
    .category-sidebar-v2:hover {
        box-shadow: var(--card-shadow-hover);
        transform: translateY(-2px);
    }
    
    .category-header-v2 h2 { 
        background: var(--gradient-primary); 
        color: var(--white-color); 
        padding: 20px 25px; 
        font-size: 18px; 
        font-weight: 700; 
        margin: 0; 
        text-transform: uppercase; 
        letter-spacing: 1px;
        position: relative;
        overflow: hidden;
    }
    
    .category-header-v2 h2::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
        transition: left 0.5s;
    }
    
    .category-header-v2:hover h2::before {
        left: 100%;
    }
    
    .category-header-v2 h2 i { 
        margin-right: 12px; 
        font-size: 16px;
        animation: pulse 2s infinite;
    }
    
    .category-body-v2 { 
        padding: 8px 0; 
    }
    
    .category-link-v2 { 
        display: flex; 
        align-items: center; 
        padding: 16px 25px; 
        color: var(--text-dark); 
        font-size: 15px; 
        font-weight: 500; 
        transition: var(--transition-smooth); 
        border-left: 4px solid transparent;
        position: relative;
        overflow: hidden;
    }
    
    .category-link-v2::before {
        content: '';
        position: absolute;
        left: 0;
        top: 0;
        width: 0;
        height: 100%;
        background: linear-gradient(90deg, rgba(0,123,255,0.1), rgba(0,123,255,0.05));
        transition: width 0.3s ease;
        z-index: 0;
    }
    .category-link-v2 i { 
        color: var(--primary-color); 
        width: 30px; 
        text-align: center; 
        margin-right: 10px; 
        font-size: 18px; 
        transition: var(--transition-smooth);
        position: relative;
        z-index: 1;
    }
    
    .category-link-v2:hover { 
        color: var(--primary-dark); 
        border-left-color: var(--primary-color);
        transform: translateX(5px);
    }
    
    .category-link-v2:hover::before {
        width: 100%;
    }
    
    .category-link-v2:hover i { 
        transform: scale(1.15) rotate(5deg); 
        color: var(--primary-color);
    }
    
    .category-link-v2.active { 
        color: var(--primary-dark); 
        border-left-color: var(--primary-color);
        font-weight: 600;
        background: linear-gradient(90deg, rgba(0,123,255,0.1), transparent);
    }
    
    .category-link-v2.active::before {
        width: 100%;
    }
    
    .category-link-v2.all-items { font-weight: 700; }
    
    /* MODERN PRODUCT CARDS */
    .product-item { 
        padding: 0 15px; 
        margin-bottom: 30px; 
        display: flex;
        animation: fadeInUp 0.6s ease-out;
        animation-fill-mode: both;
    }
    
    .product-item:nth-child(1) { animation-delay: 0.1s; }
    .product-item:nth-child(2) { animation-delay: 0.2s; }
    .product-item:nth-child(3) { animation-delay: 0.3s; }
    .product-item:nth-child(4) { animation-delay: 0.4s; }
    
    .product-card-v2 { 
        width: 100%; 
        background: var(--white-color); 
        border-radius: var(--border-radius); 
        box-shadow: var(--card-shadow); 
        transition: var(--transition-smooth); 
        overflow: hidden;
        position: relative;
        border: 1px solid var(--border-light);
    }
    
    .product-card-v2::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: linear-gradient(135deg, rgba(0,123,255,0.05), rgba(0,123,255,0.02));
        opacity: 0;
        transition: opacity 0.3s ease;
        z-index: 1;
        pointer-events: none;
    }
    
    .product-card-v2:hover { 
        transform: translateY(-10px) scale(1.02); 
        box-shadow: var(--card-shadow-hover);
        border-color: var(--primary-color);
    }
    
    .product-card-v2:hover::before {
        opacity: 1;
    }
    
    .product-image-wrapper-v2 { 
        position: relative; 
        overflow: hidden;
        border-radius: var(--border-radius-sm) var(--border-radius-sm) 0 0;
    }
    
    .product-image-v2 { 
        width: 100%; 
        height: 250px; 
        object-fit: cover; 
        display: block; 
        transition: var(--transition-slow);
        filter: brightness(1) saturate(1);
    }
    .product-card-v2:hover .product-image-v2 { 
        transform: scale(1.1); 
        filter: brightness(1.1) saturate(1.2);
    }
    
    .product-image-wrapper-v2::after {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: linear-gradient(45deg, transparent 30%, rgba(255,255,255,0.1) 50%, transparent 70%);
        transform: translateX(-100%);
        transition: transform 0.6s ease;
    }
    
    .product-card-v2:hover .product-image-wrapper-v2::after {
        transform: translateX(100%);
    }
    
    .action-overlay-v2 { 
        position: absolute; 
        top: 0; 
        left: 0; 
        right: 0; 
        bottom: 0; 
        background: rgba(0,0,0,0.3); 
        display: flex; 
        justify-content: center; 
        align-items: center; 
        opacity: 0; 
        transition: var(--transition-smooth);
    }
    
    .product-card-v2:hover .action-overlay-v2 { 
        opacity: 1; 
    }
    
    .btn-view-detail { 
        background: linear-gradient(135deg, var(--accent-color), var(--accent-light)); 
        color: var(--white-color); 
        padding: 14px 28px; 
        border-radius: 25px; 
        font-weight: 600; 
        font-size: 14px;
        transform: translateY(20px) scale(0.9); 
        transition: var(--transition-smooth);
        border: 2px solid transparent;
        box-shadow: 0 4px 15px rgba(230, 126, 34, 0.3);
        position: relative;
        z-index: 2;
        overflow: hidden;
    }
    
    .btn-view-detail::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
        transition: left 0.5s;
    }
    
    .product-card-v2:hover .btn-view-detail { 
        transform: translateY(0) scale(1); 
        background: linear-gradient(135deg, var(--accent-light), var(--accent-color));
        box-shadow: 0 6px 20px rgba(230, 126, 34, 0.4);
    }
    
    .btn-view-detail:hover::before {
        left: 100%;
    }
    
    .sale-badge-v2 { 
        position: absolute; 
        top: 15px; 
        left: 15px; 
        background: linear-gradient(135deg, var(--danger-color), #c82333); 
        color: var(--white-color); 
        padding: 6px 12px; 
        font-size: 12px; 
        font-weight: 700; 
        border-radius: var(--border-radius-sm); 
        z-index: 3;
        animation: pulse 2s infinite;
        box-shadow: 0 2px 8px rgba(220, 53, 69, 0.3);
    }
    
    .product-card-body-v2 { 
        padding: 24px 20px; 
        text-align: left;
        position: relative;
        z-index: 2;
    }
    
    .product-name-v2 { 
        font-size: 17px; 
        font-weight: 600; 
        color: var(--text-dark); 
        line-height: 1.4; 
        margin: 0 0 15px 0; 
        height: calc(17px * 1.4 * 2); 
        overflow: hidden; 
        display: -webkit-box; 
        -webkit-line-clamp: 2; 
        -webkit-box-orient: vertical;
        transition: var(--transition-fast);
    }
    
    .product-name-v2 a { 
        color: inherit; 
        transition: var(--transition-fast);
    }
    
    .product-name-v2 a:hover { 
        color: var(--primary-color);
        text-shadow: 0 1px 3px rgba(0,123,255,0.2);
    }
    .product-price-v2 { 
        font-size: 20px; 
        font-weight: 700; 
        color: var(--accent-color);
        margin-bottom: 8px;
        position: relative;
        display: inline-block;
        transition: var(--transition-fast);
    }
    
    .product-price-v2::after {
        content: '';
        position: absolute;
        bottom: -2px;
        left: 0;
        width: 0;
        height: 2px;
        background: linear-gradient(90deg, var(--accent-color), var(--accent-light));
        transition: width 0.3s ease;
    }
    
    .product-card-v2:hover .product-price-v2::after {
        width: 100%;
    }
    
    .product-price-v2.project { 
        color: var(--primary-dark);
        background: linear-gradient(135deg, rgba(0,123,255,0.1), rgba(0,123,255,0.05));
        padding: 4px 8px;
        border-radius: var(--border-radius-sm);
    }
    
    .product-price-v2 del { 
        font-size: 14px; 
        font-weight: 400; 
        color: var(--text-muted); 
        margin-left: 10px;
        text-decoration-color: var(--danger-color);
    }
    @@media (max-width: 1199.98px) { .product-name-v2 { font-size: 16px; } .product-price-v2 { font-size: 20px; } }
    @@media (max-width: 991.98px) { .category-sidebar-v2 { margin-bottom: 30px; } .product-item { width: 50%; } }
    @@media (max-width: 767.98px) { .product-image-v2 { height: 200px; } .btn-view-detail { padding: 10px 20px; font-size: 14px; } .product-item { width: 100%; padding: 0 10px; } .product-grid-row-v2 { gap: 20px 0; } }
    @@media (max-width: 575.98px) { .category-link-v2 { font-size: 15px; padding: 10px 20px; } .category-header-v2 h2 { font-size: 18px; padding: 14px 20px; } .product-name-v2 { font-size: 15px; } .product-price-v2 { font-size: 18px; } }
    
    /* =============================================================== */
    /* KEYFRAME ANIMATIONS */
    /* =============================================================== */
    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    
    @@keyframes slideInLeft {
        from {
            opacity: 0;
            transform: translateX(-30px);
        }
        to {
            opacity: 1;
            transform: translateX(0);
        }
    }
    
    @@keyframes pulse {
        0%, 100% {
            transform: scale(1);
        }
