<script>
    // GIỮ NGUYÊN TOÀN BỘ PHẦN SCRIPT
    // Logic filter của JS này sẽ hoạt động tốt với danh sách sản phẩm đầy đủ.
    $(document).ready(function () {
        const paramsV2 = new URLSearchParams(window.location.search);
        const categoryIdV2 = paramsV2.get('categoryId');
        // Xử lý filter category
        function applyCategory() {
            if (categoryIdV2) {
                const catIdNumber = parseInt(categoryIdV2);
                $('.product-item').each((index, ele) => {
                    const productCateId = parseInt($(ele).data('cate-id'));
                    if (productCateId === catIdNumber) {
                        $(ele).show();
                    } else {
                        $(ele).hide();
                    }
                });
                $('.category-link-v2').each((index, ele) => {
                    const linkCateId = parseInt(new URL(ele.href).searchParams.get('categoryId'));
                    if (linkCateId === catIdNumber) {
                        $(ele).addClass('active');
                    }
                });
                $('html, body').animate({
                    scrollTop: $('.product-page-v2').offset().top - 30
                }, 300);
                if ($('.product-item:visible').length === 0) {
                    $('.product-grid-row-v2').append(`
                        <div class="col-12 text-center mt-4 text-muted">
                            <p><i class="fas fa-box-open fa-2x"></i><br>Không tìm thấy sản phẩm phù hợp.</p>
                        </div>
                    `);
                }
            } else {
                $('.product-item').show();
                $('.category-link-v2.all-items').addClass('active');
            }
        }
        
        applyCategory();
        const fullUrlV2 = window.location.href;
        const hasSanPhamV2 = fullUrlV2.split('/').some(part => part.includes('san-pham'));
        if (!hasSanPhamV2) {
            $('.category-sidebar-v2').hide();
            $('.product-list-container-v2').addClass('col-lg-12').removeClass('col-lg-9');
        }
        
        // ===============================================================
        // LOGIC PHÂN TRANG
        // ===============================================================
        // Đợi một chút để đảm bảo DOM đã sẵn sàng
        setTimeout(function() {
            initializePagination();
        }, 100);
    });
    
    // Biến toàn cục cho phân trang
    let currentPage = 1;
    let itemsPerPage = 12;
    let totalItems = 0;
    let filteredProducts = [];
    
    function initializePagination() {
        console.log('Initializing pagination...');
        
        // Lấy tất cả sản phẩm hiện tại (có thể đã được filter theo category)
        updateFilteredProducts();
        
        // Thiết lập event listeners
        $('#items-per-page').on('change', function() {
            itemsPerPage = parseInt($(this).val());
            currentPage = 1;
            console.log(`Items per page changed to: ${itemsPerPage}`);
            updatePagination();
        });
        
        // Khởi tạo phân trang lần đầu
        updatePagination();
        console.log('Pagination initialized');
    }
    
    function updateFilteredProducts() {
        // Lấy tất cả sản phẩm từ DOM
        const allProducts = $('.product-item').toArray();
        
        // Lấy các filter hiện tại
        const params = new URLSearchParams(window.location.search);
        const categoryId = params.get('categoryId');
        const searchTerm = $('#product-search').val().toLowerCase().trim();
        const minPrice = parseFloat($('#min-price').val()) || 0;
        const maxPrice = parseFloat($('#max-price').val()) || Infinity;
        
        // Áp dụng tất cả filter
        filteredProducts = allProducts.filter(item => {
            const $item = $(item);
            
            // Filter theo category
            if (categoryId) {
                const productCateId = parseInt($item.data('cate-id'));
                if (productCateId !== parseInt(categoryId)) {
                    return false;
                }
            }
            
            // Filter theo tên sản phẩm
            if (searchTerm) {
                const productName = $item.find('.product-name-v2 a').text().toLowerCase();
                if (!productName.includes(searchTerm)) {
                    return false;
                }
            }
            
            // Filter theo giá
            const priceText = $item.find('.product-price-v2').text().replace(/[^\d]/g, '');
            const productPrice = parseFloat(priceText) || 0;
            if (productPrice < minPrice || productPrice > maxPrice) {
                return false;
            }
            
            return true;
        });
        
        totalItems = filteredProducts.length;
        console.log(`Found ${totalItems} products after filtering:`, {
            category: categoryId || 'all',
            search: searchTerm || 'none',
            priceRange: `${minPrice} - ${maxPrice === Infinity ? 'max' : maxPrice}`
        });
    }
    
    function updatePagination() {
        updateFilteredProducts();
        
        if (totalItems === 0) {
            $('.pagination-container-v2').hide();
            return;
        }
        
        $('.pagination-container-v2').show();
        
        const totalPages = Math.ceil(totalItems / itemsPerPage);
        
        // Cập nhật thông tin hiển thị
        const startItem = (currentPage - 1) * itemsPerPage + 1;
        const endItem = Math.min(currentPage * itemsPerPage, totalItems);
        
        $('#current-range').text(`${startItem}-${endItem}`);
        $('#total-products').text(totalItems);
        
        // Hiển thị sản phẩm cho trang hiện tại
        showProductsForCurrentPage();
        
        // Tạo các nút phân trang
        generatePaginationButtons(totalPages);
    }
    
    function showProductsForCurrentPage() {
        console.log(`Current page: ${currentPage}, Items per page: ${itemsPerPage}`);
        console.log(`Total filtered products: ${filteredProducts.length}`);
        
        // Ẩn tất cả sản phẩm trước
        $('.product-item').hide();
        
        // Tính toán index
        const startIndex = (currentPage - 1) * itemsPerPage;
        const endIndex = startIndex + itemsPerPage;
        
        console.log(`Showing items from index ${startIndex} to ${endIndex - 1}`);
        
        // Hiển thị sản phẩm cho trang hiện tại
        let shownCount = 0;
        for (let i = startIndex; i < endIndex && i < filteredProducts.length; i++) {
            $(filteredProducts[i]).show();
            shownCount++;
            console.log(`Showing product ${i + 1}: ${$(filteredProducts[i]).find('.product-name-v2 a').text()}`);
        }
        
        console.log(`Actually shown ${shownCount} products`);
        
        // Nếu không có sản phẩm nào được hiển thị
        if (shownCount === 0 && filteredProducts.length > 0) {
            console.error('No products shown but filtered products exist!');
            // Fallback: hiển thị trang đầu
            currentPage = 1;
            showProductsForCurrentPage();
        }
    }
    
    function generatePaginationButtons(totalPages) {
        const paginationControls = $('#pagination-controls');
        paginationControls.empty();
        
        if (totalPages <= 1) {
            return;
        }
        
        // Nút Previous
        const prevDisabled = currentPage === 1 ? 'disabled' : '';
        paginationControls.append(`
            <li class="page-item ${prevDisabled}">
                <a class="page-link" href="#" data-page="${currentPage - 1}">
                    <i class="fas fa-chevron-left"></i>
                </a>
            </li>
        `);
        
        // Logic hiển thị số trang
        let startPage = Math.max(1, currentPage - 2);
        let endPage = Math.min(totalPages, currentPage + 2);
        
        // Đảm bảo luôn hiển thị 5 trang nếu có thể
        if (endPage - startPage < 4) {
            if (startPage === 1) {
                endPage = Math.min(totalPages, startPage + 4);
            } else {
                startPage = Math.max(1, endPage - 4);
            }
        }
        
        // Trang đầu và dấu ...
        if (startPage > 1) {
            paginationControls.append(`
                <li class="page-item">
                    <a class="page-link" href="#" data-page="1">1</a>
                </li>
            `);
            if (startPage > 2) {
                paginationControls.append(`
                    <li class="page-item disabled">
                        <span class="page-link">...</span>
                    </li>
                `);
            }
        }
        
        // Các trang ở giữa
        for (let i = startPage; i <= endPage; i++) {
            const activeClass = i === currentPage ? 'active' : '';
            paginationControls.append(`
                <li class="page-item ${activeClass}">
                    <a class="page-link" href="#" data-page="${i}">${i}</a>
                </li>
            `);
        }
        
        // Dấu ... và trang cuối
        if (endPage < totalPages) {
            if (endPage < totalPages - 1) {
                paginationControls.append(`
                    <li class="page-item disabled">
                        <span class="page-link">...</span>
                    </li>
                `);
            }
            paginationControls.append(`
                <li class="page-item">
                    <a class="page-link" href="#" data-page="${totalPages}">${totalPages}</a>
                </li>
            `);
        }
        
        // Nút Next
        const nextDisabled = currentPage === totalPages ? 'disabled' : '';
        paginationControls.append(`
            <li class="page-item ${nextDisabled}">
                <a class="page-link" href="#" data-page="${currentPage + 1}">
                    <i class="fas fa-chevron-right"></i>
                </a>
            </li>
        `);
        
        // Gắn sự kiện click cho các nút phân trang
        paginationControls.find('a.page-link').on('click', function(e) {
            e.preventDefault();
            const page = parseInt($(this).data('page'));
            if (page && page !== currentPage && !$(this).parent().hasClass('disabled')) {
                currentPage = page;
                updatePagination();
                
                // Cuộn lên đầu danh sách sản phẩm
                $('html, body').animate({
                    scrollTop: $('.product-list-container-v2').offset().top - 100
                }, 300);
            }
        });
    }
    
    // Cập nhật phân trang khi filter category thay đổi
    $(document).on('click', '.category-link-v2', function(e) {
        e.preventDefault();
        console.log('Category filter clicked, updating pagination...');
        
        const href = $(this).attr('href');
        const url = new URL(href, window.location.origin);
        const newCategoryId = url.searchParams.get('categoryId');
        
        // Cập nhật URL mà không reload trang
        window.history.pushState({}, '', href);
        
        // Update active category
        $('.category-link-v2').removeClass('active');
        $(this).addClass('active');
        
        // Reset pagination về trang 1 và update
        currentPage = 1;
        updatePagination();
    });
    
    // ===============================================================
    // EVENT LISTENERS CHO SEARCH VÀ FILTER
    // ===============================================================
    
    // Tìm kiếm sản phẩm theo tên
    $('#product-search').on('input', function() {
        console.log('Search input changed:', $(this).val());
        currentPage = 1; // Reset về trang 1
        updatePagination();
    });
    
    // Lọc theo giá - input number
    $('#min-price, #max-price').on('input', function() {
        const minPrice = parseFloat($('#min-price').val()) || 0;
        const maxPrice = parseFloat($('#max-price').val()) || 50000000;
        
        // Cập nhật range slider
        $('#price-range-min').val(minPrice);
        $('#price-range-max').val(maxPrice);
        
        console.log('Price filter changed:', minPrice, '-', maxPrice);
        currentPage = 1; // Reset về trang 1
        updatePagination();
    });
    
    // Lọc theo giá - range slider
    $('#price-range-min, #price-range-max').on('input', function() {
        const minPrice = parseInt($('#price-range-min').val());
        const maxPrice = parseInt($('#price-range-max').val());
        
        // Đảm bảo min <= max
        if (minPrice > maxPrice) {
            if ($(this).attr('id') === 'price-range-min') {
                $('#price-range-max').val(minPrice);
            } else {
                $('#price-range-min').val(maxPrice);
            }
        }
        
        // Cập nhật input number
        $('#min-price').val($('#price-range-min').val());
        $('#max-price').val($('#price-range-max').val());
        
        console.log('Price range changed:', $('#price-range-min').val(), '-', $('#price-range-max').val());
        currentPage = 1; // Reset về trang 1
        updatePagination();
    });
    
    // Reset tất cả filter
    $('#reset-filters').on('click', function() {
        console.log('Resetting all filters...');
        
        // Reset search
        $('#product-search').val('');
        
        // Reset price filter
        $('#min-price').val('');
        $('#max-price').val('');
        $('#price-range-min').val(0);
        $('#price-range-max').val(50000000);
        
        // Reset category (về tất cả sản phẩm)
        $('.category-link-v2').removeClass('active');
        $('.category-link-v2[href="?"]').addClass('active');
        window.history.pushState({}, '', '?');
        
        // Reset pagination
        currentPage = 1;
        updatePagination();
    });
    
    // Thêm event listener để test phân trang
    window.testPagination = function() {
        console.log('Testing pagination...');
        console.log('Current page:', currentPage);
        console.log('Items per page:', itemsPerPage);
        console.log('Total items:', totalItems);
        console.log('Filtered products:', filteredProducts.length);
        updatePagination();
    };
    
    // ===============================================================
    // EVENT LISTENERS CHO VIEW MODE TOGGLE
    // ===============================================================
    
    // Chuyển đổi giữa grid view và list view
    $('#grid-view-btn').on('click', function() {
        if (!$(this).hasClass('active')) {
            $('.view-btn').removeClass('active');
            $(this).addClass('active');
            $('.product-grid-row-v2').removeClass('list-view');
            console.log('Switched to grid view');
            
            // Lưu preference vào localStorage
            localStorage.setItem('productViewMode', 'grid');
        }
    });
    
    $('#list-view-btn').on('click', function() {
        if (!$(this).hasClass('active')) {
            $('.view-btn').removeClass('active');
            $(this).addClass('active');
            $('.product-grid-row-v2').addClass('list-view');
            console.log('Switched to list view');
            
            // Lưu preference vào localStorage
            localStorage.setItem('productViewMode', 'list');
        }
    });
    
    // Khôi phục view mode từ localStorage
    function restoreViewMode() {
        const savedViewMode = localStorage.getItem('productViewMode') || 'grid';
        
        if (savedViewMode === 'list') {
            $('.view-btn').removeClass('active');
            $('#list-view-btn').addClass('active');
            $('.product-grid-row-v2').addClass('list-view');
        } else {
            $('.view-btn').removeClass('active');
            $('#grid-view-btn').addClass('active');
            $('.product-grid-row-v2').removeClass('list-view');
        }
        
        console.log('Restored view mode:', savedViewMode);
    }
    
    // Khởi tạo phân trang khi trang load
    $(document).ready(function() {
        initializePagination();
        
        // Khởi tạo giá trị mặc định cho price range
        $('#price-range-min').val(0);
        $('#price-range-max').val(50000000);
        
        // Khôi phục view mode
        restoreViewMode();
    });
    
    // Hàm xử lý lỗi hình ảnh với fallback nhiều cấp
    window.handleImageError = function(img, originalSrc, noImageSrc) {
        if (img.src !== originalSrc && img.src !== noImageSrc) {
            // Lần đầu lỗi: thử ảnh gốc
            img.src = originalSrc;
        } else if (img.src === originalSrc) {
            // Ảnh gốc cũng lỗi: dùng noimage
            img.src = noImageSrc;
        }
        // Nếu noimage cũng lỗi thì không làm gì nữa
    };
</script>