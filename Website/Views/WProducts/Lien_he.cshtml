@{
    ViewBag.Title = "Liên hệ - CÔNG TY CỔ PHẦN XÂY LẮP BƯU ĐIỆN MIỀN TRUNG";
    ViewBag.Description = "Kết nối cùng CTC: tư vấn, báo giá, hỗ trợ dự án & kỹ thuật. Hotline kinh doanh, kỹ thuật, email và địa chỉ đầy đủ.";
    ViewBag.Robots = "index,follow";
}

<style type="text/css">
/* ================================
   MODERN CONTACT PAGE 2025 - CTC
   Clean minimalist design
   ================================ */

@@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');

:root {
    /* Modern 2025 Color Palette */
    --primary-color: #1a1a1a;
    --secondary-color: #4a5568;
    --accent-color: #2563eb;
    --success-color: #10b981;
    --warning-color: #f59e0b;
    --danger-color: #ef4444;
    
    /* Neutral Colors */
    --white: #ffffff;
    --gray-50: #f9fafb;
    --gray-100: #f3f4f6;
    --gray-200: #e5e7eb;
    --gray-300: #d1d5db;
    --gray-400: #9ca3af;
    --gray-500: #6b7280;
    --gray-600: #4b5563;
    --gray-700: #374151;
    --gray-800: #1f2937;
    --gray-900: #111827;
    
    /* Typography */
    --text-primary: var(--primary-color);
    --text-secondary: var(--secondary-color);
    --text-muted: var(--gray-500);
    --text-light: var(--gray-400);
    
    /* Spacing & Sizing */
    --container-max: 1200px;
    --radius-sm: 6px;
    --radius-md: 12px;
    --radius-lg: 16px;
    --radius-xl: 24px;
    --radius-2xl: 32px;
    
    /* Shadows */
    --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
    --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
    --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
    --shadow-xl: 0 20px 25px -5px rgb(0 0 0 / 0.1), 0 8px 10px -6px rgb(0 0 0 / 0.1);
    
    /* Animations */
    --transition-fast: all 0.15s ease;
    --transition-smooth: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    --transition-bounce: all 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55);
    
    /* Fonts */
    --font-primary: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

/* PAGE WRAPPER */
.contact-page {
    min-height: 100vh;
    background: var(--white);
    font-family: var(--font-primary);
    color: var(--text-primary);
    line-height: 1.6;
    padding: 0;
}

/* CONTAINER */
.contact-container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 1rem;
}

/* ================================
   HERO SECTION
   ================================ */
.hero-section {
    padding: 5rem 0 4rem;
    text-align: center;
    border-bottom: 1px solid var(--gray-100);
}

.hero-title {
    font-size: clamp(3rem, 6vw, 4.5rem);
    font-weight: 900;
    line-height: 1.1;
    margin-bottom: 1.5rem;
    color: var(--text-primary);
    letter-spacing: -0.02em;
    animation: fadeInUp 1s ease-out;
}

.hero-subtitle {
    font-size: clamp(1.25rem, 2.5vw, 1.5rem);
    line-height: 1.6;
    color: var(--text-secondary);
    max-width: 700px;
    margin: 0 auto;
    font-weight: 400;
    animation: fadeInUp 1s ease-out 0.3s both;
}

/* ================================
   MAIN CONTENT
   ================================ */
.main-content {
    padding: 4rem 0;
}

.content-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    margin-bottom: 4rem;
}

.contact-section {
    display: flex;
    flex-direction: column;
    gap: 2rem;
}

/* ================================
   RESPONSIVE DESIGN
   ================================ */

/* Large Desktop (1200px+) */
@@media (min-width: 1200px) {
    .contact-container {
        max-width: 1400px;
    }
    
    .hero-title {
        font-size: 4.5rem;
    }
    
    .hero-subtitle {
        font-size: 1.5rem;
    }
}

/* Desktop (992px - 1199px) */
@@media (max-width: 1199px) {
    .contact-container {
        padding: 0 2rem;
    }
    
    .hero-title {
        font-size: 3.5rem;
    }
    
    .content-grid {
        gap: 3rem;
    }
}

/* Tablet (768px - 991px) */
@@media (max-width: 991px) {
    .content-grid {
        grid-template-columns: 1fr;
        gap: 2.5rem;
    }
    
    .hero-title {
        font-size: 3rem;
    }
    
    .hero-subtitle {
        font-size: 1.25rem;
    }
    
    .contact-form {
        padding: 2rem;
    }
    
    .form-content-wrapper {
        padding: 1.5rem;
    }
    
    .form-grid {
        grid-template-columns: 1fr;
        gap: 1rem;
    }
    
    .description-features {
        flex-direction: column;
        gap: 1rem;
        align-items: center;
    }
    
    .action-buttons {
        flex-direction: column;
        gap: 1rem;
    }
    
    .btn {
        width: 100%;
        justify-content: center;
    }
}

/* Mobile Large (576px - 767px) */
@@media (max-width: 767px) {
    .contact-container {
        padding: 0 1rem;
    }
    
    .hero-section {
        padding: 3rem 0;
        text-align: center;
    }
    
    .hero-title {
        font-size: 2.5rem;
        line-height: 1.2;
    }
    
    .hero-subtitle {
        font-size: 1.125rem;
    }
    
    .contact-card {
        padding: 1.5rem;
    }
    
    .card-title {
        font-size: 1.25rem;
    }
    
    .contact-form {
        padding: 1.5rem;
        margin-top: 2rem;
    }
    
    .form-content-wrapper {
        padding: 1rem;
    }
    
    .form-title {
        font-size: 1.75rem;
    }
    
    .form-description {
        font-size: 1.25rem;
        padding: 1rem 1.5rem;
        flex-direction: column;
        gap: 0.5rem;
    }
    
    .feature-item {
        padding: 0.5rem 1rem;
        font-size: 1rem;
    }
    
    .form-input,
    .form-select,
    .form-textarea {
        padding: 1rem;
        font-size: 1rem;
    }
    
    .btn {
        padding: 1rem 1.5rem;
        font-size: 1rem;
        min-width: auto;
    }
    
    .map-wrapper iframe {
        height: 250px;
    }
}

/* Mobile Small (480px - 575px) */
@@media (max-width: 575px) {
    .hero-title {
        font-size: 2rem;
    }
    
    .hero-subtitle {
        font-size: 1rem;
    }
    
    .contact-card {
        padding: 1rem;
    }
    
    .card-title {
        font-size: 1.125rem;
    }
    
    .contact-item {
        padding: 1rem;
        flex-direction: column;
        text-align: center;
        gap: 0.5rem;
    }
    
    .contact-item-label {
        font-size: 0.875rem;
    }
    
    .contact-item-value {
        font-size: 1rem;
    }
    
    .form-title {
        font-size: 1.5rem;
    }
    
    .form-description {
        font-size: 1.125rem;
        padding: 0.75rem 1rem;
    }
    
    .description-features {
        gap: 0.75rem;
    }
    
    .feature-item {
        padding: 0.5rem 0.75rem;
        font-size: 0.9rem;
    }
    
    .form-actions {
        flex-direction: column;
        gap: 0.75rem;
    }
    
    .btn {
        padding: 0.875rem 1.25rem;
        font-size: 0.9rem;
    }
}

/* Mobile Extra Small (320px - 479px) */
@@media (max-width: 479px) {
    .contact-container {
        padding: 0 0.75rem;
    }
    
    .hero-title {
        font-size: 1.75rem;
    }
    
    .hero-subtitle {
        font-size: 0.95rem;
    }
    
    .contact-card {
        padding: 0.75rem;
    }
    
    .card-title {
        font-size: 1rem;
    }
    
    .card-subtitle {
        font-size: 0.8rem;
    }
    
    .card-description {
        font-size: 0.95rem;
    }
    
    .contact-form {
        padding: 1rem;
    }
    
    .form-content-wrapper {
        padding: 0.75rem;
    }
    
    .form-title {
        font-size: 1.25rem;
    }
    
    .form-description {
        font-size: 1rem;
        padding: 0.5rem 0.75rem;
    }
    
    .form-input,
    .form-select,
    .form-textarea {
        padding: 0.75rem;
        font-size: 0.9rem;
    }
    
    .btn {
        padding: 0.75rem 1rem;
        font-size: 0.85rem;
        gap: 0.5rem;
    }
    
    .btn-icon {
        font-size: 1rem;
    }
    
    .map-wrapper iframe {
        height: 200px;
    }
}

/* ================================
   TOUCH & ACCESSIBILITY
   ================================ */

/* Touch-friendly improvements */
@@media (hover: none) and (pointer: coarse) {
    .btn {
        min-height: 44px;
        padding: 1rem 1.5rem;
    }
    
    .contact-item {
        min-height: 44px;
        padding: 1rem;
    }
    
    .form-input,
    .form-select,
    .form-textarea {
        min-height: 44px;
        padding: 1rem;
        font-size: 16px; /* Prevent zoom on iOS */
    }
}

/* High DPI displays */
@@media (-webkit-min-device-pixel-ratio: 2), (min-resolution: 192dpi) {
    .contact-card {
        border-width: 0.5px;
    }
    
    .form-content-wrapper {
        border-width: 1px;
    }
}

/* Landscape orientation on mobile */
@@media (max-width: 767px) and (orientation: landscape) {
    .hero-section {
        padding: 2rem 0;
    }
    
    .hero-title {
        font-size: 2rem;
    }
    
    .contact-form {
        margin-top: 1.5rem;
    }
    
    .form-grid {
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }
    
    .form-field:last-child {
        grid-column: 1 / -1;
    }
}

/* Print styles */
@@media print {
    .contact-page {
        background: white !important;
    }
    
    .hero-section,
    .contact-form,
    .action-buttons {
        display: none !important;
    }
    
    .contact-card {
        border: 1px solid #000 !important;
        box-shadow: none !important;
        page-break-inside: avoid;
    }
    
    .map-wrapper {
        display: none !important;
    }
}

/* Reduced motion preferences */
@@media (prefers-reduced-motion: reduce) {
    * {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
    }
    
    .btn:hover,
    .contact-card:hover,
    .contact-item:hover {
        transform: none !important;
    }
}

/* ================================
   CONTACT SECTIONS
   ================================ */

.section-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 1.5rem;
    letter-spacing: -0.01em;
}

.contact-card {
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-lg);
    padding: 2.5rem;
    transition: var(--transition-smooth);
    box-shadow: var(--shadow-sm);
    animation: fadeInUp 0.8s ease-out;
    flex: 1;
    display: flex;
    flex-direction: column;
}

.contact-card:hover {
    border-color: var(--gray-300);
    box-shadow: var(--shadow-md);
    transform: translateY(-4px) scale(1.02);
}

.card-header {
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--gray-100);
}

.card-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
    letter-spacing: -0.01em;
    animation: slideInLeft 0.6s ease-out 0.2s both;
}

.card-subtitle {
    font-size: 1rem;
    color: var(--text-muted);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    animation: slideInLeft 0.6s ease-out 0.4s both;
}

.card-description {
    font-size: 1.125rem;
    line-height: 1.6;
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
    animation: fadeIn 0.8s ease-out 0.6s both;
}

/* ================================
   CONTACT LIST
   ================================ */
.contact-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex-grow: 1;
}

.contact-item {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.25rem;
    background: var(--gray-50);
    border-radius: var(--radius-md);
    transition: var(--transition-smooth);
    border: 1px solid var(--gray-100);
    animation: slideInRight 0.6s ease-out;
}

.contact-item:nth-child(1) { animation-delay: 0.1s; }
.contact-item:nth-child(2) { animation-delay: 0.2s; }
.contact-item:nth-child(3) { animation-delay: 0.3s; }
.contact-item:nth-child(4) { animation-delay: 0.4s; }

.contact-item:hover {
    background: var(--gray-100);
    border-color: var(--gray-200);
    transform: translateX(8px) scale(1.02);
    box-shadow: var(--shadow-md);
}

.contact-item-content {
    flex: 1;
    min-width: 0;
}

.contact-item-label {
    font-weight: 600;
    color: var(--text-primary);
    font-size: 1rem;
    margin-bottom: 0.25rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
}

.contact-item-value {
    color: var(--text-secondary);
    text-decoration: none;
    font-weight: 500;
    font-size: 1.125rem;
    transition: var(--transition-smooth);
    display: block;
}

.contact-item-value:hover {
    color: var(--accent-color);
    text-decoration: none;
    transform: scale(1.05);
}

/* ================================
   MAP SECTION
   ================================ */
.map-section {
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid var(--gray-100);
}

.map-wrapper {
    background: var(--gray-50);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-lg);
    padding: 1rem;
    overflow: hidden;
    backdrop-filter: blur(10px);
}

.map-wrapper iframe {
    width: 100%;
    height: 250px;
    border: 0;
    border-radius: var(--radius-md);
}

.map-label {
    text-align: center;
    margin-top: 0.75rem;
    font-size: 0.875rem;
    color: var(--text-muted);
    font-style: italic;
}

/* ================================
   ACTION BUTTONS
   ================================ */
.action-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    margin-top: 2rem;
    justify-content: center;
    align-items: center;
}

.btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 1.25rem 2.5rem;
    border-radius: var(--radius-lg);
    font-weight: 600;
    font-size: 1.125rem;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: var(--transition-smooth);
    letter-spacing: 0.025em;
    text-transform: uppercase;
    animation: bounceIn 0.8s ease-out;
    position: relative;
    overflow: hidden;
    min-width: 180px;
    box-shadow: var(--shadow-lg);
}

.btn-icon {
    font-size: 1.25rem;
    transition: var(--transition-smooth);
    animation: iconFloat 2s ease-in-out infinite;
}

.btn::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
    transition: left 0.5s;
}

.btn:hover::before {
    left: 100%;
}

.btn-primary {
    background: var(--accent-color);
    color: var(--white);
    box-shadow: var(--shadow-sm);
}

.btn-primary:hover {
    background: #1d4ed8;
    box-shadow: var(--shadow-xl);
    transform: translateY(-4px) scale(1.08);
    color: var(--white);
    text-decoration: none;
}

.btn-primary:hover .btn-icon {
    animation: iconBounce 0.6s ease-in-out;
    transform: scale(1.2);
}

.btn-secondary {
    background: var(--white);
    color: var(--text-primary);
    border: 1px solid var(--gray-300);
    box-shadow: var(--shadow-lg);
}

.btn-secondary:hover {
    background: var(--gray-50);
    border-color: var(--gray-400);
    transform: translateY(-4px) scale(1.08);
    color: var(--text-primary);
    text-decoration: none;
    box-shadow: var(--shadow-xl);
}

.btn-secondary:hover .btn-icon {
    animation: iconBounce 0.6s ease-in-out;
    transform: scale(1.2);
}
}

.map-wrapper iframe:hover {
    transform: scale(1.02);
}

.map-label {
    text-align: center;
    margin-top: 1rem;
    font-size: 0.9rem;
    color: var(--text-muted);
    font-style: italic;
}

/* ================================
   CONTACT FORM
   ================================ */
.contact-form {
    background: var(--white);
    border: 3px solid var(--gray-400);
    border-radius: var(--radius-xl);
    padding: 3rem;
    box-shadow: var(--shadow-lg);
    margin-top: 4rem;
    position: relative;
}

.contact-form.full-width {
    width: 100%;
    max-width: none;
}

.contact-form::before {
    content: '';
    position: absolute;
    top: -2px;
    left: -2px;
    right: -2px;
    bottom: -2px;
    background: linear-gradient(45deg, var(--gray-400), var(--gray-500), var(--gray-600), var(--gray-400));
    border-radius: var(--radius-xl);
    z-index: -1;
    animation: borderGlow 3s ease-in-out infinite;
}

.form-content-wrapper {
    border: 2px solid var(--gray-300);
    border-radius: var(--radius-xl);
    padding: 2rem;
    background: var(--white);
    position: relative;
    overflow: hidden;
}

.form-content-wrapper::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.1) 0%, rgba(255,255,255,0.05) 100%);
    pointer-events: none;
}

.form-header {
    text-align: center;
    margin-bottom: 3rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--gray-100);
}

.form-icon-wrapper {
    margin-bottom: 1.5rem;
    animation: bounceIn 1s ease-out;
}

.form-main-icon {
    font-size: 3rem;
    display: inline-block;
    animation: iconFloat 3s ease-in-out infinite;
    background: linear-gradient(135deg, var(--accent-color), #1d4ed8);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.form-title {
    font-size: 2.25rem;
    font-weight: 800;
    color: var(--text-primary);
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
    animation: fadeInUp 1s ease-out 0.2s both;
}

.form-description-wrapper {
    animation: fadeInUp 1s ease-out 0.4s both;
}

.form-description {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--text-primary);
    line-height: 1.4;
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: var(--gray-50);
    border: 2px solid var(--gray-200);
    border-radius: var(--radius-lg);
    padding: 1.5rem 2rem;
    box-shadow: var(--shadow-md);
}

.description-icon {
    font-size: 1.5rem;
    animation: sparkle 2s ease-in-out infinite;
    color: var(--accent-color);
}

.description-features {
    display: flex;
    justify-content: center;
    gap: 2rem;
    flex-wrap: wrap;
    margin-top: 1rem;
}

.feature-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--text-secondary);
    animation: slideInUp 0.8s ease-out;
    background: var(--white);
    padding: 0.75rem 1.25rem;
    border-radius: var(--radius-md);
    border: 1px solid var(--gray-200);
    box-shadow: var(--shadow-sm);
    transition: var(--transition-smooth);
}

.feature-item:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    border-color: var(--accent-color);
}

.feature-item:nth-child(1) { animation-delay: 0.6s; }
.feature-item:nth-child(2) { animation-delay: 0.8s; }
.feature-item:nth-child(3) { animation-delay: 1s; }

.feature-icon {
    font-size: 1.25rem;
    animation: iconPulse 2s ease-in-out infinite;
    color: var(--accent-color);
}

.form-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-bottom: 1.5rem;
}

.form-field {
    position: relative;
    animation: slideInUp 0.6s ease-out;
}

.form-field:nth-child(1) { animation-delay: 0.1s; }
.form-field:nth-child(2) { animation-delay: 0.2s; }
.form-field:nth-child(3) { animation-delay: 0.3s; }
.form-field:nth-child(4) { animation-delay: 0.4s; }

.select-field {
    position: relative;
}

.select-icon {
    position: absolute;
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
    font-size: 1.1rem;
    color: var(--text-muted);
    pointer-events: none;
    z-index: 2;
    animation: iconFloat 2s ease-in-out infinite;
}

.select-field .form-select {
    padding-left: 3rem;
    appearance: none;
