@{
    string emailJsScript = @"
    <script type=""text/javascript"" src=""https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js""></script>
    <script>
        (function(){
            emailjs.init(""BYnxJ0Wja0K4oeHNA"");
        })();

        document.getElementById('contactForm').addEventListener('submit', function(e) {
            e.preventDefault();

            const submitBtn = document.getElementById('submitBtn');
            const submitText = document.getElementById('submitText');
            
            submitBtn.disabled = true;
            submitText.innerText = 'Đang gửi...';

            const formData = {
                ho_ten: this.ho_ten.value,
                email: this.email.value,
                dia_chi: this.dia_chi.value,
                noi_dung: this.noi_dung.value,
                to_email: 'pxmanhctc@gmail.com'
            };

            emailjs.send('service_utptd8j', 'template_etonz8o', formData)
            .then(function(response) {
                console.log('SUCCESS!', response.status, response.text);
                
                submitBtn.disabled = false;
                submitText.innerText = 'Gửi yêu cầu';
                
                document.getElementById('contactForm').reset();
                document.getElementById('successMsg').style.display = 'block';
                
                setTimeout(() => {
                    document.getElementById('successMsg').style.display = 'none';
                }, 5000);
                
            }, function(error) {
                console.log('FAILED...', error);
                alert('Lỗi gửi email: ' + JSON.stringify(error));
                
                submitBtn.disabled = false;
                submitText.innerText = 'Gửi yêu cầu';
            });
        });
    </script>";
}

@Html.Raw(emailJsScript)
