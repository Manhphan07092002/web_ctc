    }
    .service-banner-item:hover {
        box-shadow: 0 6px 15px rgba(0,0,0,0.1);
        transform: translateY(-4px);
    }
    
    /* BẮT ĐẦU CODE ANIMATION ĐÃ CẬP NHẬT */
    @@keyframes continuous-shake {
      0%, 100% { transform: rotate(0deg); }
      25% { transform: rotate(16deg); } /* Tăng độ lắc */
      50% { transform: rotate(5eg); }
      75% { transform: rotate(-16deg); } /* Tăng độ lắc */
    }

    .service-banner-item img {
        width: 40px;
        height: 40px;
        object-fit: contain;
        /* Áp dụng animation lắc lư nhanh và mạnh hơn */
        animation: continuous-shake 1.2s infinite ease-in-out; /* Giảm thời gian để nhanh hơn */
    }
    /* KẾT THÚC CODE ANIMATION */

    .service-banner-text {
        line-height: 1.5;
