    /* ======== CSS CHO PHẦN CHI TIẾT SẢN PHẨM ======== */
    .breadcrumb-product{padding:10px 0;border-bottom:1px solid #eee;margin-bottom:20px;font-size:14px}.breadcrumb-product a{color:#007bff;text-decoration:none}.breadcrumb-product a:hover{text-decoration:underline}.breadcrumb-product .glyphicon{font-size:12px;color:#6c757d;margin:0 5px}.breadcrumb-product .active_cate{color:#333;font-weight:bold}.product-main-section{display:flex;flex-wrap:wrap;gap:30px}.product-image-column{flex:0 0 40%;max-width:40%;position:relative}.product-main-image-container{position:relative}.product-main-image{overflow:hidden;border:1px solid #ddd;border-radius:4px;padding:5px}.product-main-image img{width:100%;object-fit:contain;max-height:400px;display:block;opacity:1;transition:transform .3s ease-in-out,opacity .3s ease-in-out}.product-main-image img:hover{transform:scale(1.05)}.product-main-image img.image-loading{opacity:0}.image-nav-button{position:absolute;top:50%;transform:translateY(-50%);background-color:rgba(0,0,0,.3);color:#fff;border:none;padding:10px;cursor:pointer;font-size:20px;z-index:10;border-radius:3px}.image-nav-button:hover{background-color:rgba(0,0,0,.6)}.btn-prev-image{left:15px}.btn-next-image{right:15px}.product-thumbnails{margin-top:15px;display:flex;flex-wrap:wrap;gap:10px}.product-thumbnails img{width:80px;height:80px;border:2px solid #ddd;border-radius:4px;cursor:pointer;object-fit:cover;transition:transform .3s ease-in-out,border-color .3s ease}.product-thumbnails img:hover,.product-thumbnails img.active-thumbnail{border-color:#007bff;transform:scale(1.1)}.product-info-column{flex:1;min-width:300px}.product-title-detail{font-size:28px;font-weight:bold;color:#333;margin-bottom:15px;line-height:1.3}.product-meta-info{margin-bottom:20px;padding-bottom:15px;border-bottom:1px solid #f0f0f0}.product-price-detail,.product-view-count{font-size:18px;color:#555;margin-bottom:10px}.product-price-detail strong{color:#d9534f;font-size:20px}.product-detail-expandable-content{margin-top:20px}.product-content-detail{font-size:16px;line-height:1.7;color:#444;max-height:150px;overflow:hidden;position:relative;transition:max-height .5s ease-in-out}.product-content-detail p{margin-bottom:15px}.product-content-detail ul,.product-content-detail ol{padding-left:20px;margin-bottom:15px}.product-content-detail img{max-width:100%;height:auto;margin:10px 0}.product-content-detail.js-fade-effect:after{content:"";position:absolute;bottom:0;left:0;right:0;height:50px;background:linear-gradient(to bottom,rgba(255,255,255,0),#fff)}.product-content-detail.expanded{max-height:100000px}.btn-toggle-detail{display:block;margin:15px auto 0;padding:10px 20px;background-color:#007bff;color:#fff;border:none;border-radius:4px;cursor:pointer;font-size:14px;font-weight:bold;transition:background-color .3s ease}.btn-toggle-detail:hover{background-color:#0056b3}

    
    /* ======== CSS CHO BANNER DỊCH VỤ ======== */
    .service-banner-container {
        display: flex;
        justify-content: space-between;
        align-items: stretch;
        flex-wrap: wrap;
        gap: 15px;
        margin-top: 40px;
