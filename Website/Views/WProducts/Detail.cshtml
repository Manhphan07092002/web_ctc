@{
    Cubetech.Website.DAO.WProductsDAO dao = new Cubetech.Website.DAO.WProductsDAO();
    Cubetech.Website.Models.Product pro = ViewData["Product"] as Cubetech.Website.Models.Product;

    ViewBag.Title = pro.Name;
    Layout = "~/Views/Shared/_Layout.cshtml";

    var lstParrentCate = dao.GetListParentCategory(pro.CategoryID);

    string priceDisplay;
    if (pro.PriceSale2 > 0)
    {
        priceDisplay = string.Format("{0:N0} đ", pro.PriceSale2);
        if (pro.PriceSale > 0 && pro.PriceSale > pro.PriceSale2) {
            priceDisplay += string.Format(" <del style='color: #888; font-size: 0.9em;'>{0:N0} đ</del>", pro.PriceSale);
        } else if (pro.Price > 0 && pro.Price > pro.PriceSale2) {
            priceDisplay += string.Format(" <del style='color: #888; font-size: 0.9em;'>{0:N0} đ</del>", pro.Price);
        }
    }
    else if (pro.PriceSale > 0)
    {
        priceDisplay = string.Format("{0:N0} đ", pro.PriceSale);
        if (pro.Price > 0 && pro.Price > pro.PriceSale) {
            priceDisplay += string.Format(" <del style='color: #888; font-size: 0.9em;'>{0:N0} đ</del>", pro.Price);
        }
    }
    else if (pro.Price > 0)
    {
        priceDisplay = string.Format("{0:N0} đ", pro.Price);
    }
    else
    {
        priceDisplay = "Liên hệ";
    }

    Random randomGenerator = new Random();
    int viewCountFromData = randomGenerator.Next(100, 10001);

    var allImagesForThumbs = new List<string>();
    if (!string.IsNullOrEmpty(pro.Image)) { allImagesForThumbs.Add(pro.Image); }
    if (!string.IsNullOrEmpty(pro.Image1)) { allImagesForThumbs.Add(pro.Image1); }
    if (!string.IsNullOrEmpty(pro.Image2)) { allImagesForThumbs.Add(pro.Image2); }
    if (!string.IsNullOrEmpty(pro.Image3)) { allImagesForThumbs.Add(pro.Image3); }
    if (!string.IsNullOrEmpty(pro.Image4)) { allImagesForThumbs.Add(pro.Image4); }
    if (!string.IsNullOrEmpty(pro.Image5)) { allImagesForThumbs.Add(pro.Image5); }
    if (!string.IsNullOrEmpty(pro.Image6)) { allImagesForThumbs.Add(pro.Image6); }

    var distinctThumbnailUrls = allImagesForThumbs.Where(url => !string.IsNullOrEmpty(url)).Distinct().ToList();
}

<style>
    /* Bố cục chính với 2 cột */
