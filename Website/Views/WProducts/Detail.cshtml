<script>
    document.addEventListener('DOMContentLoaded', function () {
        const imageUrls = @Html.Raw(Json.Encode(distinctThumbnailUrls.Select(Url.Content)));
        let currentImageIndex = 0;
        const mainImage = document.querySelector('.product-main-image img');
        const thumbnailElements = document.querySelectorAll('.product-thumbnails img');
        const btnPrev = document.querySelector('.btn-prev-image');
        const btnNext = document.querySelector('.btn-next-image');
        function updateMainImage(index, newAltText) {
            if (!mainImage || index < 0 || index >= imageUrls.length) return;
            const newSrc = imageUrls[index];
            if (mainImage.src !== newSrc) {
                mainImage.classList.add('image-loading');
                setTimeout(() => {
                    mainImage.src = newSrc;
                    mainImage.alt = newAltText || `Ảnh sản phẩm ${index + 1}`;
                    mainImage.classList.remove('image-loading');
                }, 150);
            }
            currentImageIndex = index;
            updateActiveThumbnail();
        }
        function updateActiveThumbnail() {
            thumbnailElements.forEach((thumb, idx) => {
                thumb.classList.toggle('active-thumbnail', idx === currentImageIndex);
            });
        }
        thumbnailElements.forEach(thumb => {
            thumb.addEventListener('click', event => {
                const newIndex = parseInt(event.target.dataset.index);
                updateMainImage(newIndex, event.target.alt);
            });
        });
        if (btnPrev && btnNext) {
            btnPrev.addEventListener('click', () => {
                let newIndex = currentImageIndex - 1;
                if (newIndex < 0) { newIndex = imageUrls.length - 1; }
                updateMainImage(newIndex);
            });
            btnNext.addEventListener('click', () => {
                let newIndex = currentImageIndex + 1;
                if (newIndex >= imageUrls.length) { newIndex = 0; }
                updateMainImage(newIndex);
            });
            if (imageUrls.length > 0) updateActiveThumbnail();
        }
        const detailContent = document.getElementById('productDetailContent');
        const toggleButton = document.getElementById('toggleDetailButton');
        if (detailContent && toggleButton) {
            const initialMaxHeight = 150;
            if (detailContent.scrollHeight > initialMaxHeight) {
                toggleButton.style.display = 'block';
                detailContent.classList.add('js-fade-effect');
            } else {
                toggleButton.style.display = 'none';
                detailContent.style.maxHeight = 'none';
            }
            toggleButton.addEventListener('click', function () {
                detailContent.classList.toggle('expanded');
                const isExpanded = detailContent.classList.contains('expanded');
                this.textContent = isExpanded ? 'Thu gọn' : 'Xem thêm';
                detailContent.classList.toggle('js-fade-effect', !isExpanded);
            });
        }
    });
</script>