<div class="container">
    <div class="service_title">
        <div class="col-sm-12 text-center">
            <h2>Dịch Vụ Của Chúng Tôi</h2>
            <p class="lead">CTC tự hào cung cấp các giải pháp toàn diện, chất lượng cao trong lĩnh vực xây lắp và hạ tầng.</p>
            <hr />
        </div>
    </div>


    <div class="row">
        @for (int i = 0; i < staticServices.Count; i++)
        {
            var item = staticServices[i];
            var imageUrl = !string.IsNullOrEmpty(item.Image) ? Url.Content(item.Image) : Url.Content("~/Content/Image/noimage.png");
            var modalImageUrl = !string.IsNullOrEmpty(item.Image) ? Url.Content(item.Image) : Url.Content("~/Content/Image/noimage.png");
            
            <div class="col-md-3 col-sm-6 service-item">
                <div class="thumbnail text-center">
                    <img src="@imageUrl" alt="@item.Name" class="img-responsive">
                    <div class="caption">
                        <h3>@item.Name</h3>
                        <p>@item.ShortDescription</p>
                        <p class="text-center"> 
                            <a href="#" class="btn btn-primary" role="button" data-toggle="modal" data-target="#serviceModal"
                               data-title="@item.Name"
                               data-image="@modalImageUrl"
                               data-description="@Html.Raw(item.DetailDescription)">
                                Xem chi tiết
                            </a>
                        </p>
                    </div>
                </div>
            </div>

            if ((i + 1) % 4 == 0) 
            {
                <div class="clearfix visible-md-block visible-lg-block"></div>
            }
            if ((i + 1) % 2 == 0)
            {
                <div class="clearfix visible-sm-block"></div>
            }
        }
    </div>
</div>


<div class="modal fade" id="serviceModal" tabindex="-1" role="dialog" aria-labelledby="myModalLabel">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span
                        aria-hidden="true">&times;</span></button>
                <h4 class="modal-title" id="modal-title">Tiêu đề dịch vụ</h4>
            </div>
            <div class="modal-body">
                <img id="modal-image" src="" class="img-responsive" style="width:100%; margin-bottom: 15px;"
                    alt="Hình ảnh dịch vụ">
                <div id="modal-description">
                    <p>Nội dung chi tiết của sẽ được hiển thị ở đây.</p>
                </div>
            </div>
        </div>
    </div>
</div>

@* Script (giữ nguyên) *@
<script>
    $(document).ready(function () {
        $('#serviceModal').on('show.bs.modal', function (event) {
            var button = $(event.relatedTarget);
            var title = button.data('title');
            var imageUrl = button.data('image');
            var description = button.data('description');
            var modal = $(this);
            modal.find('.modal-title').text(title);
            modal.find('#modal-image').attr('src', imageUrl);
            modal.find('#modal-description').html(description);
        });
    });
</script>

