    /* --- CSS MỚI CHO ANIMATION CỦA MODAL --- */

    /* Hiệu ứng cho toàn bộ nội dung modal khi xuất hiện */
    /* Bootstrap 3 dùng class .in khi modal hiển thị, không phải .show */
    .modal.fade .modal-dialog {
        /* Hiệu ứng trượt xuống mặc định của Bootstrap 3 là tốt rồi, 
           nếu muốn thay đổi mạnh hơn có thể cần ghi đè nhiều hơn hoặc dùng JS.
           Ở đây chúng ta sẽ tập trung vào các thành phần con. */
    }

    .modal-content {
        border-radius: 8px; /* Bo góc cho modal content */
        box-shadow: 0 5px 15px rgba(0,0,0,0.25); /* Tăng nhẹ bóng đổ */
        /* Thêm transition nếu muốn các thay đổi khác (như transform) mượt mà */
        transition: transform 0.3s ease-out; 
    }
    
    /* Nếu muốn modal có hiệu ứng "zoom" nhẹ khi xuất hiện, 
       bạn có thể thử (nhưng cẩn thận xung đột với hiệu ứng slide mặc định của Bootstrap):
    .modal.fade .modal-dialog {
        transform: scale(0.95);
        opacity: 0;
        transition: transform 0.3s ease-out, opacity 0.3s ease-out !important;
    }
    .modal.fade.in .modal-dialog {
        transform: scale(1);
        opacity: 1;
    }
    */


    /* Hiệu ứng cho nút X (close) trong header của modal */
    .modal-header .close {
        font-size: 28px; /* Tăng kích thước nút close một chút */
        transition: opacity 0.2s ease-in-out, transform 0.2s ease-in-out;
    }
    .modal-header .close:hover {
        opacity: 0.8;
        transform: scale(1.1) rotate(90deg); /* Xoay nhẹ và phóng to khi hover */
    }

    /* Hiệu ứng cho hình ảnh trong modal body */
    #modal-image {
