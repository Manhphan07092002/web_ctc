<div class="activity-detail-container">
    <a href="/hoat_dong" class="back-button">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
        </svg>
        Quay lại danh sách hoạt động
    </a>

    <div class="activity-header">
        @{
            // Đếm tổng số ảnh có sẵn (bao gồm cả từ images array và imageUrl)
            var displayImages = new List<string>();
            
            // Thêm ảnh từ images array (nếu có)
            if (activity != null && activity.images != null && activity.images.Length > 0)
            {
                foreach (var img in activity.images)
                {
                    if (!string.IsNullOrEmpty(img) && img != "/Image/icon/thong_bao.jpg")
                    {
                        displayImages.Add(img);
                    }
                }
            }
            
            // Thêm ảnh từ imageUrl (nếu có và khác default)
            if (activity != null && !string.IsNullOrEmpty(activity.imageUrl) && 
                activity.imageUrl != "/Image/icon/thong_bao.jpg" && 
                !displayImages.Contains(activity.imageUrl))
            {
                displayImages.Add(activity.imageUrl);
            }
            
            // Giới hạn tối đa 5 ảnh
            if (displayImages.Count > 5)
            {
                displayImages = displayImages.Take(5).ToList();
            }
            
            int totalDisplayImages = displayImages.Count;
        }
        
        @if (totalDisplayImages >= 1)
        {
            <!-- TH2: Có 1-5 ảnh → Auto-play slider -->
            <div class="image-slider auto-play" data-auto-play="true">
                <div class="slider-container" data-slides="@totalDisplayImages">
                    @for (int i = 0; i < totalDisplayImages; i++)
                    {
                        <div class="slide @(i == 0 ? "active" : "")">
                            <img src="@displayImages[i]" alt="@activity.title - Ảnh @(i+1)" 
                                 onerror="this.src='/Image/icon/thong_bao.jpg';">
                        </div>
                    }
                </div>
                
                @if (totalDisplayImages > 1)
                {
                    <div class="slider-dots">
                        @for (int i = 0; i < totalDisplayImages; i++)
                        {
                            <div class="dot @(i == 0 ? "active" : "")" onclick="goToSlide(@i)"></div>
                        }
                    </div>
                    <div class="slider-controls">
                        <button class="slider-btn prev" onclick="prevSlide()">‹</button>
                        <button class="slider-btn next" onclick="nextSlide()">›</button>
                    </div>
                }
            </div>
        }
        else
        {
            <!-- TH1: Không có ảnh → Ảnh mặc định -->
            <div class="image-slider single-image">
                <div class="slider-container">
                    <div class="slide single active">
                        <img src="/Image/icon/thong_bao.jpg" alt="@activity.title" class="activity-hero-image">
                    </div>
                </div>
            </div>
        }
        <div class="activity-header-content">
            <h1 class="activity-title">@activity.title</h1>
            <span class="activity-category">@activity.activityType</span>
            
            <div class="activity-meta">
                @if (!string.IsNullOrEmpty(activity.location))
                {
                    <div class="meta-item">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25s-7.5-4.108-7.5-11.25a7.5 7.5 0 1 1 15 0Z" />
                        </svg>
                        @activity.location
                    </div>
                }
                <div class="meta-item">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5a2.25 2.25 0 0 0 2.25-2.25m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5a2.25 2.25 0 0 1 2.25 2.25v7.5" />
                    </svg>
                    Đã xuất bản
                </div>
                @if (!string.IsNullOrEmpty(activity.createdDate))
                {
                    <div class="meta-item">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                        </svg>
                        @activity.createdDate
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="activity-content">
        <div class="activity-main">
            <h2 class="section-title">Mô tả hoạt động</h2>
            <div class="activity-description">
                @if (!string.IsNullOrEmpty(activity.description))
                {
                    @activity.description
                }
                else
                {
                    <p>Chưa có mô tả chi tiết cho hoạt động này.</p>
                }
            </div>

            @if (activity.documents != null && activity.documents.Length > 0)
            {
                <h4 style="margin-top: 30px; margin-bottom: 15px; color: #1e293b;">📁 Tài liệu hoạt động</h4>
            }
            
            @if (activity.documents != null && activity.documents.Length > 1)
            {
                <button onclick="downloadAllFiles()" class="download-all-btn">
                    📦 Tải tất cả (@activity.documents.Length files)
                </button>
            }

            @if (activity.documents != null && activity.documents.Length > 0)
            {
                <div class="file-list">
                    @for (int i = 0; i < activity.documents.Length; i++)
                    {
                        string fileName = System.IO.Path.GetFileName(activity.documents[i]);
                        if (string.IsNullOrEmpty(fileName)) 
                        { 
                            fileName = "Document " + (i + 1); 
                        }
                        
                        <div class="file-item">
                            <div>
                                <div class="file-name">📄 @fileName</div>
                                <div class="file-size">File @(i + 1)</div>
                            </div>
                            <div style="display: flex; gap: 8px;">
                                <a href="@activity.documents[i]" target="_blank" class="document-link" style="margin: 0; padding: 6px 12px; font-size: 12px;">
                                    👁️ Xem
                                </a>
                                <a href="@activity.documents[i]" download class="individual-download">
                                    ⬇️ Tải
                                </a>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <div class="activity-sidebar">
            <h3 class="section-title">Thông tin hoạt động</h3>
            <div class="info-grid">
                @if (!string.IsNullOrEmpty(activity.participants))
                {
                    <div class="info-item">
                        <div class="info-label">Người tham gia</div>
                        <div class="info-value">@activity.participants</div>
                    </div>
                }

                @if (!string.IsNullOrEmpty(activity.startDate))
                {
                    <div class="info-item">
                        <div class="info-label">Thời gian bắt đầu</div>
                        <div class="info-value" style="display: flex; align-items: center; gap: 8px;">
                            <span style="color: #3b82f6;">📅</span>
                            <span>@activity.startDate</span>
                        </div>
                    </div>
                }

                @if (!string.IsNullOrEmpty(activity.endDate))
                {
                    <div class="info-item">
                        <div class="info-label">Thời gian kết thúc</div>
                        <div class="info-value" style="display: flex; align-items: center; gap: 8px;">
                            <span style="color: #dc2626;">🏁</span>
                            <span>@activity.endDate</span>
                        </div>
                    </div>
                }

                @if (!string.IsNullOrEmpty(activity.viewCount))
                {
                    <div class="info-item">
                        <div class="info-label">Lượt xem</div>
                        <div class="info-value" style="display: flex; align-items: center; gap: 8px;">
                            <span style="color: #059669;">👁️</span>
                            <span>@activity.viewCount</span>
                        </div>
                    </div>
                }

            </div>
            
            <!-- Like Button Form -->
            <div style="margin-top: 30px; text-align: center;">
                @if (!string.IsNullOrEmpty(likeMessage))
                {
                    <div style="margin-bottom: 15px; padding: 10px; background: #d4edda; color: #155724; border-radius: 8px; font-size: 14px;">
                        @likeMessage
                    </div>
                }
                
                <form method="post" target="likeFrame" style="display: inline-block;" onsubmit="handleLikeSubmit(this)">
                    <input type="hidden" name="action" value="like" />
                    <input type="hidden" name="activityId" value="@activity.activityId" />
                    <button type="submit" class="like-button" id="likeBtn">
                        <span id="likeIcon">❤️</span>
                        <span id="likeText">Thích hoạt động</span>
                        <span id="likeCount" class="like-count-badge">@activity.likeCount</span>
                    </button>
                </form>
                
                <!-- Hidden iframe for form submission -->
                <iframe name="likeFrame" style="display: none;" onload="handleLikeResponse()"></iframe>
            </div>
        </div>
    </div>
</div>

@{
    // Tạo JavaScript array cho documents
    string documentsJson = "[]";
    if (activity.documents != null && activity.documents.Length > 0)
    {
        var docList = new List<string>();
        for (int i = 0; i < activity.documents.Length; i++)
        {
            string fileName = System.IO.Path.GetFileName(activity.documents[i]);
            if (string.IsNullOrEmpty(fileName)) 
            { 
                fileName = "Document_" + (i + 1);
            }
            
            docList.Add(string.Format("{{\"url\": \"{0}\", \"name\": \"{1}\"}}", 
                activity.documents[i].Replace("\"", "\\\"").Replace("\\", "\\\\"), 
                fileName.Replace("\"", "\\\"").Replace("\\", "\\\\")));
        }
        documentsJson = "[" + string.Join(",", docList.ToArray()) + "]";
    }
}

<!-- Hidden input to pass documents data -->
<input type="hidden" id="documentsData" value="@Html.Raw(Server.HtmlEncode(documentsJson))" />

<script type="text/javascript">
    // Activity documents data
    var activityDocuments = [];
    
    // Initialize documents array from hidden input
    function initDocuments() {
        try {
            var hiddenInput = document.getElementById('documentsData');
            if (hiddenInput && hiddenInput.value) {
                activityDocuments = JSON.parse(hiddenInput.value);
            } else {
                activityDocuments = [];
            }
        } catch(e) {
            console.error('Error parsing documents data:', e);
            activityDocuments = [];
        }
    }
    
    // Call initialization when DOM is ready
    document.addEventListener('DOMContentLoaded', initDocuments);

    // Download all files function
    function downloadAllFiles() {
        if (activityDocuments.length === 0) {
            alert('Không có tài liệu để tải xuống!');
            return;
        }

        // Show loading message
        const btn = document.querySelector('.download-all-btn');
        const originalText = btn.innerHTML;
        btn.innerHTML = '⏳ Đang tải...';
        btn.disabled = true;

        // Download each file with delay to avoid browser blocking
        activityDocuments.forEach((doc, index) => {
            setTimeout(() => {
                const link = document.createElement('a');
                link.href = doc.url;
                link.download = doc.name;
                link.style.display = 'none';
                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);
                
                // Reset button after last download
                if (index === activityDocuments.length - 1) {
                    setTimeout(() => {
                        btn.innerHTML = originalText;
                        btn.disabled = false;
                    }, 1000);
                }
            }, index * 500); // 500ms delay between downloads
        });
    }

    // Optional: Add click functionality to slider dots
    document.addEventListener('DOMContentLoaded', function() {
        const dots = document.querySelectorAll('.dot');
        const sliderContainer = document.querySelector('.slider-container');
        
        if (dots.length > 1 && sliderContainer) {
            dots.forEach((dot, index) => {
                dot.addEventListener('click', function() {
                    // Remove active class from all dots
                    dots.forEach(d => d.classList.remove('active'));
                    // Add active class to clicked dot
                    this.classList.add('active');
                    
                    // Move slider to corresponding position
                    const slideCount = parseInt(sliderContainer.getAttribute('data-slides')) || dots.length;
                    const translateX = -index * (100 / slideCount); // Dynamic percentage per slide
                    sliderContainer.style.transform = `translateX(${translateX}%)`;
                    
                    // Pause animation temporarily
                    sliderContainer.style.animationPlayState = 'paused';
                    setTimeout(() => {
                        sliderContainer.style.animationPlayState = 'running';
                    }, 3000);
                });
            });
        }
    });

    // Slider Control Functions
    let currentSlide = 0;
    let totalSlides = 0;
    let sliderContainer = null;
    let dots = [];

    // Initialize slider
    document.addEventListener('DOMContentLoaded', function() {
        const slider = document.querySelector('.image-slider');
        if (slider) {
            sliderContainer = slider.querySelector('.slider-container');
            dots = slider.querySelectorAll('.dot');
            totalSlides = dots.length;
            
            // Only auto-advance if it has auto-play class
            if (slider.classList.contains('auto-play')) {
                setInterval(() => {
                    if (!slider.matches(':hover')) {
                        nextSlide();
                    }
                }, 3000);
            }
        }
    });

    function goToSlide(slideIndex) {
        currentSlide = slideIndex;
        updateSlider();
    }

    function nextSlide() {
        currentSlide = (currentSlide + 1) % totalSlides;
        updateSlider();
    }

    function prevSlide() {
        currentSlide = (currentSlide - 1 + totalSlides) % totalSlides;
        updateSlider();
    }

    function updateSlider() {
        if (sliderContainer && dots.length > 0) {
            const slideCount = parseInt(sliderContainer.getAttribute('data-slides')) || totalSlides;
            const translateX = -currentSlide * (100 / slideCount); // Dynamic percentage per slide
            
            // Temporarily disable CSS animation
            sliderContainer.style.animation = 'none';
            sliderContainer.style.transform = `translateX(${translateX}%)`;
            
            // Update dots
            dots.forEach((dot, index) => {
                dot.classList.toggle('active', index === currentSlide);
            });
            
            // Re-enable animation after a short delay with correct animation based on slide count
            setTimeout(() => {
                const slider = document.querySelector('.image-slider');
                if (slider && slider.classList.contains('auto-play')) {
                    const slideCount = sliderContainer.getAttribute('data-slides');
                    switch(slideCount) {
                        case '2':
                            sliderContainer.style.animation = 'slideShow2 8s infinite ease-in-out';
                            break;
                        case '3':
                            sliderContainer.style.animation = 'slideShow3 12s infinite ease-in-out';
                            break;
                        case '4':
                            sliderContainer.style.animation = 'slideShow4 16s infinite ease-in-out';
                            break;
                        case '5':
                            sliderContainer.style.animation = 'slideShow5 20s infinite ease-in-out';
                            break;
                        default:
                            sliderContainer.style.animation = 'slideShow3 12s infinite ease-in-out';
                    }
                }
            }, 500);
        }
    }

    // Like functionality with iframe (no page reload)
    let currentLikeCount = parseInt('@activity.likeCount') || 0;
    let isSubmitting = false;

    function handleLikeSubmit(form) {
        if (isSubmitting) return false;
        
        isSubmitting = true;
        const btn = document.getElementById('likeBtn');
        const icon = document.getElementById('likeIcon');
        const text = document.getElementById('likeText');
        const count = document.getElementById('likeCount');
        
        // Update UI immediately
        btn.classList.add('liked');
        icon.textContent = '💖';
        text.textContent = 'Đã thích';
        currentLikeCount++;
        count.textContent = currentLikeCount;
        
        // Disable button temporarily
        btn.disabled = true;
        
        return true; // Allow form submission
    }

    function handleLikeResponse() {
        // This runs when iframe loads (form submitted)
        setTimeout(() => {
            const btn = document.getElementById('likeBtn');
            btn.disabled = false;
            isSubmitting = false;
            
            // Show success message
            showLikeMessage('Đã thích hoạt động này! ❤️');
        }, 500);
    }

    function showLikeMessage(message) {
        // Create or update message div
        let messageDiv = document.getElementById('likeMessage');
        if (!messageDiv) {
            messageDiv = document.createElement('div');
            messageDiv.id = 'likeMessage';
            messageDiv.style.cssText = 'margin-bottom: 15px; padding: 10px; background: #d4edda; color: #155724; border-radius: 8px; font-size: 14px; animation: fadeIn 0.5s ease;';
            
            const likeContainer = document.querySelector('.like-button').parentElement.parentElement;
            likeContainer.insertBefore(messageDiv, likeContainer.firstChild);
        }
        
        messageDiv.textContent = message;
        messageDiv.style.display = 'block';
        
        // Hide after 3 seconds
        setTimeout(() => {
            messageDiv.style.display = 'none';
        }, 3000);
    }
</script>